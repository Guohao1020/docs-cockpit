    openDrawer('module-drawer');
  }

  // ── 0.8.0 · prompt 复制(给 vibe-coding 编辑器生成 plan/RFC/spec)──
  // 把 {key} 占位符替换成 vars[key] 的值 · 支持同一占位符多次出现(replaceAll)
  function fillTemplate(tmpl, vars) {
    return String(tmpl == null ? '' : tmpl).replace(/\{(\w+)\}/g, (m, k) => (
      (vars && Object.prototype.hasOwnProperty.call(vars, k))
        ? String(vars[k])
        : m
    ));
  }

  // clipboard:首选 navigator.clipboard · 失败 fallback 到 textarea + execCommand
  // (file:// 上下文 + Firefox 严格策略时需要 fallback)
  function copyText(text, onSuccess, onError) {
    function fallback() {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.top = '-9999px';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.focus(); ta.select();
      let ok = false;
      try { ok = document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
      if (ok && onSuccess) onSuccess();
      else if (onError) onError();
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(
        () => { if (onSuccess) onSuccess(); },
        () => fallback()
      );
    } else {
      fallback();
    }
  }

  // 0.9.0:拆出 buildDocPrompt · 返回填好变量的提示词文本(不复制)
  // 让 CTA 面板的 tab 切换能先 preview 再让用户决定是否 Copy
  function buildDocPrompt(moduleId, kind) {
    const m = getModule(moduleId);
    if (!m) return '';
    const today = new Date().toISOString().slice(0, 10);
    const desc = (m.desc || '').trim();
    const excerpt = (m.bodyExcerpt || '').trim();
    // 描述优先 · 没有就用 body 摘要 · 都没有就给个占位提示
    const descOrExcerpt = desc.length >= 20
      ? desc
      : (excerpt
          ? excerpt
          : t('prompt.no_context_placeholder'));
    const projectName = (RAW.project && RAW.project.name) || 'this project';
    const tmpl = t('prompt.' + kind);
    if (!tmpl || tmpl === ('prompt.' + kind)) {
      return '';
    }
    return fillTemplate(tmpl, {
      project: projectName,
      id: m.id,
      idLower: m.id.toLowerCase(),
      title: m.title || '',
      status: m.status || 'not-started',
      sprint: m.sprint || '—',
      progress: (m.progress == null ? 0 : m.progress),
      path: m.path || '',
      date: today,
      descOrExcerpt: descOrExcerpt,
    });
  }

  // 旧接口保留 · 直接 build → copy(仍然给键盘快捷键 / 老调用兜底用)
  function copyDocPrompt(moduleId, kind) {
    const text = buildDocPrompt(moduleId, kind);
    if (!text) { toast(t('toast.copy_failed')); return; }
    copyText(
      text,
      () => toast(t('toast.prompt_copied_' + kind)),
      () => toast(t('toast.copy_failed'))
    );
  }

  // ── 0.7.1 · drawer 内联 MD 预览 ──────────────────────────
  // 不重开 drawer · 只换 #md-body 内容(drawer-head 保持模块上下文 · 标识"还在这个模块")
  // back 按钮 → 调 openModuleDrawer(_activeModuleId) 恢复模块视图
  function showDocPreview(moduleId, docIndex) {
    const m = getModule(moduleId);
    if (!m) return;
    const d = (m.docs || [])[docIndex];
    if (!d) return;
    const body = document.getElementById('md-body');
    if (!body) return;

    const backBtnHtml =
      '<button type="button" class="pv-back" id="pv-back">' +
        '<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2.5L4 6l4 3.5"/></svg>' +
        '<span>' + escapeHtml(t('drawer.docs_back')) + '</span>' +
      '</button>';

    const exists = (d.exists !== false);
    const showPath = d.resolved || d.path || '';
    const headHtml =
      '<div class="doc-preview-head">' +
        backBtnHtml +
        '<div class="pv-meta">' +
          '<div class="pv-title">' + escapeHtml(d.title || '') + '</div>' +
          '<div class="pv-path">' + escapeHtml(showPath) + '</div>' +
          (d.mtime ? '<div class="pv-mtime">' + escapeHtml(d.mtime) + '</div>' : '') +
        '</div>' +
      '</div>';

    let contentHtml;
    if (!exists) {
      // 文件不存在 · drawer 内提示 · 不跳出浏览器
      contentHtml =
        '<div class="doc-preview-missing">' +
          '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_missing_title')) + '</div>' +
          '<div>' + escapeHtml(t('drawer.docs_missing_hint')) + '</div>' +
          '<div class="pv-missing-path">' + escapeHtml(d.path || '') + '</div>' +
        '</div>';
    } else if (d.content) {
      // 有 content → marked 渲染(CDN 失败时 fallback 到 <pre> · 见底部 CDN guard)
      let rendered;
      try {
        rendered = (typeof marked !== 'undefined' && marked.parse)
          ? marked.parse(d.content)
          : '<pre>' + escapeHtml(d.content) + '</pre>';
      } catch (e) {
        rendered = '<pre>' + escapeHtml(d.content) + '</pre>';
      }
      contentHtml = '<div class="doc-preview-body">' + rendered + '</div>';
    } else {
      // 非 .md / .markdown 或文件过大 → 尝试浏览器原生打开(图片 / PDF 等)
      // 用 file:// URL(resolved 是绝对路径)
      const url = d.resolved
        ? 'file:///' + d.resolved.replace(/\\/g, '/').replace(/^\/+/, '')
        : d.path;
      try { window.open(url, '_blank'); } catch (e) {}
      contentHtml =
        '<div class="doc-list-empty">' +
          escapeHtml(t('drawer.docs_open_external')) +
        '</div>';
    }

    body.innerHTML = headHtml + contentHtml;

    // 0.7.2:预览模式加宽 drawer · 让 MD 表格 / 代码块 / 长行有空间
    const drawer = document.getElementById('module-drawer');
    if (drawer) drawer.classList.add('wide');

    // 语法高亮
    if (d.content && typeof hljs !== 'undefined' && hljs.highlightElement) {
      body.querySelectorAll('.doc-preview-body pre code').forEach(b => {
        try { hljs.highlightElement(b); } catch (e) {}
      });
    }

    // 绑 back
    const backBtn = body.querySelector('#pv-back');
    if (backBtn) {
      backBtn.addEventListener('click', () => openModuleDrawer(moduleId));
    }

    // 滚到顶
    body.scrollTop = 0;
  }

