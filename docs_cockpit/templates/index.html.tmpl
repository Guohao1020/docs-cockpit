<script>
(function() {
  'use strict';

  // ── 数据 + 持久化 ─────────────────────────────────────
  const RAW = JSON.parse(document.getElementById('project-data').textContent);
  const STORAGE_KEY = 'project-kanban-state-v1';
  const BUILD_TIME = (RAW.project && RAW.project.lastBuild) || '';

  // 0.11.3 · plan §1 缺口 3 修复:override 跟 source-of-truth 漂移
  //
  // 老语义:override 永远赢 → 用户某次点过的 subtask 状态硬覆盖后续 build 的 MD 真值。
  // 新语义:每次 build 之后 · 自动失效**上一 build 的 subtask 级 override**
  //         · let source MD 重新接管 · 在同一 build 内用户的 toggle 仍持久。
  // 保留:module 级 override(status select / progress slider)· 这种是用户长期意图 ·
  //         不该被 build 弹回。
  function loadOverrides() {
    try {
      const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      const last_built = stored._built_at || '';
      if (BUILD_TIME && last_built && last_built !== BUILD_TIME) {
        // build 刷过了 · subtask 级 override 全部失效 · 让 source MD 真值接管
        const fresh = { _built_at: BUILD_TIME };
        for (const k of Object.keys(stored)) {
          if (k === '_built_at') continue;
          if (k.indexOf('__st__') !== -1) continue;  // subtask 级 · 失效
          fresh[k] = stored[k];                       // module 级 · 保留
        }
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(fresh)); } catch (e) {}
        return fresh;
      }
      if (!stored._built_at) stored._built_at = BUILD_TIME;
      return stored;
    } catch (e) { return {}; }
  }
  function saveOverrides(map) {
    try {
      map._built_at = BUILD_TIME;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(map));
    } catch (e) {}
  }

  const overrides = loadOverrides();

  // 0.11.0-alpha.5:把老 index-based subtask key `MID__stN` 清掉 · 避免跟新
  // id-based key `MID__st__<sha1-id>` 混淆 + 出现 33% 这种错位显示。
  // 一次性 migration · 跑完写回 localStorage · 老用户下次打开看不到老 key。
  (function migrateOldSubtaskKeys() {
    let dirty = false;
    for (const k of Object.keys(overrides)) {
      // 老格式:`M<id>__st<digit>` · 比如 `M02__st3`
      if (/^[^_]+__st\d+$/.test(k)) {
        delete overrides[k];
        dirty = true;
      }
    }
    if (dirty) saveOverrides(overrides);
  })();

  // merge: 用户存储的覆盖优先
  function getModule(id) {
    const base = RAW.modules.find(m => m.id === id);
    if (!base) return null;
    const ov = overrides[id] || {};
    // 0.11.0-alpha.5 · 用 stable subtask.id(v0.11 W1 加的 sha1 算)而不是 index
    // 老 index-based key `id__stN` 留 localStorage 里 orphan · 不影响新 key
    const subtasks = (base.subtasks || []).map((st, i) => {
      const stKey = st.id || ('idx-' + i);   // v0.10 fallback
      const k = id + '__st__' + stKey;
      return { ...st, done: (k in overrides) ? !!overrides[k] : st.done };
    });
    const m = {
      ...base,
      subtasks,
      status: ov.status || base.status,
      manualProgress: ('manualProgress' in ov) ? ov.manualProgress : base.manualProgress,
      progress: ('progress' in ov) ? ov.progress : base.progress
    };
    if (!m.manualProgress && m.subtasks.length > 0) {
      const done = m.subtasks.filter(s => s.done).length;
      m.progress = Math.round((done / m.subtasks.length) * 100);
    }
    if (m.progress === 100 && m.status !== 'done' && !ov.status) m.status = 'done';
    if (m.progress > 0 && m.progress < 100 && m.status === 'not-started' && !ov.status) m.status = 'in-progress';
    return m;
  }

  function allModules() {
    return RAW.modules.map(m => getModule(m.id));
  }

  // ── 工具 ─────────────────────────────────────────────
  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
