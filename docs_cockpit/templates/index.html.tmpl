        '## 工具提示',
        '',
        '- **superpowers** 用户:技能包里有就试 `/spec`',
        '- **gstack** 用户:走 spec-init 之类的命令',
        '- **Cursor / Codex / Continue / Aider**:整段提示词粘贴到 chat',
        '',
        '---',
        '_由 docs-cockpit 生成 · 本 module 未关联 docs · 请补一份。_'
      ].join('\n'),
      'drawer.docs_preview': '预览',
      'drawer.docs_open': '打开',
      'drawer.docs_back': '← 返回模块',
      'drawer.docs_missing_title': '找不到文件',
      'drawer.docs_missing_hint': '已依次尝试:绝对路径 · 相对源 MD · 相对仓库根 · 均未找到该文件。',
      'drawer.docs_missing_tooltip': '未找到:{path}',
      'drawer.docs_open_external': '正在用浏览器新标签打开此文件 · 该类型不在抽屉内联渲染。',
      'sysdocs.eyebrow': '系统文档 · MEMORY & GUIDES',
      'sysdocs.title': '项目级文档与记忆',
      'sysdocs.section_label': '常驻文档',
      'sysdocs.count_items': '{n} 项',
      'sysdocs.tip_label': '提示',
      'sysdocs.tip_body': '在数据配置中,把 <code style="font-family:var(--f-mono); background: var(--c-cloud); padding: 1px 6px; border-radius: 3px;">systemDocs</code> 数组按需要扩展;每条 <code style="font-family:var(--f-mono); background: var(--c-cloud); padding: 1px 6px; border-radius: 3px;">{ id, title, path, desc, icon }</code> 将作为一个入口出现在此抽屉。',
      'sysdocs.empty': '尚未配置系统文档',
      'toast.saved': '已保存',
      'toast.status_updated': '状态已更新',
      'toast.progress_updated': '进度已更新 · {n}%',
      'toast.progress_set': '进度已设为 {n}%',
      'status.not-started': '未启动',
      'status.planned': '已排期',
      'status.in-progress': '进行中',
      'status.blocked': '阻塞',
      'status.done': '已完成',
      'status.deferred': '已推迟',
    }
  };

  let LANG = (() => {
    try { return localStorage.getItem(STORAGE_KEY + '::lang') || 'en'; }
    catch (e) { return 'en'; }
  })();

  function t(key, vars) {
    let s = (I18N[LANG] && I18N[LANG][key]) || I18N.en[key] || key;
    if (vars) for (const k in vars) s = s.split('{' + k + '}').join(vars[k]);
    return s;
  }

  // Lang-aware status label · still usable as STATUS_LABEL[key] for legacy call-sites
  const STATUS_LABEL = new Proxy({}, {
    get(_, s) { return t('status.' + s) || s; }
  });
  // English-locked label for places that want the EN form regardless
  const STATUS_LABEL_EN = new Proxy({}, {
    get(_, s) { return I18N.en['status.' + s] || s; }
  });

  function applyI18nStatic() {
    document.documentElement.lang = (LANG === 'zh' ? 'zh-CN' : 'en');
    document.querySelectorAll('[data-i18n]').forEach(el => {
      el.innerHTML = t(el.dataset.i18n);
    });
    document.querySelectorAll('[data-i18n-title]').forEach(el => {
      el.title = t(el.dataset.i18nTitle);
    });
    document.querySelectorAll('[data-i18n-aria]').forEach(el => {
      el.setAttribute('aria-label', t(el.dataset.i18nAria));
    });
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === LANG);
    });
  }

  // ── 文件类型推断(用于文档行的标签) ────────────────
  function fileExt(path) {
    const m = /\.([a-zA-Z0-9]+)$/.exec(path || '');
    return m ? m[1].toUpperCase() : (path && path.endsWith('/') ? 'DIR' : 'LINK');
  }

  // ── 项目基础信息 ─────────────────────────────────────
  function renderProjectMeta() {
    const p = RAW.project || {};
    const fallback = t('topbar.crumb');
    document.getElementById('brand-name').textContent = p.name || fallback;
    document.getElementById('brand-mark').textContent = (p.mark || (p.name || 'P').slice(0, 1)).toUpperCase();
    document.getElementById('hero-title').textContent = p.name || t('hero.title');
    if (p.tagline) document.getElementById('hero-tagline').textContent = p.tagline;
    if (p.eyebrow) document.getElementById('hero-eyebrow').textContent = p.eyebrow;
    document.getElementById('build-time').textContent = p.lastBuild || '—';
    document.title = (p.name || fallback) + ' · ' + t('topbar.crumb');
  }

  // ── KPI + 总进度 ─────────────────────────────────────
  function renderKpi() {
    const mods = allModules();
    const total = mods.length;
    const byStatus = {};
    STATUS_ORDER.forEach(s => byStatus[s] = 0);
    mods.forEach(m => byStatus[m.status] = (byStatus[m.status] || 0) + 1);

    document.getElementById('kpi-total').textContent = total;
    document.getElementById('kpi-done').textContent = byStatus['done'] || 0;
    document.getElementById('kpi-progress').textContent = (byStatus['in-progress'] || 0) + (byStatus['planned'] || 0);
    document.getElementById('kpi-progress-active').textContent = byStatus['in-progress'] || 0;
    document.getElementById('kpi-progress-planned').textContent = byStatus['planned'] || 0;
    document.getElementById('kpi-todo').textContent = (byStatus['not-started'] || 0) + (byStatus['blocked'] || 0);
    document.getElementById('kpi-blocked').textContent = byStatus['blocked'] || 0;
    const cn = (RAW.concepts || []).length;
    document.getElementById('kpi-concept-count').textContent = cn;
    document.getElementById('concept-meta').textContent = t('concept.meta_count', { n: cn });
    document.getElementById('kpi-meta').textContent = t('kpi.meta_sum', { m: total, c: cn });

    const overall = total ? Math.round(mods.reduce((a, m) => a + (m.progress || 0), 0) / total) : 0;
    document.getElementById('overall-pct').textContent = overall;
    document.getElementById('overall-fill').style.width = overall + '%';
  }

  // ── Kanban ───────────────────────────────────────────
  function renderKanban() {
    const root = document.getElementById('kanban');
    root.innerHTML = '';
    const grouped = {};
    STATUS_ORDER.forEach(s => grouped[s] = []);
    allModules().forEach(m => {
      if (!grouped[m.status]) grouped[m.status] = [];
      grouped[m.status].push(m);
    });

    STATUS_ORDER.forEach(s => {
      const col = document.createElement('div');
      col.className = 'k-col s-' + s;
      const items = grouped[s] || [];
      let inner = '<div class="k-col-head">' +
        '<span class="name"><span class="glyph"></span>' + STATUS_LABEL[s] + '</span>' +
        '<span class="count">' + items.length + '</span>' +
      '</div>';
      if (items.length === 0) {
        inner += '<div class="k-col-empty">—</div>';
      } else {
        inner += items.map(m => {
          const hasDocs = (m.docs && m.docs.length) ? m.docs.length : 0;
          // 0.8.0:active 状态(in-progress/planned/blocked)无 docs → 显示"需要补 docs"chip
          const isActive = (m.status === 'in-progress' || m.status === 'planned' || m.status === 'blocked');
          const docPill = hasDocs
            ? '<span class="doc-pill" title="' + escapeHtml(t('kanban.doc_count_title', { n: hasDocs })) + '"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/></svg>' + hasDocs + '</span>'
            : (isActive
                ? '<span class="doc-pill needs-docs" title="' + escapeHtml(t('kanban.needs_docs_title')) + '"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6.5"/><line x1="8" y1="5" x2="8" y2="9"/><circle cx="8" cy="11.5" r="0.5" fill="currentColor"/></svg>' + escapeHtml(t('kanban.needs_docs_chip')) + '</span>'
                : '');
          return '<div class="m-card" data-id="' + escapeHtml(m.id) + '" tabindex="0" role="button" aria-label="' + escapeHtml(m.id + ' ' + m.title) + '">' +
            '<div class="m-id"><span>' + escapeHtml(m.id) + '</span>' + docPill + '</div>' +
            '<div class="m-title">' + escapeHtml(m.title) + '</div>' +
            '<div class="m-meta">' +
              '<span class="m-sprint">' + escapeHtml(m.sprint || '—') + '</span>' +
              '<span class="m-pct">' + (m.progress || 0) + '%</span>' +
            '</div>' +
            '<div class="bar"><div class="bar-fill" style="width:' + (m.progress || 0) + '%"></div></div>' +
          '</div>';
        }).join('');
      }
      col.innerHTML = inner;
      root.appendChild(col);
    });

    // 绑事件
    // 0.11.0-alpha.6 §4.b · click 走 hash router(navigateTo)· `?ui=modal` 时
    // 回退到老 openModuleDrawer · 向后兼容
    root.querySelectorAll('.m-card').forEach(el => {
      el.addEventListener('click', () => navigateTo('module', el.dataset.id));
      el.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          navigateTo('module', el.dataset.id);
        }
      });
    });
  }

  // ── Sprints ──────────────────────────────────────────
  function renderSprints() {
    const root = document.getElementById('sprints');
    if (!root) return;
    const mods = allModules();
    const bySprint = {};
    mods.forEach(m => {
      const sp = m.sprint || '—';
      if (!bySprint[sp]) bySprint[sp] = [];
      bySprint[sp].push(m);
    });
    const names = Object.keys(bySprint).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN-u-kn-true'));
    if (!names.length) { root.innerHTML = '<div class="k-col-empty">' + escapeHtml(t('sprint.empty')) + '</div>'; return; }
    root.innerHTML = names.map(sp => {
      const items = bySprint[sp];
      const avg = Math.round(items.reduce((a, m) => a + (m.progress || 0), 0) / items.length);
      const cls = avg === 100 ? 's-done' : (avg > 0 ? 's-active' : '');
      return '<div class="sprint-row ' + cls + '">' +
        '<div class="s-name"><span class="s-dot"></span>' + escapeHtml(sp) + '</div>' +
        '<div class="s-bar"><div class="s-bar-fill" style="width:' + avg + '%"></div></div>' +
        '<div class="s-pct">' + avg + '%</div>' +
        '<div class="s-count">' + items.length + ' ' + escapeHtml(t('sprint.modules_suffix')) + '</div>' +
      '</div>';
    }).join('');
  }

  // ── Concepts ─────────────────────────────────────────
  function renderConcepts() {
    const root = document.getElementById('concepts');
    if (!root) return;
    const list = RAW.concepts || [];
    if (!list.length) { document.getElementById('concepts-section').style.display = 'none'; return; }
    root.innerHTML = list.map(c => (
      '<div class="c-chip">' +
        '<div class="c-id"><span>' + escapeHtml(c.id) + '</span><span class="c-sprint">' + escapeHtml(c.sprint || '—') + '</span></div>' +
        '<div class="c-title"><span class="c-status-dot s-' + c.status + '"></span>' + escapeHtml(c.title) + '</div>' +
        '<div class="bar"><div class="bar-fill" style="width:' + (c.progress || 0) + '%; background:' + statusColor(c.status) + '"></div></div>' +
        '<div class="c-pct">' + (c.progress || 0) + '%</div>' +
      '</div>'
    )).join('');
  }

  function statusColor(s) {
    return {
      'done': 'var(--s-done)',
      'in-progress': 'var(--s-progress)',
      'planned': 'var(--s-planned)',
      'blocked': 'var(--s-blocked)',
      'not-started': 'var(--s-todo)',
      'deferred': 'var(--s-deferred)'
    }[s] || 'var(--c-ink)';
  }

  // ── Module Drawer ────────────────────────────────────
  let _activeModuleId = null;
  function openModuleDrawer(id) {
    const m = getModule(id);
    if (!m) return;
    _activeModuleId = id;
    // 0.7.2:从 doc 预览返回模块视图时 · 收回 drawer 宽度
    const _drawer = document.getElementById('module-drawer');
    if (_drawer) _drawer.classList.remove('wide');

    document.getElementById('md-meta').innerHTML =
      '<span class="dot s-' + m.status + '"></span>' +
      '<span style="font-family: var(--f-mono);">' + escapeHtml(m.id) + '</span>' +
      '<span>·</span>' +
      '<span>' + STATUS_LABEL[m.status] + '</span>' +
      '<span>·</span>' +
      '<span>' + escapeHtml(m.sprint || '—') + '</span>';
    document.getElementById('md-title').textContent = m.title;

    const body = document.getElementById('md-body');

    // description
    const descHtml = m.desc
      ? '<div class="desc">' + escapeHtml(m.desc) + '</div>'
      : '<div class="desc empty">' + escapeHtml(t('drawer.desc_empty')) + '</div>';

    // docs · 0.7.1:button + 内联预览(有 content 时 marked 渲染 · 否则 file:// 打开)
    let docsHtml;
    if (m.docs && m.docs.length) {
      docsHtml = '<div class="doc-list">' + m.docs.map((d, i) => {
        // 兼容老 payload:exists 未定义视为存在 · content 未定义视为不可内联
        const exists = (d.exists !== false);
        const hasContent = !!(d.content && d.content.length);
        const rowClasses = ['doc-row'];
        if (!exists) rowClasses.push('missing');
        if (hasContent) rowClasses.push('has-content');
        const action = !exists
          ? ''
          : (hasContent
              ? t('drawer.docs_preview')
              : t('drawer.docs_open'));
        const actionSpan = action
          ? '<span class="doc-action">' + escapeHtml(action) + '</span>'
          : '';
        // 展示用 path:优先用解析后的绝对路径(用户能看到 docs/docs/ 这种 bug 的真实位置)
        const showPath = d.resolved || d.path || '';
        const titleAttr = !exists
          ? t('drawer.docs_missing_tooltip', { path: d.path || '' })
          : (d.mtime || '');
        return (
          '<button type="button" class="' + rowClasses.join(' ') + '"' +
            ' data-doc-i="' + i + '"' +
            ' title="' + escapeHtml(titleAttr) + '">' +
            '<svg class="doc-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/><line x1="5.5" y1="8" x2="10.5" y2="8"/><line x1="5.5" y1="10.5" x2="9" y2="10.5"/></svg>' +
            '<div class="doc-info"><div class="doc-title">' + escapeHtml(d.title) + '</div><div class="doc-path">' + escapeHtml(showPath) + '</div></div>' +
            actionSpan +
            '<span class="doc-ext">' + escapeHtml(fileExt(showPath)) + '</span>' +
          '</button>'
        );
      }).join('') + '</div>';
    } else {
      // 0.9.0:替换"无关联文档"为 CTA 面板 · tab 切换 + 提示词原文展示 + 单 Copy 按钮
      // 让用户先看清提示词内容(prompt 长度 / 替换变量是否正确 / 是否要手工微调)再决定复制
      docsHtml =
        '<div class="docs-empty-cta">' +
          '<div class="cta-title">' +
            '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="6.5"/><line x1="8" y1="5" x2="8" y2="9"/><circle cx="8" cy="11.5" r="0.5" fill="currentColor"/></svg>' +
            '<span>' + escapeHtml(t('empty_docs.title')) + '</span>' +
          '</div>' +
          '<div class="cta-hint">' + t('empty_docs.hint') + '</div>' +
          '<div class="cta-tabs" role="tablist">' +
            '<button type="button" data-prompt-kind="plan" class="active" role="tab" aria-selected="true">' + escapeHtml(t('empty_docs.tab_plan')) + '</button>' +
            '<button type="button" data-prompt-kind="rfc" role="tab" aria-selected="false">' + escapeHtml(t('empty_docs.tab_rfc')) + '</button>' +
            '<button type="button" data-prompt-kind="spec" role="tab" aria-selected="false">' + escapeHtml(t('empty_docs.tab_spec')) + '</button>' +
          '</div>' +
          '<div class="cta-tab-desc" id="cta-tab-desc">' + escapeHtml(t('empty_docs.tab_plan_desc')) + '</div>' +
          '<pre class="cta-prompt-view" id="cta-prompt-view"></pre>' +
          '<div class="cta-copy-row">' +
            '<button type="button" class="cta-copy-btn" id="cta-copy-btn">' +
              '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4.5" y="2.5" width="9" height="11" rx="1"/><path d="M2.5 11.5V4.5a1 1 0 0 1 1-1H4"/></svg>' +
              '<span id="cta-copy-label">' + escapeHtml(t('empty_docs.copy_btn')) + '</span>' +
            '</button>' +
            '<span class="cta-copy-meta" id="cta-copy-meta"></span>' +
          '</div>' +
          '<div class="cta-tools-hint">' + escapeHtml(t('empty_docs.tools_hint')) + '</div>' +
        '</div>';
    }

    // status select
    const statusHtml = '<div class="status-select">' + STATUS_ORDER.map(s => (
      '<button data-status="' + s + '"' + (s === m.status ? ' class="active"' : '') + '>' +
        '<span class="ss-dot s-' + s + '"></span>' +
        '<span>' + escapeHtml(STATUS_LABEL[s]) + '</span>' +
      '</button>'
    )).join('') + '</div>';

    // subtasks
    let subtasksHtml = '';
    if (m.subtasks && m.subtasks.length) {
      subtasksHtml = '<div class="subtasks">' + m.subtasks.map((st, i) => {
        // 0.11.0-alpha.5 · 用 stable subtask.id 作 data-st-key · 跟 getModule + toggle 一致
        const stKey = st.id || ('idx-' + i);
        // 0.11.0-alpha.6 §4.e · code_anchors[] 图标(alpha.2 backend)+ Copy prompt 按钮(alpha.3 sidecar)
        let extrasHtml = '';
        if (st.code_anchors && st.code_anchors.length) {
          // 第一条 anchor 显图标 · 多 anchor 时 click 渲染所有(右栏)
          const ca = st.code_anchors[0];
          const anchorOk = ca && ca.exists && !ca.warning;
          extrasHtml += '<button type="button" class="st-code-btn' + (anchorOk ? '' : ' stale') + '" data-st-key="' + escapeHtml(stKey) + '" title="' + escapeHtml(anchorOk ? (ca.path + (ca.lines ? ':' + ca.lines : '')) : (ca.warning || 'stale anchor')) + '">' +
            '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 4 2 8 6 12"/><polyline points="10 4 14 8 10 12"/></svg>' +
          '</button>';
        }
        // Copy prompt 按钮(只在 prompts.js 已加载时显)
        extrasHtml += '<button type="button" class="st-prompt-btn" data-st-key="' + escapeHtml(stKey) + '" title="Copy prompt for this subtask">' +
          '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="9" height="11" rx="1.5"/><path d="M3 5v8.5A1.5 1.5 0 0 0 4.5 15h7"/></svg>' +
        '</button>';
        return '<div class="st' + (st.done ? ' done' : '') + '" data-st-key="' + escapeHtml(stKey) + '" tabindex="0" role="checkbox" aria-checked="' + st.done + '">' +
          '<span class="check"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 6.5l2.5 2.5 4.5-5"/></svg></span>' +
          '<span class="st-text">' + escapeHtml(st.title) + '</span>' +
          '<span class="st-extras">' + extrasHtml + '</span>' +
        '</div>';
      }).join('') + '</div>';
    } else {
      subtasksHtml = '<div class="doc-list-empty">' + escapeHtml(t('drawer.subtasks_empty')) + '</div>';
    }
    const doneCount = (m.subtasks || []).filter(s => s.done).length;
    const subtaskMeta = (m.subtasks && m.subtasks.length)
      ? t('drawer.subtasks_meta', { done: doneCount, total: m.subtasks.length })
      : t('drawer.subtasks_empty_dash');

    // progress control
    const hasSubtasks = m.subtasks && m.subtasks.length > 0;
    const isManual = m.manualProgress || !hasSubtasks;
    const progressHtml =
      '<div class="progress-control">' +
        '<div class="pc-head">' +
          '<span class="pc-num">' + (m.progress || 0) + '%</span>' +
          '<label class="toggle-row" title="' + escapeHtml(t('drawer.manual_tip')) + '">' +
            '<input type="checkbox" id="manual-toggle"' + (isManual ? ' checked' : '') + (hasSubtasks ? '' : ' disabled') + '>' +
            '<span class="toggle"></span>' +
            '<span>' + escapeHtml(t('drawer.manual_toggle')) + '</span>' +
          '</label>' +
        '</div>' +
        '<input type="range" min="0" max="100" step="1" value="' + (m.progress || 0) + '" id="pc-slider"' + (!isManual ? ' disabled' : '') + '>' +
        '<div class="pc-ticks"><span>0</span><span>25</span><span>50</span><span>75</span><span>100</span></div>' +
        '<div class="pc-steps">' +
          '<button data-step="0">0%</button>' +
          '<button data-step="25">25%</button>' +
          '<button data-step="50">50%</button>' +
          '<button data-step="75">75%</button>' +
          '<button data-step="100">100%</button>' +
        '</div>' +
      '</div>';

    body.innerHTML =
      '<div class="d-section">' +
        '<div class="d-label">' + escapeHtml(t('drawer.desc_label')) + '</div>' +
        descHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.status_label')) + '</span><span class="right">' + escapeHtml(STATUS_LABEL_EN[m.status]) + '</span></div>' +
        statusHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.progress_label')) + '</span><span class="right">' + escapeHtml(isManual ? t('drawer.progress_manual') : t('drawer.progress_auto')) + '</span></div>' +
        progressHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.subtasks_label')) + '</span><span class="right">' + escapeHtml(subtaskMeta) + '</span></div>' +
        subtasksHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.docs_label')) + '</span><span class="right">' + escapeHtml(t('drawer.docs_meta_items', { n: ((m.docs && m.docs.length) || 0) })) + '</span></div>' +
        docsHtml +
      '</div>';

    // 绑事件:status
    body.querySelectorAll('.status-select button').forEach(btn => {
      btn.addEventListener('click', () => {
        const newStatus = btn.dataset.status;
        const ov = overrides[id] || {};
        ov.status = newStatus;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
        toast(t('toast.status_updated'));
      });
    });

    // 绑事件:slider
    const slider = body.querySelector('#pc-slider');
    if (slider) {
      slider.addEventListener('input', e => {
        const v = parseInt(e.target.value, 10);
        body.querySelector('.pc-num').textContent = v + '%';
      });
      slider.addEventListener('change', e => {
        const v = parseInt(e.target.value, 10);
        const ov = overrides[id] || {};
        ov.progress = v;
        ov.manualProgress = true;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        toast(t('toast.progress_updated', { n: v }));
      });
    }
    // 绑:快捷 25/50/75/100
    body.querySelectorAll('.pc-steps button').forEach(b => {
      b.addEventListener('click', () => {
        const v = parseInt(b.dataset.step, 10);
        if (slider) {
          slider.disabled = false;
          slider.value = v;
        }
        const ov = overrides[id] || {};
        ov.progress = v;
        ov.manualProgress = true;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
        toast(t('toast.progress_set', { n: v }));
      });
    });
    // 绑:手动切换
    const manualToggle = body.querySelector('#manual-toggle');
    if (manualToggle) {
      manualToggle.addEventListener('change', e => {
        const isManual = e.target.checked;
        const ov = overrides[id] || {};
        ov.manualProgress = isManual;
        if (!isManual) delete ov.progress;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
      });
    }
    // 绑:子任务
    body.querySelectorAll('.st').forEach(stEl => {
      const toggleSt = (e) => {
        // 0.11.0-alpha.6 §4.e · 如果 click 落在 extras 按钮(code/prompt)· 不切 toggle
        if (e && e.target && e.target.closest('.st-extras')) return;
        // 0.11.0-alpha.5 · 用 stable subtask.id · 跟 getModule render 一致
        const stKey = stEl.dataset.stKey;
        const k = id + '__st__' + stKey;
        const cur = stEl.classList.contains('done');
        overrides[k] = !cur;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
      };
      stEl.addEventListener('click', toggleSt);
      stEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleSt(); }
      });
    });

    // 0.11.0-alpha.6 §4.e · code anchor 图标 click · 渲染 code preview 到右栏(仅 split-mode 有意义 · modal 也允许)
    body.querySelectorAll('.st-code-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const stKey = btn.dataset.stKey;
        const st = (m.subtasks || []).find(s => (s.id || '').toString() === stKey);
        if (!st || !st.code_anchors || !st.code_anchors.length) return;
        renderSplitPreviewCode(st);
      });
    });
    // 0.11.0-alpha.6 §4.e · Copy prompt 按钮 click · 走 alpha.3 prompts.js sidecar
    body.querySelectorAll('.st-prompt-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const stKey = btn.dataset.stKey;
        copySubtaskPrompt(stKey);
      });
    });

    // 0.7.1:绑 docs 按钮 · 有 content 走内联预览 · 否则尝试 file:// 打开 · 缺失则弹错
    // 0.11.0-alpha.6 §4.d · split-mode 下 · click 走 split-preview · 不弹 drawer 内嵌预览
    body.querySelectorAll('.doc-list button.doc-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.docI, 10);
        const d = (m.docs || [])[i];
        if (!d) return;
        if (document.body.classList.contains('split-mode')) {
          renderSplitPreviewDoc(d, btn);
        } else {
          showDocPreview(id, i);
        }
      });
    });

    // 0.11.0-alpha.6 §4.d · split-mode 进入时 · 默认右栏渲染第一条 linked doc
    if (document.body.classList.contains('split-mode')) {
      const firstDocBtn = body.querySelector('.doc-list button.doc-row');
      if (firstDocBtn && m.docs && m.docs.length) {
        renderSplitPreviewDoc(m.docs[0], firstDocBtn);
      } else {
        renderSplitPreviewEmpty();
      }
    }

    // 0.9.0:绑 empty-docs CTA · tab 切换 + 实时渲染 prompt + 单 Copy 按钮
    // 默认显示 plan tab · 切 tab 时重新渲染 · Copy 按钮复制当前 tab 内容
    const ctaEl = body.querySelector('.docs-empty-cta');
    if (ctaEl) {
      let currentKind = 'plan';
      const viewEl = ctaEl.querySelector('#cta-prompt-view');
      const descEl = ctaEl.querySelector('#cta-tab-desc');
      const metaEl = ctaEl.querySelector('#cta-copy-meta');

      function renderPrompt(kind) {
        currentKind = kind;
        // 高亮当前 tab
        ctaEl.querySelectorAll('.cta-tabs button').forEach(b => {
          const on = (b.dataset.promptKind === kind);
          b.classList.toggle('active', on);
          b.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        // 切 tab 描述
        descEl.textContent = t('empty_docs.tab_' + kind + '_desc');
        // 渲染 prompt 全文 + 显示字数 meta
        const text = buildDocPrompt(id, kind);
        viewEl.textContent = text;
        metaEl.textContent = t('empty_docs.copy_meta', { chars: text.length });
      }

      ctaEl.querySelectorAll('.cta-tabs button').forEach(btn => {
        btn.addEventListener('click', () => renderPrompt(btn.dataset.promptKind));
      });

      const copyBtn = ctaEl.querySelector('#cta-copy-btn');
      const copyLabel = ctaEl.querySelector('#cta-copy-label');
      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          copyText(
            viewEl.textContent,
            () => {
              copyLabel.textContent = t('empty_docs.copy_btn_done');
              toast(t('toast.prompt_copied_' + currentKind));
              setTimeout(() => {
                copyLabel.textContent = t('empty_docs.copy_btn');
              }, 1600);
            },
            () => toast(t('toast.copy_failed'))
          );
        });
      }

      // 首次渲染:默认 plan
      renderPrompt('plan');
    }

    openDrawer('module-drawer');
  }

  // ── 0.8.0 · prompt 复制(给 vibe-coding 编辑器生成 plan/RFC/spec)──
  // 把 {key} 占位符替换成 vars[key] 的值 · 支持同一占位符多次出现(replaceAll)
  function fillTemplate(tmpl, vars) {
    return String(tmpl == null ? '' : tmpl).replace(/\{(\w+)\}/g, (m, k) => (
      (vars && Object.prototype.hasOwnProperty.call(vars, k))
        ? String(vars[k])
        : m
    ));
  }

  // clipboard:首选 navigator.clipboard · 失败 fallback 到 textarea + execCommand
  // (file:// 上下文 + Firefox 严格策略时需要 fallback)
  function copyText(text, onSuccess, onError) {
    function fallback() {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.top = '-9999px';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.focus(); ta.select();
      let ok = false;
      try { ok = document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
      if (ok && onSuccess) onSuccess();
      else if (onError) onError();
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(
        () => { if (onSuccess) onSuccess(); },
        () => fallback()
      );
    } else {
      fallback();
    }
  }

  // 0.9.0:拆出 buildDocPrompt · 返回填好变量的提示词文本(不复制)
  // 让 CTA 面板的 tab 切换能先 preview 再让用户决定是否 Copy
  function buildDocPrompt(moduleId, kind) {
    const m = getModule(moduleId);
    if (!m) return '';
    const today = new Date().toISOString().slice(0, 10);
    const desc = (m.desc || '').trim();
    const excerpt = (m.bodyExcerpt || '').trim();
    // 描述优先 · 没有就用 body 摘要 · 都没有就给个占位提示
    const descOrExcerpt = desc.length >= 20
      ? desc
      : (excerpt
          ? excerpt
          : t('prompt.no_context_placeholder'));
    const projectName = (RAW.project && RAW.project.name) || 'this project';
    const tmpl = t('prompt.' + kind);
    if (!tmpl || tmpl === ('prompt.' + kind)) {
      return '';
    }
    return fillTemplate(tmpl, {
      project: projectName,
      id: m.id,
      idLower: m.id.toLowerCase(),
      title: m.title || '',
      status: m.status || 'not-started',
      sprint: m.sprint || '—',
      progress: (m.progress == null ? 0 : m.progress),
      path: m.path || '',
      date: today,
      descOrExcerpt: descOrExcerpt,
    });
  }

  // 旧接口保留 · 直接 build → copy(仍然给键盘快捷键 / 老调用兜底用)
  function copyDocPrompt(moduleId, kind) {
    const text = buildDocPrompt(moduleId, kind);
    if (!text) { toast(t('toast.copy_failed')); return; }
    copyText(
      text,
      () => toast(t('toast.prompt_copied_' + kind)),
      () => toast(t('toast.copy_failed'))
    );
  }

  // ── 0.7.1 · drawer 内联 MD 预览 ──────────────────────────
  // 不重开 drawer · 只换 #md-body 内容(drawer-head 保持模块上下文 · 标识"还在这个模块")
  // back 按钮 → 调 openModuleDrawer(_activeModuleId) 恢复模块视图
  function showDocPreview(moduleId, docIndex) {
    const m = getModule(moduleId);
    if (!m) return;
    const d = (m.docs || [])[docIndex];
    if (!d) return;
    const body = document.getElementById('md-body');
    if (!body) return;

    const backBtnHtml =
      '<button type="button" class="pv-back" id="pv-back">' +
        '<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2.5L4 6l4 3.5"/></svg>' +
        '<span>' + escapeHtml(t('drawer.docs_back')) + '</span>' +
      '</button>';

    const exists = (d.exists !== false);
    const showPath = d.resolved || d.path || '';
    const headHtml =
      '<div class="doc-preview-head">' +
        backBtnHtml +
        '<div class="pv-meta">' +
          '<div class="pv-title">' + escapeHtml(d.title || '') + '</div>' +
          '<div class="pv-path">' + escapeHtml(showPath) + '</div>' +
          (d.mtime ? '<div class="pv-mtime">' + escapeHtml(d.mtime) + '</div>' : '') +
        '</div>' +
      '</div>';

    let contentHtml;
    if (!exists) {
      // 文件不存在 · drawer 内提示 · 不跳出浏览器
      contentHtml =
        '<div class="doc-preview-missing">' +
          '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_missing_title')) + '</div>' +
          '<div>' + escapeHtml(t('drawer.docs_missing_hint')) + '</div>' +
          '<div class="pv-missing-path">' + escapeHtml(d.path || '') + '</div>' +
        '</div>';
    } else if (d.content) {
      // 有 content → marked 渲染(CDN 失败时 fallback 到 <pre> · 见底部 CDN guard)
      let rendered;
      try {
        rendered = (typeof marked !== 'undefined' && marked.parse)
          ? marked.parse(d.content)
          : '<pre>' + escapeHtml(d.content) + '</pre>';
      } catch (e) {
        rendered = '<pre>' + escapeHtml(d.content) + '</pre>';
      }
      contentHtml = '<div class="doc-preview-body">' + rendered + '</div>';
    } else {
      // 非 .md / .markdown 或文件过大 → 尝试浏览器原生打开(图片 / PDF 等)
      // 用 file:// URL(resolved 是绝对路径)
      const url = d.resolved
        ? 'file:///' + d.resolved.replace(/\\/g, '/').replace(/^\/+/, '')
        : d.path;
      try { window.open(url, '_blank'); } catch (e) {}
      contentHtml =
        '<div class="doc-list-empty">' +
          escapeHtml(t('drawer.docs_open_external')) +
        '</div>';
    }

    body.innerHTML = headHtml + contentHtml;

    // 0.7.2:预览模式加宽 drawer · 让 MD 表格 / 代码块 / 长行有空间
    const drawer = document.getElementById('module-drawer');
    if (drawer) drawer.classList.add('wide');

    // 语法高亮
    if (d.content && typeof hljs !== 'undefined' && hljs.highlightElement) {
      body.querySelectorAll('.doc-preview-body pre code').forEach(b => {
        try { hljs.highlightElement(b); } catch (e) {}
      });
    }

    // 绑 back
    const backBtn = body.querySelector('#pv-back');
    if (backBtn) {
      backBtn.addEventListener('click', () => openModuleDrawer(moduleId));
    }

    // 滚到顶
    body.scrollTop = 0;
  }

  // ── System Docs Drawer ───────────────────────────────
  function renderSystemDocs() {
    const list = RAW.systemDocs || [];
    document.getElementById('docs-count').textContent = list.length;
    document.getElementById('dd-count').textContent = t('sysdocs.count_items', { n: list.length });
    const el = document.getElementById('sysdoc-list');
    if (!list.length) { el.innerHTML = '<div class="doc-list-empty">' + escapeHtml(t('sysdocs.empty')) + '</div>'; return; }
    // 0.11.0-alpha.6 §4.b · sysdoc row click 走 hash router · 不再新窗口
    // 注意:用 button 而非 anchor · 避免 file:// 浏览器原生跳走
    // `?ui=modal` 时 navigateTo() 回退到 window.open · 老体验保留
    el.innerHTML = list.map(d => {
      const iconSvg = iconForDoc(d.icon || 'doc');
      return '<button type="button" class="sysdoc-row" data-sysdoc-id="' + escapeHtml(d.id) + '">' +
        '<span class="sd-icon">' + iconSvg + '</span>' +
        '<div class="sd-info">' +
          '<div class="sd-title">' + escapeHtml(d.title) + '</div>' +
          '<div class="sd-desc">' + escapeHtml(d.desc || '') + '</div>' +
          '<div class="sd-path">' + escapeHtml(d.path || '') + '</div>' +
        '</div>' +
        '<svg class="sd-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3l5 5-5 5"/></svg>' +
      '</button>';
    }).join('');
    // bind click
    el.querySelectorAll('.sysdoc-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.sysdocId;
        try { closeDrawer(); } catch (e) {}
        navigateTo('sysdoc', id);
      });
    });
  }
  function iconForDoc(kind) {
    if (kind === 'memory') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="5.5"/><path d="M8 5v3l2 1.5"/></svg>';
    }
    if (kind === 'design') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="2.5" width="11" height="11" rx="2"/><path d="M2.5 6.5h11M6.5 2.5v11"/></svg>';
    }
    if (kind === 'plan') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h10v10H3z"/><path d="M3 6.5h10M6.5 3v10"/></svg>';
    }
    return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/><line x1="5.5" y1="8" x2="10.5" y2="8"/><line x1="5.5" y1="10.5" x2="9" y2="10.5"/></svg>';
  }

  // ── Drawer 通用 ─────────────────────────────────────
  function openDrawer(id) {
    document.querySelectorAll('.drawer').forEach(d => d.classList.toggle('open', d.id === id));
    document.getElementById('scrim').classList.add('open');
  }
  function closeDrawer() {
    document.querySelectorAll('.drawer').forEach(d => {
      d.classList.remove('open');
      d.classList.remove('wide');  // 0.7.2:关 drawer 时一并收回 doc-preview 加宽
    });
    document.getElementById('scrim').classList.remove('open');
    _activeModuleId = null;
  }

  // ── Toast ─────────────────────────────────────────
  let _toastTimer = null;
  function toast(msg) {
    const el = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    el.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => el.classList.remove('show'), 1600);
  }

  // ── 全量重绘 ────────────────────────────────────────
  function renderAll() {
    renderKpi();
    renderKanban();
    renderSprints();
    renderConcepts();
  }

  // ── 0.11.0-alpha.6 §4.b · hash router ─────────────────────
  // URL hash 模型(plan §6.6):
  //   ''                     · dashboard 首页
  //   '#/module/<id>'        · module 二级页面(split-view · §4.c/d 填内容)
  //   '#/sysdoc/<id>'        · system doc 二级页面
  //   '#/concept/<id>'       · concept 二级页面
  // Query 参数:
  //   '?ui=modal'            · 强制走老 modal drawer(向后兼容)
  function _hasModalQueryParam() {
    try {
      return new URLSearchParams(window.location.search).get('ui') === 'modal';
    } catch (e) { return false; }
  }
  const _UI_MODE = _hasModalQueryParam() ? 'modal' : 'split-view';

  function parseHash() {
    const raw = (window.location.hash || '').replace(/^#\/?/, '').trim();
    if (!raw) return { kind: 'dashboard', id: null };
    const parts = raw.split('/');
    const kind = parts[0];
    const id = parts[1] ? decodeURIComponent(parts[1]) : null;
    if (['module', 'sysdoc', 'concept'].indexOf(kind) >= 0) {
      return { kind, id };
    }
    return { kind: 'dashboard', id: null };
  }

  // 当前路由状态 · 全局
  let _currentRoute = { kind: 'dashboard', id: null };

  // 0.11.0-alpha.6 §4.c · drawer DOM 在 modal / split-view 之间搬家
  // modal 默认 DOM 位置:body 直接 child(<aside id="module-drawer">)
  // split-view:JS 把 drawer.appendChild 进 #split-nav-slot · CSS 切样式
  function _moveModuleDrawerToSplitNav() {
    const drawer = document.getElementById('module-drawer');
    const slot = document.getElementById('split-nav-slot');
    if (!drawer || !slot) return;
    if (drawer.parentElement !== slot) slot.appendChild(drawer);
    // split-view 不需要 .open class(永远显)· 但 _activeModuleId 仍要追踪
    drawer.classList.add('open');
  }
  function _moveModuleDrawerBackToBody() {
    const drawer = document.getElementById('module-drawer');
    if (!drawer) return;
    if (drawer.parentElement !== document.body) {
      document.body.appendChild(drawer);
    }
    drawer.classList.remove('open');
  }

  function applyRoute() {
    _currentRoute = parseHash();
    const body = document.body;
    const splitPage = document.getElementById('split-page');
    const backBtn = document.getElementById('back-btn');
    const crumb = document.getElementById('topbar-crumb');

    if (_currentRoute.kind === 'dashboard') {
      body.classList.remove('split-mode');
      splitPage.setAttribute('hidden', '');
      if (backBtn) backBtn.setAttribute('hidden', '');
      if (crumb) crumb.textContent = t('topbar.crumb');
      _moveModuleDrawerBackToBody();
      // 关闭遗留 modal scrim
      const scrim = document.getElementById('scrim');
      if (scrim) scrim.classList.remove('open');
    } else {
      body.classList.add('split-mode');
      splitPage.removeAttribute('hidden');
      if (backBtn) backBtn.removeAttribute('hidden');
      if (crumb) {
        const kindLabel = _currentRoute.kind === 'module' ? 'Module'
                        : _currentRoute.kind === 'sysdoc' ? 'System Doc'
                        : 'Concept';
        crumb.textContent = kindLabel + ' · ' + (_currentRoute.id || '?');
      }
      // 按 kind 渲染左 navigator
      if (_currentRoute.kind === 'module' && _currentRoute.id) {
        _moveModuleDrawerToSplitNav();
        // 复用 openModuleDrawer 的渲染 + 事件绑定(CSS 在 split-mode override modal 样式)
        try { openModuleDrawer(_currentRoute.id); } catch (e) { console.error(e); }
      } else if (_currentRoute.kind === 'sysdoc' && _currentRoute.id) {
        // sysdoc / concept · §4.d 接 · 暂时显占位
        _moveModuleDrawerBackToBody();
        renderSplitNavPlaceholder(_currentRoute);
      } else if (_currentRoute.kind === 'concept' && _currentRoute.id) {
        _moveModuleDrawerBackToBody();
        renderSplitNavPlaceholder(_currentRoute);
      }
    }
  }

  function renderSplitNavPlaceholder(route) {
    // sysdoc · §4.d 接 sysdoc split-view 渲染
    if (route.kind === 'sysdoc' && route.id) {
      _renderSysdocSplitNav(route.id);
      return;
    }
    // concept / 兜底
    const slot = document.getElementById('split-nav-slot');
    if (!slot) return;
    slot.innerHTML =
      '<div style="padding:24px;">' +
      '<div style="font-family:var(--f-sans); font-size:18px; color:var(--c-ink); margin-bottom:8px;">' +
      escapeHtml(route.kind + ' · ' + (route.id || '?')) +
      '</div>' +
      '<div style="font-family:var(--f-mono); font-size:11px; color:var(--c-graphite);">' +
      'Concept split-view · alpha.7 follow-up' +
      '</div>' +
      '</div>';
  }

  // 0.11.0-alpha.6 §4.d · 右 preview 渲染 + linked docs 切换
  function _markdownToHtml(content) {
    if (!content) return '';
    try {
      return (typeof marked !== 'undefined' && marked.parse)
        ? marked.parse(content)
        : '<pre>' + escapeHtml(content) + '</pre>';
    } catch (e) {
      return '<pre>' + escapeHtml(content) + '</pre>';
    }
  }

  function renderSplitPreviewDoc(d, sourceBtn) {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    const exists = (d.exists !== false);
    const hasContent = !!(d.content && d.content.length);
    let bodyHtml;
    if (!exists) {
      bodyHtml = '<div class="doc-preview-missing">' +
        '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_missing_title')) + '</div>' +
        '<div>' + escapeHtml(t('drawer.docs_missing_hint')) + '</div>' +
        '<div class="pv-missing-path">' + escapeHtml(d.path || '') + '</div>' +
      '</div>';
    } else if (hasContent) {
      bodyHtml = '<div class="doc-preview-body">' + _markdownToHtml(d.content) + '</div>';
    } else {
      // 非 .md / 文件过大 · 提示外部打开
      const url = d.resolved
        ? 'file:///' + d.resolved.replace(/\\/g, '/').replace(/^\/+/, '')
        : (d.path || '');
      bodyHtml =
        '<div class="doc-preview-missing">' +
          '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_open_external')) + '</div>' +
          '<div class="pv-missing-path">' + escapeHtml(url) + '</div>' +
        '</div>';
    }
    slot.innerHTML =
      '<div class="split-preview-head">' +
        '<div class="pv-title">' + escapeHtml(d.title || d.path || '') + '</div>' +
        (d.path ? '<div class="pv-path">' + escapeHtml(d.path) + '</div>' : '') +
        (d.mtime ? '<div class="pv-mtime">' + escapeHtml(d.mtime) + '</div>' : '') +
      '</div>' +
      bodyHtml;
    // 高亮当前 active doc-row(左 navigator)
    const allRows = document.querySelectorAll('#split-nav-slot .doc-list .doc-row');
    allRows.forEach(r => r.classList.remove('active'));
    if (sourceBtn && sourceBtn.classList) sourceBtn.classList.add('active');
    // 滚到顶
    slot.scrollTop = 0;
  }

  function renderSplitPreviewEmpty() {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    slot.innerHTML =
      '<div class="split-preview-placeholder">' +
        'No linked docs for this module · add `docs:` in frontmatter or `## Related` section in body.' +
      '</div>';
  }

  // 0.11.0-alpha.6 §4.e · 右栏渲染 code preview · alpha.2 backend code_anchors[] 数据接入
  function renderSplitPreviewCode(subtask) {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    const anchors = subtask.code_anchors || [];
    let bodyHtml = '';
    for (const ca of anchors) {
      const hasPreview = !!(ca.preview && ca.preview.length);
      const vscodeBtn = ca.vscode_url
        ? '<a class="code-anchor-vscode" href="' + escapeHtml(ca.vscode_url) + '" title="Open in VS Code">↗ VS Code</a>'
        : '';
      bodyHtml += '<div class="code-anchor-block">' +
        '<div class="code-anchor-head">' +
          '<span class="ca-path">' + escapeHtml(ca.path || '') + (ca.lines ? ':' + escapeHtml(ca.lines) : '') + '</span>' +
          vscodeBtn +
        '</div>' +
        (ca.warning ? '<div class="code-anchor-warn">⚠ ' + escapeHtml(ca.warning) + '</div>' : '') +
        (hasPreview ? '<pre class="code-anchor-preview"><code>' + escapeHtml(ca.preview) + '</code></pre>' : '') +
      '</div>';
    }
    slot.innerHTML =
      '<div class="split-preview-head">' +
        '<div class="pv-title">Code anchor · ' + escapeHtml(subtask.title || '') + '</div>' +
        '<div class="pv-path">' + escapeHtml(subtask.id || '') + '</div>' +
      '</div>' +
      bodyHtml;
    slot.scrollTop = 0;
    // 高亮 active code-btn
    document.querySelectorAll('#split-nav-slot .st-code-btn').forEach(b => b.classList.remove('active'));
    const btn = document.querySelector('#split-nav-slot .st-code-btn[data-st-key="' + (subtask.id || '') + '"]');
    if (btn) btn.classList.add('active');
  }

  // 0.11.0-alpha.6 §4.e · Copy prompt for subtask · alpha.3 prompts.js sidecar 接入
  function copySubtaskPrompt(subtaskId) {
    const prompt = (window.__PROMPTS__ || {})[subtaskId];
    if (!prompt) {
      toast(t('toast.prompt_missing') || 'Prompt not available · run docs-cockpit build to refresh');
      return;
    }
    // 0.10.1 clipboard fallback(file:// 兼容)
    (async () => {
      try {
        await navigator.clipboard.writeText(prompt);
        toast(t('toast.prompt_copied') || 'Prompt copied · paste to Claude / Codex');
        return;
      } catch (e) {}
      // execCommand fallback
      try {
        const ta = document.createElement('textarea');
        ta.value = prompt;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        toast(ok ? (t('toast.prompt_copied') || 'Prompt copied') : 'Copy failed · prompt preview: ' + prompt.slice(0, 200) + '…');
      } catch (e) {
        toast('Copy failed · ' + e.message);
      }
    })();
  }

  // 0.11.0-alpha.6 §4.d · sysdoc split-view · 左 navigator 是 systemDocs list ·
  // 右 preview 渲染 active 那条 doc body
  function _renderSysdocSplitNav(activeId) {
    const slot = document.getElementById('split-nav-slot');
    if (!slot) return;
    const list = RAW.systemDocs || [];
    const rowsHtml = list.map(d => {
      const isActive = (d.id === activeId);
      const iconSvg = iconForDoc(d.icon || 'doc');
      return '<button type="button" class="sysdoc-row sysdoc-nav-row' + (isActive ? ' active' : '') + '" data-sysdoc-id="' + escapeHtml(d.id) + '">' +
        '<span class="sd-icon">' + iconSvg + '</span>' +
        '<div class="sd-info">' +
          '<div class="sd-title">' + escapeHtml(d.title) + '</div>' +
          '<div class="sd-desc">' + escapeHtml(d.desc || '') + '</div>' +
        '</div>' +
      '</button>';
    }).join('');
    slot.innerHTML =
      '<div class="drawer-head" style="position:sticky;top:0;background:var(--c-bg);z-index:2;border-bottom:1px solid var(--c-hairline);padding:14px 20px;">' +
        '<div>' +
          '<div class="h-meta" style="font-family:var(--f-mono);font-size:11px;color:var(--c-graphite);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px;">' + escapeHtml(t('sysdocs.eyebrow')) + '</div>' +
          '<h2 style="margin:0;font-size:18px;font-weight:600;color:var(--c-ink);">' + escapeHtml(t('sysdocs.title')) + '</h2>' +
        '</div>' +
      '</div>' +
      '<div class="drawer-body" style="padding:16px;">' +
        '<div class="sysdoc-list">' + rowsHtml + '</div>' +
      '</div>';
    // 绑 click · 切 sysdoc(同 split-view 内导航)
    slot.querySelectorAll('.sysdoc-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const newId = btn.dataset.sysdocId;
        if (newId === activeId) return;
        window.location.hash = '#/sysdoc/' + encodeURIComponent(newId);
      });
    });
    // 渲染右 preview · 当前 active sysdoc 的 content
    const active = list.find(d => d.id === activeId);
    if (active) {
      renderSplitPreviewDoc(active, null);
    } else {
      renderSplitPreviewEmpty();
    }
  }

  function navigateTo(kind, id) {
    // _UI_MODE === 'modal' 时退回老 modal flow(向后兼容)
    if (_UI_MODE === 'modal') {
      if (kind === 'module') openModuleDrawer(id);
      else if (kind === 'sysdoc') {
        // sysdoc 老 modal 行为:新窗口打开 · 不变
        const doc = (RAW.systemDocs || []).find(d => d.id === id);
        if (doc && doc.path) window.open(doc.path, '_blank');
      }
      return;
    }
    const newHash = '#/' + kind + '/' + encodeURIComponent(id);
    if (window.location.hash !== newHash) {
      window.location.hash = newHash;
    } else {
      // 同 hash · 强制 re-render
      applyRoute();
    }
  }

  function backToDashboard() {
    if (window.location.hash) {
      // 走 history · 浏览器 back 键 work
      window.location.hash = '';
    } else {
      applyRoute();
    }
  }

  // ── 初始化 ────────────────────────────────────────
  function init() {
    applyI18nStatic();
    renderProjectMeta();
    renderSystemDocs();
    renderAll();

    // Lang toggle handler
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => {
        LANG = btn.dataset.lang;
        try { localStorage.setItem(STORAGE_KEY + '::lang', LANG); } catch (e) {}
        applyI18nStatic();
        renderProjectMeta();
        renderSystemDocs();
        renderAll();
        // If module drawer is open · re-render it too
        if (_activeModuleId) openModuleDrawer(_activeModuleId);
      });
    });

    document.getElementById('open-docs').addEventListener('click', () => openDrawer('docs-drawer'));
    document.getElementById('md-close').addEventListener('click', closeDrawer);
    document.getElementById('dd-close').addEventListener('click', closeDrawer);
    document.getElementById('scrim').addEventListener('click', closeDrawer);

    // 0.11.0-alpha.6 §4.b · Back 按钮 + hashchange + Esc 处理 split-view
    const backBtn = document.getElementById('back-btn');
    if (backBtn) backBtn.addEventListener('click', backToDashboard);
    window.addEventListener('hashchange', applyRoute);
    // initial apply · 处理打开页面时 URL 已带 hash 的场景
    applyRoute();

    document.addEventListener('keydown', e => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (document.activeElement && document.activeElement.tagName) || '';
      const inField = tag === 'INPUT' || tag === 'TEXTAREA';
      if (e.key === 'Escape') {
        // 0.11.0-alpha.6 §4.b · Esc 优先关 modal(若开)· 否则返回 dashboard
        const anyDrawerOpen = document.querySelector('.drawer.open');
        if (anyDrawerOpen) { closeDrawer(); return; }
        if (_currentRoute.kind !== 'dashboard') { backToDashboard(); return; }
        return;
      }
      if (inField) return;
      if (e.key === 'd' || e.key === 'D') {
        const docsOpen = document.getElementById('docs-drawer').classList.contains('open');
        if (docsOpen) closeDrawer(); else openDrawer('docs-drawer');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
