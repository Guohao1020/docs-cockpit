<script id="project-data" type="application/json">__DOCS_JSON__</script>

<script>
(function() {
  'use strict';

  // ── 数据 + 持久化 ─────────────────────────────────────
  const RAW = JSON.parse(document.getElementById('project-data').textContent);
  const STORAGE_KEY = 'project-kanban-state-v1';

  function loadOverrides() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch (e) { return {}; }
  }
  function saveOverrides(map) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(map)); } catch (e) {}
  }

  const overrides = loadOverrides();

  // 0.11.0-alpha.5:把老 index-based subtask key `MID__stN` 清掉 · 避免跟新
  // id-based key `MID__st__<sha1-id>` 混淆 + 出现 33% 这种错位显示。
  // 一次性 migration · 跑完写回 localStorage · 老用户下次打开看不到老 key。
  (function migrateOldSubtaskKeys() {
    let dirty = false;
    for (const k of Object.keys(overrides)) {
      // 老格式:`M<id>__st<digit>` · 比如 `M02__st3`
      if (/^[^_]+__st\d+$/.test(k)) {
        delete overrides[k];
        dirty = true;
      }
    }
    if (dirty) saveOverrides(overrides);
  })();

  // merge: 用户存储的覆盖优先
  function getModule(id) {
    const base = RAW.modules.find(m => m.id === id);
    if (!base) return null;
    const ov = overrides[id] || {};
    // 0.11.0-alpha.5 · 用 stable subtask.id(v0.11 W1 加的 sha1 算)而不是 index
    // 老 index-based key `id__stN` 留 localStorage 里 orphan · 不影响新 key
    const subtasks = (base.subtasks || []).map((st, i) => {
      const stKey = st.id || ('idx-' + i);   // v0.10 fallback
      const k = id + '__st__' + stKey;
      return { ...st, done: (k in overrides) ? !!overrides[k] : st.done };
    });
    const m = {
      ...base,
      subtasks,
      status: ov.status || base.status,
      manualProgress: ('manualProgress' in ov) ? ov.manualProgress : base.manualProgress,
      progress: ('progress' in ov) ? ov.progress : base.progress
    };
    if (!m.manualProgress && m.subtasks.length > 0) {
      const done = m.subtasks.filter(s => s.done).length;
      m.progress = Math.round((done / m.subtasks.length) * 100);
    }
    if (m.progress === 100 && m.status !== 'done' && !ov.status) m.status = 'done';
    if (m.progress > 0 && m.progress < 100 && m.status === 'not-started' && !ov.status) m.status = 'in-progress';
    return m;
  }

  function allModules() {
    return RAW.modules.map(m => getModule(m.id));
  }

  // ── 工具 ─────────────────────────────────────────────
  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  const STATUS_ORDER = ['not-started', 'planned', 'in-progress', 'blocked', 'done'];

  // ── i18n ───────────────────────────────────────────
  const I18N = {
    en: {
      'topbar.crumb': 'Project Dashboard',
      'topbar.back': 'Back',
      'toast.prompt_copied': 'Prompt copied · paste to Claude / Codex',
      'toast.prompt_missing': 'Prompt not in cache · run docs-cockpit build to refresh prompts.js',
      'topbar.last_build': 'Last build',
      'topbar.sysdocs_btn': 'System Docs',
      'topbar.sysdocs_title': 'System Docs (D)',
      'hero.eyebrow': 'PROJECT DASHBOARD · MODULE PROGRESS',
      'hero.title': 'Project progress overview',
      'hero.tagline': 'Module status · sprint progress · core concepts · one-stop visualization with fine-grained progress control.',
      'hero.gauge_label': 'Overall · module-weighted',
      'kpi.title': 'Overview',
      'kpi.total': 'Total modules',
      'kpi.total_sub_prefix': 'configured ·',
      'kpi.concepts_suffix': 'concepts',
      'kpi.done': 'Done',
      'kpi.progress': 'In progress · Planned',
      'kpi.todo': 'Not started · Blocked',
      'kpi.meta_sum': '{m} modules · {c} concepts',
      'kanban.title': 'Module Kanban',
      'kanban.meta': 'Click a card to view docs and progress controls',
      'kanban.col_empty': '—',
      'kanban.doc_count_title': '{n} linked doc(s)',
      'sprint.title': 'Sprint Timeline',
      'sprint.meta': 'Per-sprint module coverage and average progress',
      'sprint.empty': 'No sprint data',
      'sprint.modules_suffix': 'modules',
      'concept.title': 'Core Concepts',
      'concept.meta_count': '{n} concepts',
      'drawer.close': 'Close',
      'drawer.desc_label': 'Description',
      'drawer.desc_empty': 'No description.',
