<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>项目看板 · 模板</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github.min.css" />
<style>
/* ───── design tokens ───────────────────────────── */
:root {
  --c-primary:        #024ad8;
  --c-primary-bright: #296ef9;
  --c-primary-deep:   #0e3191;
  --c-primary-soft:   #eaf1fe;

  --c-canvas:    #ffffff;
  --c-paper:     #ffffff;
  --c-tint:      #fafafa;
  --c-cloud:     #f4f4f5;
  --c-fog:       #ebebec;
  --c-hairline:  #e6e6e8;
  --c-steel:     #c5c5c8;
  --c-graphite:  #6b6b71;
  --c-charcoal:  #2f2f33;
  --c-ink:       #18181b;
  --c-ink-deep:  #0a0a0d;
  --c-on-ink:    #ffffff;

  --s-done:      #059669;
  --s-progress:  #024ad8;
  --s-planned:   #6366f1;
  --s-blocked:   #dc2626;
  --s-todo:      #a1a1a8;
  --s-deferred:  #d97706;

  --r-xs: 2px; --r-sm: 4px; --r-md: 6px; --r-lg: 10px; --r-xl: 16px; --r-pill: 9999px;

  --shadow-sm: 0 1px 2px rgba(15, 17, 23, 0.04), 0 1px 1px rgba(15, 17, 23, 0.06);
  --shadow-md: 0 2px 4px rgba(15, 17, 23, 0.04), 0 8px 16px rgba(15, 17, 23, 0.06);
  --shadow-lg: 0 12px 32px rgba(15, 17, 23, 0.14), 0 4px 8px rgba(15, 17, 23, 0.06);

  --f-display: 'Inter', ui-sans-serif, system-ui, sans-serif;
  --f-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: var(--f-display);
  color: var(--c-ink);
  background: var(--c-canvas);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
button { font: inherit; color: inherit; }
a { color: var(--c-primary); text-decoration: none; }
a:hover { text-decoration: underline; }
:focus-visible {
  outline: 2px solid var(--c-primary);
  outline-offset: 2px;
  border-radius: 3px;
}

/* ───── top bar ──────────────────────────────────── */
.topbar {
  position: sticky; top: 0; z-index: 30;
  background: rgba(255,255,255,0.92);
  backdrop-filter: saturate(140%) blur(8px);
  border-bottom: 1px solid var(--c-hairline);
  padding: 0 28px;
  height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px;
}
.brand {
  display: flex; align-items: center; gap: 11px;
  font-weight: 600; font-size: 14px;
  letter-spacing: -0.005em;
  color: var(--c-ink);
}
.brand .mark {
  width: 26px; height: 26px;
  background: var(--c-ink);
  border-radius: 6px;
  display: grid; place-items: center;
  color: var(--c-on-ink);
  font-family: var(--f-mono); font-weight: 600;
  font-size: 13px;
}
.brand .crumb {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding-left: 12px;
  margin-left: 2px;
  border-left: 1px solid var(--c-hairline);
  white-space: nowrap;
}

/* 0.11.0-alpha.6 §4.b · Back to dashboard 按钮 · URL hash 非空时显示 */
.back-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid var(--c-hairline);
  background: transparent;
  color: var(--c-ink);
  padding: 6px 10px;
  border-radius: 6px;
  font-family: var(--f-mono);
  font-size: 12px;
  cursor: pointer;
  margin-right: 12px;
  transition: background 0.12s ease, border-color 0.12s ease;
}
.back-btn:hover { background: var(--c-tint); border-color: var(--c-ink); }
.back-btn svg { width: 14px; height: 14px; }
.back-btn[hidden] { display: none !important; }

/* 0.11.0-alpha.6 §4.b/c · split-page 容器 + grid layout · plan §6.6 */
.split-page {
  padding: 16px 0 64px;
  min-height: 70vh;
  display: grid;
  grid-template-columns: minmax(360px, 38%) 1fr;
  gap: 20px;
  align-items: start;
}
/* 0.12.0 fix · 让 hidden 属性真生效 · 跟 UA [hidden]{display:none} specificity
   相等被 .split-page 覆盖 · 必须显式 override 回 none · 否则 dashboard root
   会露出空的 split-view 占位区(用户截图反馈) */
.split-page[hidden] { display: none; }
.split-nav-slot {
  /* §4.c · module-drawer DOM 移进来 · CSS override modal 样式
     0.11.0-alpha.7 follow-up · overflow-y: auto 让左 navigator 自己滚动 · 修被截断 */
  position: relative;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg);
  overflow-y: auto;
  overflow-x: hidden;
  max-height: calc(100vh - 120px);
  display: flex;
  flex-direction: column;
}
.split-preview-slot {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg);
  padding: 24px 32px;
  min-height: 70vh;
  max-height: calc(100vh - 120px);
  overflow-y: auto;
}
.split-preview-placeholder {
  font-family: var(--f-mono);
  font-size: 12px;
  color: var(--c-graphite);
  text-align: center;
  padding: 64px 16px;
}
/* 0.11.0-alpha.6 §4.d · split-preview head(顶部 title + path + mtime)
   0.11.0-alpha.7 follow-up · 用 --f-display 不是 --f-sans · 跟 design.md 对齐 */
.split-preview-head {
  padding-bottom: 12px;
  margin-bottom: 16px;
  border-bottom: 1px solid var(--c-hairline);
}
.split-preview-head .pv-title {
  font-family: var(--f-display);
  font-size: 16px;
  font-weight: 600;
  color: var(--c-ink);
  margin-bottom: 4px;
}
.split-preview-head .pv-path {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  word-break: break-all;
}
.split-preview-head .pv-mtime {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-charcoal);
  margin-top: 4px;
}
/* 0.14.3 M14-f53acd · subtask doc preview slice info badge · 让用户知道这是切片不是全文 */
.split-preview-head .pv-slice-badge {
  display: inline-block;
  margin-top: 6px;
  padding: 3px 9px;
  background: var(--c-tint);
  color: var(--c-primary);
  border-radius: 9999px;
  font-family: var(--f-mono);
  font-size: 11px;
  font-weight: 500;
}
/* §4.d · 左 navigator 里 active 那条 doc-row 高亮
   0.11.0-alpha.7 follow-up · design.md HP 蓝 · 去灰底 · 只用 left border + 字加深 */
body.split-mode .doc-list .doc-row.active {
  background: transparent;
  border-left: 2px solid var(--c-primary);
  border-radius: 0 var(--r-md) var(--r-md) 0;
}
body.split-mode .doc-list .doc-row.active .doc-title {
  color: var(--c-ink);
  font-weight: 600;
}
body.split-mode .sysdoc-list .sysdoc-row.active {
  background: transparent;
  border-left: 2px solid var(--c-primary);
  border-radius: 0 var(--r-md) var(--r-md) 0;
}
body.split-mode .sysdoc-list .sysdoc-row.active .sd-title {
  color: var(--c-ink);
  font-weight: 600;
}

/* §4.e · subtask 行的 code / prompt 按钮
   0.11.0-alpha.7 follow-up · 对齐 design.md token */
.subtasks .st .st-extras {
  display: inline-flex;
  gap: 4px;
  margin-left: 8px;
  flex-shrink: 0;
}
.st-code-btn, .st-prompt-btn, .st-doc-btn {
  background: transparent;
  border: 1px solid var(--c-hairline);
  color: var(--c-graphite);
  width: 22px;
  height: 22px;
  border-radius: var(--r-sm);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.12s, border-color 0.12s, color 0.12s;
}
.st-code-btn:hover, .st-prompt-btn:hover, .st-doc-btn:hover {
  background: var(--c-tint);
  border-color: var(--c-primary);
  color: var(--c-primary);
}
.st-code-btn svg, .st-prompt-btn svg, .st-doc-btn svg { width: 12px; height: 12px; }
.st-code-btn.active, .st-doc-btn.active {
  background: var(--c-primary);
  border-color: var(--c-primary);
  color: var(--c-on-ink);
}
.st-code-btn.stale, .st-doc-btn.stale {
  border-color: var(--s-blocked);
  color: var(--s-blocked);
}
/* 0.11.0-alpha.8 · 多 anchor 时按钮上盖一个小数字标 · 第一个不画 · 避免单 anchor 视觉噪声 */
.st-code-btn .badge-idx, .st-doc-btn .badge-idx {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--c-primary);
  color: var(--c-on-ink);
  font-family: var(--f-mono);
  font-size: 9px;
  line-height: 1;
  padding: 1px 3px;
  border-radius: 6px;
  pointer-events: none;
}
.st-code-btn, .st-doc-btn { position: relative; }

/* 0.14.4 · 「Refine with AI」按钮已干掉(per-module 点按钮 dogfood 摩擦) ·
   build 自动写 docs/refine/M<id>.md 给 LLM CLI 直 pipe · 见 v0.14.4 CHANGELOG。
   prompts-refine.js sidecar 保留 · MCP server / 自定义脚本仍能消费。
   下面 hidden 规则给老 build 出的 HTML 兜底 · 避免遗留 DOM 残留出现。 */
body.split-mode #module-drawer .drawer-head .refine-btn { display: none !important; }

/* 0.11.3 · 「同步 source」按钮 · 主动清当前 module 的 subtask override
   secondary tier · outline 而非 filled · 不抢 Refine 主行为 */
body.split-mode #module-drawer .drawer-head .reset-overrides-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  font-family: var(--f-display);
  font-size: 12px;
  font-weight: 500;
  color: var(--c-primary);
  background: transparent;
  border: 1px solid var(--c-primary);
  border-radius: var(--r-md);
  cursor: pointer;
  transition: background 0.12s ease, color 0.12s ease;
}
body.split-mode #module-drawer .drawer-head .reset-overrides-btn:hover {
  background: var(--c-tint);
}
body.split-mode #module-drawer .drawer-head .reset-overrides-btn svg {
  width: 14px;
  height: 14px;
}
body.split-mode #module-drawer .drawer-head {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* §4.e · 右栏 code-anchor preview 渲染
   0.11.0-alpha.7 follow-up · design.md HP 蓝 + canvas/cloud/hairline token */
.code-anchor-block {
  margin-bottom: 16px;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
}
.code-anchor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  background: var(--c-cloud);
  border-bottom: 1px solid var(--c-hairline);
  font-family: var(--f-mono);
  font-size: 12px;
}
.code-anchor-head .ca-path {
  color: var(--c-ink);
  word-break: break-all;
}
.code-anchor-vscode {
  font-size: 11px;
  color: var(--c-primary);
  text-decoration: none;
  padding: 3px 8px;
  border: 1px solid var(--c-primary);
  border-radius: var(--r-sm);
  white-space: nowrap;
  margin-left: 8px;
  transition: background 0.12s ease, color 0.12s ease;
}
.code-anchor-vscode:hover {
  background: var(--c-primary);
  color: var(--c-on-ink);
  text-decoration: none;
}
.code-anchor-warn {
  padding: 8px 12px;
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--s-blocked);
  background: var(--c-tint);
  border-bottom: 1px solid var(--c-hairline);
}
.code-anchor-preview {
  margin: 0;
  padding: 12px;
  font-family: var(--f-mono);
  font-size: 12px;
  line-height: 1.5;
  background: var(--c-canvas);
  overflow-x: auto;
  white-space: pre;
}

/* hash 路由切到 split-page 时 · 隐藏 dashboard sections */
body.split-mode #hero-section,
body.split-mode #kpi-section,
body.split-mode #kanban-section,
body.split-mode #sprints-section,
body.split-mode #concepts-section { display: none; }
body.split-mode .split-page[hidden] { display: grid !important; }

/* 0.14 M15 · backlog-mode 下 · 隐藏 Kanban / Sprint / Concept · 显 backlog-page */
body.backlog-mode #hero-section,
body.backlog-mode #kpi-section,
body.backlog-mode #kanban-section,
body.backlog-mode #sprints-section,
body.backlog-mode #concepts-section { display: none; }
body.backlog-mode .backlog-page[hidden] { display: block !important; }

/* ─ 0.14 M15 · backlog page · 扁平 subtask 列表 + 4-axis filter ─ */
.backlog-page {
  padding: 16px 0 100px;  /* bottom padding 给 bundle-bar 留空 */
  min-height: 70vh;
}
.backlog-page[hidden] { display: none; }
.backlog-filters {
  position: sticky;
  top: 56px;  /* topbar 下方 */
  z-index: 6;
  background: var(--c-canvas);
  border-bottom: 1px solid var(--c-hairline);
  padding: 12px 0;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}
.backlog-filter-group {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.backlog-filter-group label {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.backlog-filter-group select,
.backlog-filter-group input[type="search"] {
  font-family: var(--f-display);
  font-size: 13px;
  padding: 6px 10px;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  background: var(--c-paper);
  color: var(--c-ink);
  min-width: 100px;
}
.backlog-filter-group input[type="search"] { min-width: 200px; }
.backlog-filter-clear {
  background: transparent;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  padding: 6px 10px;
  font-family: var(--f-display);
  font-size: 12px;
  color: var(--c-graphite);
  cursor: pointer;
  margin-left: auto;
}
.backlog-filter-clear:hover { color: var(--c-primary); border-color: var(--c-primary); }
.backlog-summary {
  font-family: var(--f-mono);
  font-size: 12px;
  color: var(--c-graphite);
  padding: 12px 0 0;
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.backlog-summary .bs-count {
  flex: 1;
  min-width: 200px;
}
.backlog-summary .bs-actions {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.backlog-summary label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  user-select: none;
}
.backlog-summary .bs-quick {
  background: transparent;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  padding: 4px 10px;
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  cursor: pointer;
  transition: color 0.12s, border-color 0.12s;
}
.backlog-summary .bs-quick:hover {
  color: var(--c-primary);
  border-color: var(--c-primary);
}
.backlog-summary .bs-quick:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}
.backlog-list { display: flex; flex-direction: column; gap: 0; }
.backlog-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 12px;
  border-bottom: 1px solid var(--c-hairline);
  transition: background 0.1s;
  cursor: pointer;
}
.backlog-row:hover { background: var(--c-tint); }
.backlog-row.selected { background: var(--c-tint); }
.backlog-row.done { opacity: 0.55; }
.backlog-row input[type="checkbox"] { cursor: pointer; flex-shrink: 0; }
.backlog-row .br-id {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  flex-shrink: 0;
  min-width: 88px;
}
.backlog-row .br-title {
  flex: 1;
  font-family: var(--f-display);
  font-size: 13px;
  color: var(--c-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.backlog-row.done .br-title { text-decoration: line-through; }
.backlog-row .br-meta {
  display: inline-flex;
  gap: 6px;
  align-items: center;
  flex-shrink: 0;
}
.backlog-row .br-badge {
  font-family: var(--f-mono);
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 8px;
  background: var(--c-fog);
  color: var(--c-graphite);
}
.backlog-row .br-badge.s-done   { background: rgba(56,142,60,0.12); color: #2e7d32; }
.backlog-row .br-badge.s-blocked { background: rgba(229,57,53,0.12); color: #c62828; }
.backlog-row .br-badge.s-in-progress { background: rgba(2,74,216,0.12); color: var(--c-primary); }
.backlog-row .br-prompt-btn {
  background: transparent;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  width: 26px;
  height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.backlog-row .br-prompt-btn:hover { color: var(--c-primary); border-color: var(--c-primary); }
.backlog-row .br-prompt-btn svg { width: 12px; height: 12px; }

/* 0.14 M16 · bundle floating bar(底部 sticky) */
.bundle-bar {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 12px 20px;
  background: var(--c-ink);
  color: var(--c-on-ink);
  border-radius: 12px;
  box-shadow: var(--shadow-lg);
  font-family: var(--f-display);
  font-size: 13px;
}
.bundle-bar[hidden] { display: none; }
.bundle-bar .bb-count {
  font-family: var(--f-mono);
  font-size: 14px;
  font-weight: 600;
}
.bundle-bar .bb-verdict {
  font-family: var(--f-mono);
  font-size: 11px;
  opacity: 0.7;
  max-width: 280px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bundle-bar button {
  font-family: var(--f-display);
  font-size: 12px;
  padding: 6px 12px;
  border-radius: var(--r-sm);
  cursor: pointer;
  border: 1px solid transparent;
}
.bundle-bar .bb-copy {
  background: var(--c-primary);
  color: var(--c-on-ink);
  border-color: var(--c-primary);
}
.bundle-bar .bb-copy:hover { background: var(--c-primary-bright); border-color: var(--c-primary-bright); }
.bundle-bar .bb-clear {
  background: transparent;
  color: var(--c-on-ink);
  border-color: rgba(255,255,255,0.3);
}
.bundle-bar .bb-clear:hover { border-color: var(--c-on-ink); }

/* §4.c · split-mode 下 · module-drawer 不再是 modal · 嵌进 split-nav-slot */
body.split-mode #scrim { display: none !important; }
body.split-mode #module-drawer {
  position: static;
  transform: none !important;
  width: 100% !important;
  max-width: none !important;
  height: auto !important;
  box-shadow: none !important;
  border: none !important;
  border-radius: 0 !important;
  overflow: visible;
  visibility: visible !important;
}
body.split-mode #module-drawer .drawer-head {
  position: sticky;
  top: 0;
  background: var(--c-bg);
  z-index: 2;
  border-bottom: 1px solid var(--c-hairline);
}
body.split-mode #module-drawer .h-close {
  /* 关闭按钮在 split-view 没意义 · Back 按钮接管 */
  display: none !important;
}
body.split-mode #module-drawer .drawer-body {
  /* drawer-body 默认有 overflow:auto · split-view 让 split-nav-slot 接管滚动
     0.11.0-alpha.7 follow-up · 'overflow: visible' 配合 split-nav-slot 的 overflow-y:auto
     · 让左 navigator 整体在 slot 里滚动 · drawer-body 内部不再单独滚 · 避免双滚动条 */
  overflow: visible !important;
  max-height: none !important;
  flex: none;
}

/* §4.c · 响应式 · < 1024px 收回 stacked · 左在上 / 右在下 */
@media (max-width: 1023px) {
  .split-page {
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .split-nav-slot {
    max-height: none;
  }
  .split-preview-slot {
    max-height: none;
  }
}
@media (max-width: 720px) {
  .brand .crumb { display: none; }
  .docs-btn span:not(.docs-count):not(.docs-icon) { display: none; }
  .build-stamp span:not(.dot) { display: none; }
}
.topbar-right { display: flex; align-items: center; gap: 12px; }

/* ─ Language toggle ─ */
.lang-toggle {
  display: inline-flex;
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
  font-family: var(--f-mono);
  font-size: 11px;
  flex-shrink: 0;
}
.lang-toggle button {
  padding: 4px 9px;
  color: var(--c-graphite);
  border: 0;
  background: none;
  cursor: pointer;
  font: inherit;
}
.lang-toggle button.active {
  background: var(--c-ink);
  color: var(--c-on-ink);
}
.lang-toggle button:hover:not(.active) {
  background: var(--c-fog);
  color: var(--c-ink);
}
.build-stamp {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  letter-spacing: 0.02em;
  display: flex; align-items: center; gap: 8px;
  white-space: nowrap;
  flex-shrink: 0;
}
.build-stamp .dot {
  width: 6px; height: 6px;
  background: var(--s-done);
  border-radius: 50%;
  box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.12);
}
.docs-btn {
  display: inline-flex; align-items: center; gap: 8px;
  height: 32px;
  padding: 0 12px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  cursor: pointer;
  font-size: 12.5px; font-weight: 500;
  color: var(--c-charcoal);
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.docs-btn:hover {
  background: var(--c-tint);
  border-color: var(--c-steel);
  color: var(--c-ink);
}
.docs-btn .docs-icon {
  width: 14px; height: 14px;
  color: var(--c-graphite);
}
.docs-btn .docs-count {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  background: var(--c-cloud);
  color: var(--c-graphite);
  padding: 1px 6px;
  border-radius: var(--r-pill);
  letter-spacing: 0.02em;
}

/* ───── main shell ──────────────────────────────── */
.shell {
  max-width: 1440px;
  margin: 0 auto;
  padding: 36px 28px 96px;
}

/* ───── hero ────────────────────────────────────── */
.hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 48px;
  align-items: end;
  padding: 8px 0 36px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--c-hairline);
}
.hero .eyebrow {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 14px;
}
.hero h1 {
  margin: 0 0 8px;
  font-size: 40px; font-weight: 500;
  line-height: 1.05;
  letter-spacing: -0.022em;
  color: var(--c-ink);
}
.hero p.tagline {
  margin: 0;
  max-width: 560px;
  font-size: 15px;
  color: var(--c-graphite);
  line-height: 1.55;
}
.hero .gauge {
  text-align: right;
  padding-right: 4px;
}
.hero .gauge .num {
  font-family: var(--f-display);
  font-size: 64px; font-weight: 500;
  line-height: 0.95;
  color: var(--c-primary);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.035em;
}
.hero .gauge .label {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 10px;
}
.hero .gauge .track {
  margin-top: 12px;
  width: 200px;
  height: 3px;
  background: var(--c-fog);
  border-radius: 0;
  margin-left: auto;
}
.hero .gauge .fill {
  height: 100%;
  background: var(--c-primary);
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ───── section heading ─────────────────────────── */
.section { margin-bottom: 44px; }
.section-head {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--c-hairline);
}
.section-head .title {
  font-family: var(--f-display);
  font-size: 11px; font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--c-ink);
}
.section-head .meta {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
}

/* ───── kpi strip ───────────────────────────────── */
.kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--c-paper);
}
.kpi-cell {
  padding: 22px 24px 20px;
  border-left: 1px solid var(--c-hairline);
  position: relative;
}
.kpi-cell:first-child { border-left: none; }
.kpi-cell::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c-ink);
}
.kpi-cell.t-done::before     { background: var(--s-done); }
.kpi-cell.t-progress::before { background: var(--s-progress); }
.kpi-cell.t-todo::before     { background: var(--s-todo); }
.kpi-cell .k-label {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}
.kpi-cell .k-num {
  font-size: 36px;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.022em;
  line-height: 1;
  color: var(--c-ink);
}
.kpi-cell.t-done .k-num     { color: var(--s-done); }
.kpi-cell.t-progress .k-num { color: var(--s-progress); }
.kpi-cell .k-sub {
  margin-top: 10px;
  font-size: 11.5px;
  color: var(--c-graphite);
}
@media (max-width: 900px) {
  .kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .kpi-cell { border-left: none; border-top: 1px solid var(--c-hairline); }
  .kpi-cell:nth-child(2) { border-left: 1px solid var(--c-hairline); }
  .kpi-cell:nth-child(-n+2) { border-top: none; }
}

/* ───── kanban ──────────────────────────────────── */
.kanban {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14px;
  align-items: start;
}
@media (max-width: 1240px) { .kanban { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 760px)  { .kanban { grid-template-columns: 1fr; } }
.k-col {
  min-height: 80px;
}
.k-col-head {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 8px;
  margin-bottom: 10px;
  border-bottom: 1px solid;
  font-family: var(--f-mono);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.k-col-head .name {
  display: inline-flex; align-items: center; gap: 7px;
  font-weight: 600;
  color: var(--c-ink);
}
.k-col-head .count {
  font-weight: 500;
  color: var(--c-graphite);
  font-size: 10.5px;
}
.k-col-head .glyph {
  width: 8px; height: 8px;
  border-radius: 50%;
  display: inline-block;
}
.k-col.s-not-started .k-col-head { border-color: var(--s-todo); }
.k-col.s-not-started .k-col-head .glyph { background: transparent; border: 1.5px solid var(--s-todo); }
.k-col.s-planned     .k-col-head { border-color: var(--s-planned); }
.k-col.s-planned     .k-col-head .glyph { background: var(--s-planned); opacity: 0.55; }
.k-col.s-in-progress .k-col-head { border-color: var(--s-progress); }
.k-col.s-in-progress .k-col-head .glyph { background: var(--s-progress); }
.k-col.s-blocked     .k-col-head { border-color: var(--s-blocked); }
.k-col.s-blocked     .k-col-head .glyph { background: var(--s-blocked); }
.k-col.s-done        .k-col-head { border-color: var(--s-done); }
.k-col.s-done        .k-col-head .glyph { background: var(--s-done); }

/* card */
.m-card {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-left: 3px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 12px 14px 13px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  position: relative;
}
.m-card:hover {
  transform: translateY(-1px);
  border-color: var(--c-steel);
  box-shadow: var(--shadow-md);
}
.k-col.s-not-started .m-card { border-left-color: #d1d1d4; }
.k-col.s-planned     .m-card { border-left-color: #a5b4fc; }
.k-col.s-in-progress .m-card { border-left-color: var(--s-progress); }
.k-col.s-blocked     .m-card { border-left-color: #fca5a5; }
.k-col.s-done        .m-card { border-left-color: #6ee7b7; }

.m-card .m-id {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--c-graphite);
  display: flex; justify-content: space-between; align-items: center;
}
.m-card .m-id .doc-pill {
  font-size: 9.5px;
  font-weight: 500;
  color: var(--c-graphite);
  display: inline-flex; align-items: center; gap: 3px;
  letter-spacing: 0;
}
.m-card .m-id .doc-pill svg { width: 10px; height: 10px; }
.m-card .m-title {
  font-size: 13px; font-weight: 500;
  margin-top: 5px; margin-bottom: 11px;
  color: var(--c-ink);
  line-height: 1.36;
}
.m-card .m-meta {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 7px;
}
.m-card .m-sprint {
  font-family: var(--f-mono);
  font-size: 9.5px; font-weight: 500;
  letter-spacing: 0.02em;
  background: var(--c-cloud);
  color: var(--c-charcoal);
  padding: 2px 7px;
  border-radius: var(--r-xs);
}
.m-card .m-pct {
  font-family: var(--f-mono);
  font-size: 11px; font-weight: 600;
  color: var(--c-ink);
  font-variant-numeric: tabular-nums;
}
.k-col.s-done .m-card .m-pct { color: var(--s-done); }
.k-col.s-in-progress .m-card .m-pct { color: var(--s-progress); }
.bar {
  height: 3px;
  background: var(--c-fog);
  overflow: hidden;
}
.bar > .bar-fill {
  height: 100%;
  background: var(--c-ink);
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.k-col.s-done .bar-fill        { background: var(--s-done); }
.k-col.s-in-progress .bar-fill { background: var(--s-progress); }
.k-col.s-blocked .bar-fill     { background: var(--s-blocked); }
.k-col.s-planned .bar-fill     { background: var(--s-planned); }
.k-col-empty {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-steel);
  padding: 16px 4px;
  text-align: center;
  letter-spacing: 0.04em;
}

/* ───── sprint rows ────────────────────────────── */
.sprint-row {
  display: grid;
  grid-template-columns: 140px 1fr 72px 80px;
  gap: 20px;
  padding: 13px 0;
  border-bottom: 1px solid var(--c-hairline);
  align-items: center;
}
.sprint-row:last-child { border-bottom: none; }
.sprint-row .s-name {
  font-family: var(--f-mono);
  font-size: 12px; font-weight: 600;
  color: var(--c-ink);
  display: flex; align-items: center; gap: 9px;
}
.sprint-row .s-dot {
  width: 8px; height: 8px;
  background: var(--c-steel);
  transform: rotate(45deg);
}
.sprint-row.s-done .s-dot   { background: var(--s-done); }
.sprint-row.s-active .s-dot { background: var(--s-progress); }
.sprint-row .s-bar { height: 4px; background: var(--c-fog); }
.sprint-row .s-bar > .s-bar-fill {
  height: 100%;
  background: var(--c-primary);
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.sprint-row.s-done .s-bar-fill { background: var(--s-done); }
.sprint-row .s-pct {
  font-family: var(--f-mono);
  font-size: 12px; font-weight: 600;
  color: var(--c-ink);
  text-align: right;
  font-variant-numeric: tabular-nums;
}
.sprint-row.s-done   .s-pct { color: var(--s-done); }
.sprint-row.s-active .s-pct { color: var(--s-progress); }
.sprint-row .s-count {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  text-align: right;
}

/* ───── concept grid ───────────────────────────── */
.concept-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
}
.c-chip {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
}
.c-chip:hover {
  transform: translateY(-1px);
  border-color: var(--c-steel);
  box-shadow: var(--shadow-md);
}
.c-chip .c-id {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--c-graphite);
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 6px;
}
.c-chip .c-sprint {
  font-family: var(--f-mono);
  font-size: 9.5px;
  background: var(--c-cloud);
  color: var(--c-charcoal);
  padding: 1px 6px; border-radius: var(--r-xs);
  letter-spacing: 0.02em;
}
.c-chip .c-title {
  font-size: 13px; font-weight: 500;
  margin-bottom: 10px;
  color: var(--c-ink);
  line-height: 1.36;
}
.c-chip .c-title .c-status-dot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  margin-right: 7px;
  vertical-align: middle;
}
.c-status-dot.s-done       { background: var(--s-done); }
.c-status-dot.s-in-progress { background: var(--s-progress); }
.c-status-dot.s-planned    { background: var(--s-planned); }
.c-status-dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.c-status-dot.s-blocked    { background: var(--s-blocked); }
.c-status-dot.s-deferred   { background: var(--s-deferred); }
.c-chip .c-pct {
  font-family: var(--f-mono);
  font-size: 10.5px; font-weight: 600;
  color: var(--c-graphite);
  text-align: right;
  margin-top: 5px;
  font-variant-numeric: tabular-nums;
}

/* ───── drawer + scrim ──────────────────────────── */
.scrim {
  position: fixed; inset: 0;
  background: rgba(20, 22, 30, 0.4);
  opacity: 0;
  pointer-events: none;
  z-index: 80;
  transition: opacity 0.22s;
}
.scrim.open { opacity: 1; pointer-events: auto; }
.drawer {
  position: fixed; top: 0; right: 0; bottom: 0;
  /* 0.9.0:默认 720px(0.8.x 是 540px · 用户实测 prompt + 表格 / 长文都不够看)
     · 仍保留响应式 fallback · 极小屏 96vw 让出页面边距 */
  width: min(720px, 96vw);
  background: var(--c-paper);
  z-index: 90;
  transform: translateX(100%);
  /* 0.7.2:width 也进 transition · 预览模式下平滑加宽 */
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0.24, 1),
              width 0.22s cubic-bezier(0.32, 0.72, 0.24, 1);
  display: flex; flex-direction: column;
  box-shadow: -16px 0 48px rgba(15, 17, 23, 0.16);
}
.drawer.open { transform: translateX(0); }
/* 0.7.2:doc 预览模式加宽 · 容下 markdown 表格 / 代码块 / 长行 */
.drawer.wide { width: min(960px, 96vw); }

.drawer-head {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 16px;
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--c-hairline);
}
.drawer-head .h-meta {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 6px;
  display: flex; align-items: center; gap: 10px;
}
.drawer-head .h-meta .dot {
  width: 7px; height: 7px; border-radius: 50%;
}
.drawer-head .h-meta .dot.s-done       { background: var(--s-done); }
.drawer-head .h-meta .dot.s-in-progress { background: var(--s-progress); }
.drawer-head .h-meta .dot.s-planned    { background: var(--s-planned); }
.drawer-head .h-meta .dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.drawer-head .h-meta .dot.s-blocked    { background: var(--s-blocked); }
.drawer-head .h-meta .dot.s-deferred   { background: var(--s-deferred); }
.drawer-head h2 {
  font-size: 20px; font-weight: 500;
  line-height: 1.25;
  letter-spacing: -0.015em;
  margin: 0;
  color: var(--c-ink);
}
.drawer-head .h-close {
  width: 32px; height: 32px;
  border-radius: var(--r-md);
  background: transparent;
  border: 1px solid transparent;
  cursor: pointer;
  display: grid; place-items: center;
  color: var(--c-graphite);
}
.drawer-head .h-close:hover {
  background: var(--c-cloud);
  color: var(--c-ink);
}
.drawer-head .h-close svg { width: 14px; height: 14px; }
.drawer-body {
  flex: 1; overflow-y: auto;
  padding: 24px;
}
.drawer-body .d-section {
  margin-bottom: 28px;
}
.drawer-body .d-section:last-child { margin-bottom: 0; }
.drawer-body .d-label {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 10px;
  display: flex; justify-content: space-between; align-items: baseline;
}
.drawer-body .d-label .right { color: var(--c-charcoal); font-weight: 500; letter-spacing: 0.04em; }
.drawer-body .desc {
  font-size: 13.5px;
  color: var(--c-charcoal);
  line-height: 1.6;
  padding: 12px 14px;
  background: var(--c-tint);
  border-radius: var(--r-md);
  border: 1px solid var(--c-hairline);
}
.drawer-body .desc.empty {
  font-style: italic;
  color: var(--c-graphite);
}

/* docs list */
.doc-list {
  display: flex; flex-direction: column;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
}
.doc-list .doc-row {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px;
  border-bottom: 1px solid var(--c-hairline);
  text-decoration: none;
  color: var(--c-ink);
  transition: background 0.15s;
  font-size: 13px;
}
.doc-list .doc-row:last-child { border-bottom: none; }
.doc-list .doc-row:hover {
  background: var(--c-tint);
  text-decoration: none;
}
.doc-list .doc-row .doc-icon {
  width: 16px; height: 16px;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.doc-list .doc-row .doc-info { flex: 1; min-width: 0; }
.doc-list .doc-row .doc-title {
  font-weight: 500;
  color: var(--c-ink);
}
.doc-list .doc-row .doc-path {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  margin-top: 1px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-list .doc-row .doc-ext {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 500;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.doc-list-empty {
  padding: 18px 14px;
  border: 1px dashed var(--c-hairline);
  border-radius: var(--r-md);
  text-align: center;
  font-size: 12px;
  color: var(--c-graphite);
}
/* 0.8.0 / 0.9.0:empty-docs CTA panel · 显示提示词原文 → 一键复制
   · 0.8.0 是 3 个直接 copy 按钮(用户实测不直观:不知道复制了啥)
   · 0.9.0 改成"tab 切换 doc 类型 + 实时渲染 prompt + 单 Copy 按钮" */
.docs-empty-cta {
  border: 1px solid #fbcfe8;
  background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
  border-radius: var(--r-md);
  padding: 14px 16px 16px;
}
.docs-empty-cta .cta-title {
  display: flex; align-items: center; gap: 8px;
  font-size: 12.5px; font-weight: 600;
  color: #9a3412;
  margin-bottom: 6px;
}
.docs-empty-cta .cta-title svg { width: 14px; height: 14px; }
.docs-empty-cta .cta-hint {
  font-size: 12px;
  line-height: 1.55;
  color: #7c2d12;
  margin-bottom: 12px;
}
.docs-empty-cta .cta-hint code {
  font-family: var(--f-mono);
  font-size: 0.92em;
  background: rgba(124, 45, 18, 0.08);
  padding: 1px 5px;
  border-radius: 3px;
}
/* 0.9.0:tab 条 — 切换 Plan / RFC / Spec */
.docs-empty-cta .cta-tabs {
  display: flex; gap: 4px;
  border-bottom: 1px solid #fcd34d;
  margin-bottom: 10px;
}
.docs-empty-cta .cta-tabs button {
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  font: 500 12px/1 var(--f-sans);
  color: #9a3412;
  padding: 7px 10px 8px;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
  border-radius: var(--r-md) var(--r-md) 0 0;
}
.docs-empty-cta .cta-tabs button:hover {
  background: rgba(251, 146, 60, 0.12);
  color: #7c2d12;
}
.docs-empty-cta .cta-tabs button.active {
  background: var(--c-paper);
  border-bottom-color: #ea580c;
  color: #7c2d12;
  font-weight: 600;
}
.docs-empty-cta .cta-tab-desc {
  font-size: 11px;
  line-height: 1.5;
  color: #7c2d12;
  opacity: 0.85;
  margin-bottom: 8px;
}
/* 0.9.0:prompt 原文展示 · 等宽 + 可滚动 · 让用户先看清再复制 */
.docs-empty-cta .cta-prompt-view {
  background: var(--c-paper);
  border: 1px solid #fcd34d;
  border-radius: var(--r-md);
  padding: 10px 12px;
  max-height: 380px;
  overflow: auto;
  font-family: var(--f-mono);
  font-size: 11.5px;
  line-height: 1.55;
  color: var(--c-ink);
  white-space: pre-wrap;
  word-break: break-word;
  margin-bottom: 10px;
}
.docs-empty-cta .cta-copy-row {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 8px;
}
.docs-empty-cta .cta-copy-btn {
  background: #ea580c;
  border: 1px solid #c2410c;
  color: #fff;
  font: 600 12px/1 var(--f-sans);
  padding: 8px 14px;
  border-radius: var(--r-md);
  cursor: pointer;
  display: inline-flex; align-items: center; gap: 6px;
  transition: background 0.15s, transform 0.05s;
}
.docs-empty-cta .cta-copy-btn:hover { background: #c2410c; }
.docs-empty-cta .cta-copy-btn:active { transform: translateY(1px); }
.docs-empty-cta .cta-copy-meta {
  font-size: 10.5px;
  color: #9a3412;
  font-family: var(--f-mono);
}
.docs-empty-cta .cta-tools-hint {
  font-size: 10.5px;
  color: #9a3412;
  opacity: 0.78;
  letter-spacing: 0.01em;
}

/* 0.8.0:kanban 卡片上"需要补 docs"指示 chip(in-progress/planned/blocked + 空 docs)*/
.doc-pill.needs-docs {
  background: #fef3c7;
  color: #92400e;
  border: 1px solid #fcd34d;
}
.doc-pill.needs-docs:hover {
  background: #fde68a;
}

/* 0.7.1:doc-row 状态指示 */
.doc-list .doc-row.missing {
  background: repeating-linear-gradient(45deg, transparent 0 6px, rgba(220,38,38,0.04) 6px 8px);
}
.doc-list .doc-row.missing .doc-title::after {
  content: "404";
  font-family: var(--f-mono);
  font-size: 9.5px;
  background: rgba(220,38,38,0.12);
  color: #b91c1c;
  margin-left: 8px;
  padding: 1px 5px;
  border-radius: 3px;
  letter-spacing: 0.04em;
}
.doc-list .doc-row.has-content:hover {
  background: var(--c-primary-soft);
}
.doc-list .doc-row .doc-action {
  font-family: var(--f-mono);
  font-size: 9.5px;
  font-weight: 600;
  color: var(--c-primary);
  background: var(--c-primary-soft);
  padding: 2px 6px;
  border-radius: 3px;
  flex-shrink: 0;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.doc-list .doc-row.missing .doc-action {
  display: none;
}

/* 0.7.1:drawer 内联 MD 预览 ───────────────────────── */
.doc-preview-head {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--c-hairline);
}
.doc-preview-head .pv-back {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 6px 12px;
  cursor: pointer;
  font: 500 12px/1 var(--f-sans);
  color: var(--c-charcoal);
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.doc-preview-head .pv-back:hover {
  background: var(--c-tint);
  border-color: var(--c-steel);
  color: var(--c-ink);
}
.doc-preview-head .pv-back svg { width: 12px; height: 12px; }
.doc-preview-head .pv-meta {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 2px;
  text-align: right;
}
.doc-preview-head .pv-title {
  font-size: 13px; font-weight: 600;
  color: var(--c-ink);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-preview-head .pv-path {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-preview-head .pv-mtime {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
}
.doc-preview-body {
  font-size: 14px; line-height: 1.65;
  color: var(--c-ink);
}
.doc-preview-body h1, .doc-preview-body h2, .doc-preview-body h3,
.doc-preview-body h4, .doc-preview-body h5, .doc-preview-body h6 {
  font-weight: 600;
  margin: 1.4em 0 0.5em;
  line-height: 1.3;
}
.doc-preview-body h1 { font-size: 22px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 0.3em; }
.doc-preview-body h2 { font-size: 18px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 0.25em; }
.doc-preview-body h3 { font-size: 16px; }
.doc-preview-body h4 { font-size: 14.5px; }
.doc-preview-body h5, .doc-preview-body h6 { font-size: 13.5px; color: var(--c-charcoal); }
.doc-preview-body p { margin: 0.75em 0; }
.doc-preview-body ul, .doc-preview-body ol { margin: 0.6em 0; padding-left: 1.6em; }
.doc-preview-body li { margin: 0.25em 0; }
.doc-preview-body li > ul, .doc-preview-body li > ol { margin: 0.25em 0; }
.doc-preview-body code {
  font-family: var(--f-mono);
  font-size: 0.88em;
  background: var(--c-cloud);
  padding: 1px 5px;
  border-radius: 3px;
}
.doc-preview-body pre {
  background: var(--c-tint);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 12px 14px;
  overflow-x: auto;
  margin: 0.8em 0;
  font-size: 12.5px;
  line-height: 1.55;
}
.doc-preview-body pre code {
  background: transparent;
  padding: 0;
  border-radius: 0;
  font-size: 1em;
}
.doc-preview-body blockquote {
  margin: 0.8em 0;
  padding: 4px 14px;
  border-left: 3px solid var(--c-primary);
  background: var(--c-primary-soft);
  color: var(--c-charcoal);
  border-radius: 0 var(--r-md) var(--r-md) 0;
}
.doc-preview-body blockquote p:first-child { margin-top: 0; }
.doc-preview-body blockquote p:last-child { margin-bottom: 0; }
.doc-preview-body table {
  border-collapse: collapse;
  margin: 0.9em 0;
  font-size: 12.5px;
  width: 100%;
}
.doc-preview-body th, .doc-preview-body td {
  border: 1px solid var(--c-hairline);
  padding: 7px 10px;
  text-align: left;
}
.doc-preview-body th {
  background: var(--c-tint);
  font-weight: 600;
}
.doc-preview-body a {
  color: var(--c-primary);
  text-decoration: none;
}
.doc-preview-body a:hover { text-decoration: underline; }
.doc-preview-body hr {
  border: none;
  border-top: 1px solid var(--c-hairline);
  margin: 1.6em 0;
}
.doc-preview-body img {
  max-width: 100%;
  border-radius: var(--r-md);
}
.doc-preview-body input[type="checkbox"] {
  margin-right: 6px;
  vertical-align: middle;
}
.doc-preview-missing {
  padding: 28px 18px;
  border: 1px dashed #fecaca;
  background: rgba(220,38,38,0.04);
  border-radius: var(--r-md);
  text-align: center;
  color: #b91c1c;
  font-size: 13px;
}
.doc-preview-missing .pv-missing-title {
  font-weight: 600;
  margin-bottom: 8px;
}
.doc-preview-missing .pv-missing-path {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  word-break: break-all;
}

/* status select */
.status-select {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
}
.status-select button {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 9px 4px 8px;
  cursor: pointer;
  text-align: center;
  font-size: 11px; font-weight: 500;
  color: var(--c-charcoal);
  transition: background 0.15s, border-color 0.15s, color 0.15s;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
}
.status-select button:hover {
  border-color: var(--c-steel);
  background: var(--c-tint);
}
.status-select button .ss-dot {
  width: 9px; height: 9px;
  border-radius: 50%;
}
.status-select button.active {
  border-color: var(--c-ink);
  color: var(--c-ink);
  background: var(--c-paper);
  box-shadow: 0 0 0 2px var(--c-ink) inset;
  border-color: transparent;
}
.status-select .ss-dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.status-select .ss-dot.s-planned     { background: var(--s-planned); opacity: 0.7; }
.status-select .ss-dot.s-in-progress { background: var(--s-progress); }
.status-select .ss-dot.s-blocked     { background: var(--s-blocked); }
.status-select .ss-dot.s-done        { background: var(--s-done); }

/* progress control */
.progress-control {
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 16px;
  background: var(--c-tint);
}
.progress-control .pc-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12px;
}
.progress-control .pc-num {
  font-family: var(--f-display);
  font-size: 28px; font-weight: 500;
  font-variant-numeric: tabular-nums;
  color: var(--c-ink);
  line-height: 1;
  letter-spacing: -0.02em;
}
.progress-control .pc-mode {
  display: flex; align-items: center; gap: 8px;
  font-size: 11.5px;
  color: var(--c-graphite);
}
.progress-control input[type="range"] {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  height: 6px;
  background: var(--c-fog);
  border-radius: 99px;
  outline: none;
  cursor: pointer;
}
.progress-control input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--c-primary);
  border: 3px solid var(--c-paper);
  box-shadow: 0 0 0 1px var(--c-primary);
  cursor: pointer;
  transition: transform 0.1s;
}
.progress-control input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.1); }
.progress-control input[type="range"]::-moz-range-thumb {
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--c-primary);
  border: 3px solid var(--c-paper);
  box-shadow: 0 0 0 1px var(--c-primary);
  cursor: pointer;
}
.progress-control input[type="range"]:disabled { opacity: 0.5; cursor: not-allowed; }
.progress-control .pc-ticks {
  display: flex; justify-content: space-between;
  margin-top: 8px;
  font-family: var(--f-mono);
  font-size: 9.5px;
  color: var(--c-graphite);
}
.progress-control .pc-steps {
  display: flex; gap: 4px;
  margin-top: 10px;
}
.progress-control .pc-steps button {
  flex: 1;
  height: 26px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  font-family: var(--f-mono);
  font-size: 11px; font-weight: 500;
  color: var(--c-charcoal);
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s;
}
.progress-control .pc-steps button:hover {
  border-color: var(--c-steel);
  background: var(--c-tint);
}

/* toggle (sync mode) */
.toggle-row {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px;
  color: var(--c-charcoal);
  cursor: pointer;
  user-select: none;
}
.toggle-row .toggle {
  width: 30px; height: 18px;
  background: var(--c-fog);
  border-radius: 9999px;
  position: relative;
  transition: background 0.18s;
  flex-shrink: 0;
}
.toggle-row .toggle::after {
  content: "";
  position: absolute;
  top: 2px; left: 2px;
  width: 14px; height: 14px;
  background: var(--c-paper);
  border-radius: 50%;
  box-shadow: 0 1px 2px rgba(0,0,0,0.2);
  transition: transform 0.18s;
}
.toggle-row input { display: none; }
.toggle-row input:checked + .toggle { background: var(--c-primary); }
.toggle-row input:checked + .toggle::after { transform: translateX(12px); }

/* subtask checklist */
.subtasks {
  display: flex; flex-direction: column;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
}
.subtasks .st {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px;
  border-bottom: 1px solid var(--c-hairline);
  cursor: pointer;
  transition: background 0.12s;
  font-size: 13px;
}
.subtasks .st:last-child { border-bottom: none; }
.subtasks .st:hover { background: var(--c-tint); }
.subtasks .st .check {
  width: 16px; height: 16px;
  border: 1.5px solid var(--c-steel);
  border-radius: 4px;
  flex-shrink: 0;
  display: grid; place-items: center;
  transition: background 0.12s, border-color 0.12s;
}
.subtasks .st.done .check {
  background: var(--s-done);
  border-color: var(--s-done);
}
.subtasks .st .check svg {
  width: 10px; height: 10px;
  color: white;
  opacity: 0;
  transition: opacity 0.12s;
}
.subtasks .st.done .check svg { opacity: 1; }
.subtasks .st .st-text {
  flex: 1;
  color: var(--c-ink);
}
.subtasks .st.done .st-text {
  text-decoration: line-through;
  color: var(--c-graphite);
}

/* system-docs drawer specific */
.sysdoc-list {
  display: flex; flex-direction: column;
  gap: 8px;
}
.sysdoc-row {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 14px 16px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, transform 0.18s, box-shadow 0.18s;
  text-decoration: none;
  color: inherit;
}
.sysdoc-row:hover {
  border-color: var(--c-steel);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
}
.sysdoc-row .sd-icon {
  width: 34px; height: 34px;
  background: var(--c-cloud);
  border-radius: var(--r-md);
  display: grid; place-items: center;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.sysdoc-row .sd-icon svg { width: 16px; height: 16px; }
.sysdoc-row .sd-info { flex: 1; min-width: 0; }
.sysdoc-row .sd-title {
  font-family: var(--f-mono);
  font-size: 13px; font-weight: 600;
  color: var(--c-ink);
  margin-bottom: 3px;
}
.sysdoc-row .sd-desc {
  font-size: 12px;
  color: var(--c-graphite);
  line-height: 1.45;
}
.sysdoc-row .sd-path {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
  margin-top: 6px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.sysdoc-row .sd-arrow {
  align-self: center;
  color: var(--c-steel);
  flex-shrink: 0;
}
.sysdoc-row:hover .sd-arrow { color: var(--c-ink); }

/* toast */
.toast {
  position: fixed; bottom: 22px; left: 50%;
  transform: translateX(-50%) translateY(20px);
  z-index: 200;
  background: var(--c-ink);
  color: var(--c-on-ink);
  padding: 9px 16px;
  border-radius: 9999px;
  font-size: 12.5px; font-weight: 500;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s, transform 0.18s;
  display: inline-flex; align-items: center; gap: 8px;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.toast .ck {
  width: 14px; height: 14px;
  background: #6ee7b7;
  border-radius: 50%;
  display: grid; place-items: center;
  color: var(--c-ink);
  font-size: 10px; font-weight: 700;
}

/* utilities */
.spacer-sm { height: 8px; }
.spacer-md { height: 16px; }
.kbd-hint {
  font-family: var(--f-mono);
  font-size: 10px;
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  border-bottom-width: 2px;
  color: var(--c-charcoal);
  padding: 1px 6px;
  border-radius: 3px;
}
</style>
</head>
<body>

<header class="topbar">
  <button class="back-btn" id="back-btn" type="button" hidden aria-label="Back to dashboard" title="Back (Esc)">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3l-5 5 5 5"/></svg>
    <span data-i18n="topbar.back">Back</span>
  </button>
  <div class="brand">
    <span class="mark" id="brand-mark">·</span>
    <span id="brand-name">Project Dashboard</span>
    <span class="crumb" id="topbar-crumb" data-i18n="topbar.crumb">Project Dashboard</span>
  </div>
  <div class="topbar-right">
    <span class="build-stamp"><span class="dot"></span><span><span data-i18n="topbar.last_build">Last build</span> · <span id="build-time">—</span></span></span>
    <button class="docs-btn" id="open-docs" type="button" data-i18n-title="topbar.sysdocs_title" title="System Docs (D)">
      <svg class="docs-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/>
        <path d="M10 2.5V5.5h3"/>
        <line x1="5.5" y1="8" x2="10.5" y2="8"/>
        <line x1="5.5" y1="10.5" x2="9" y2="10.5"/>
      </svg>
      <span data-i18n="topbar.sysdocs_btn">System Docs</span>
      <span class="docs-count" id="docs-count">0</span>
    </button>
    <!-- 0.14 M15 · Backlog 入口 · 跳 #/backlog 扁平 subtask 视图 + 4-axis filter -->
    <button class="docs-btn" id="open-backlog" type="button" data-i18n-title="topbar.backlog_title" title="Open backlog view · cross-module flat subtask list with filters">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:14px;height:14px">
        <line x1="3" y1="4" x2="13" y2="4"/>
        <line x1="3" y1="8" x2="13" y2="8"/>
        <line x1="3" y1="12" x2="13" y2="12"/>
        <circle cx="2" cy="4" r="0.8" fill="currentColor"/>
        <circle cx="2" cy="8" r="0.8" fill="currentColor"/>
        <circle cx="2" cy="12" r="0.8" fill="currentColor"/>
      </svg>
      <span data-i18n="topbar.backlog_btn">Backlog</span>
