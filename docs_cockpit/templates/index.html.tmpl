      'drawer.manual_toggle': 'Manual adjust',
      'drawer.manual_tip': 'Auto: derive from subtasks · Manual: slider control',
      'drawer.subtasks_label': 'Subtasks',
      'drawer.subtasks_meta': '{done} / {total} done',
      'drawer.subtasks_empty_dash': '—',
      'drawer.subtasks_empty': 'No subtasks · progress set to manual',
      'drawer.docs_label': 'Linked Docs',
      'drawer.docs_meta_items': '{n} items',
      'drawer.docs_empty': 'No linked docs',
      'drawer.docs_preview': 'Preview',
      'drawer.docs_open': 'Open',
      'drawer.docs_back': '← Back to module',
      'drawer.docs_missing_title': 'File not found',
      'drawer.docs_missing_hint': 'The linked doc was not found at any of the candidate paths (absolute · relative to the source MD · relative to the repo root).',
      'drawer.docs_missing_tooltip': 'Not found: {path}',
      'drawer.docs_open_external': 'Opening in a new tab · this file type is not rendered inline.',
      'sysdocs.eyebrow': 'SYSTEM DOCS · MEMORY & GUIDES',
