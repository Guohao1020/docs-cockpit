      'sysdocs.section_label': 'Permanent Docs',
      'sysdocs.count_items': '{n} items',
      'sysdocs.tip_label': 'Tip',
      'sysdocs.tip_body': 'Extend the systemDocs array in your config to add more entries. Each <code style="font-family:var(--f-mono); background: var(--c-cloud); padding: 1px 6px; border-radius: 3px;">{ id, title, path, desc, icon }</code> becomes an entry in this drawer.',
      'sysdocs.empty': 'No system docs configured',
      'toast.saved': 'Saved',
      'toast.status_updated': 'Status updated',
      'toast.progress_updated': 'Progress updated · {n}%',
      'toast.progress_set': 'Progress set to {n}%',
      'status.not-started': 'Not Started',
      'status.planned': 'Planned',
      'status.in-progress': 'In Progress',
      'status.blocked': 'Blocked',
      'status.done': 'Done',
      'status.deferred': 'Deferred',
    },
    zh: {
      'topbar.crumb': '项目看板',
      'topbar.last_build': '最后构建',
      'topbar.sysdocs_btn': '系统文档',
      'topbar.sysdocs_title': '系统文档 (D)',
      'hero.eyebrow': '通用项目看板 · 模块进度',
      'hero.title': '项目进度概览',
      'hero.tagline': '模块状态、Sprint 进度、核心概念 · 一站式可视化与精细化进度控制。',
      'hero.gauge_label': '总体进度 · 模块加权',
      'kpi.title': '概览',
      'kpi.total': '总模块',
      'kpi.total_sub_prefix': '配置于 ·',
      'kpi.concepts_suffix': '个概念',
      'kpi.done': '已完成',
      'kpi.progress': '进行中 · 已排期',
      'kpi.todo': '未排期 · 阻塞',
      'kpi.meta_sum': '{m} 个模块 · {c} 个概念',
      'kanban.title': '模块 Kanban',
      'kanban.meta': '点击卡片查看文档与进度精细控制',
      'kanban.col_empty': '—',
      'kanban.doc_count_title': '{n} 份关联文档',
      'sprint.title': 'Sprint Timeline',
      'sprint.meta': '每 Sprint 的模块覆盖与平均进度',
      'sprint.empty': '无 Sprint 数据',
      'sprint.modules_suffix': '模块',
      'concept.title': '核心概念',
      'concept.meta_count': '{n} 个概念',
      'drawer.close': '关闭',
      'drawer.desc_label': '描述',
      'drawer.desc_empty': '未填写描述。',
      'drawer.status_label': '状态',
      'drawer.progress_label': '进度',
      'drawer.progress_manual': '手动',
      'drawer.progress_auto': '自动 · 子任务',
      'drawer.manual_toggle': '手动调整',
      'drawer.manual_tip': '自动:基于子任务计算 · 手动:滑块控制',
      'drawer.subtasks_label': '子任务',
      'drawer.subtasks_meta': '{done} / {total} 完成',
      'drawer.subtasks_empty_dash': '—',
      'drawer.subtasks_empty': '无子任务 · 进度切换为手动模式',
      'drawer.docs_label': '关联文档',
      'drawer.docs_meta_items': '{n} 项',
      'drawer.docs_empty': '尚未关联文档',
      'drawer.docs_preview': '预览',
      'drawer.docs_open': '打开',
      'drawer.docs_back': '← 返回模块',
      'drawer.docs_missing_title': '找不到文件',
      'drawer.docs_missing_hint': '已依次尝试:绝对路径 · 相对源 MD · 相对仓库根 · 均未找到该文件。',
      'drawer.docs_missing_tooltip': '未找到:{path}',
      'drawer.docs_open_external': '正在用浏览器新标签打开此文件 · 该类型不在抽屉内联渲染。',
      'sysdocs.eyebrow': '系统文档 · MEMORY & GUIDES',
      'sysdocs.title': '项目级文档与记忆',
      'sysdocs.section_label': '常驻文档',
      'sysdocs.count_items': '{n} 项',
      'sysdocs.tip_label': '提示',
      'sysdocs.tip_body': '在数据配置中,把 <code style="font-family:var(--f-mono); background: var(--c-cloud); padding: 1px 6px; border-radius: 3px;">systemDocs</code> 数组按需要扩展;每条 <code style="font-family:var(--f-mono); background: var(--c-cloud); padding: 1px 6px; border-radius: 3px;">{ id, title, path, desc, icon }</code> 将作为一个入口出现在此抽屉。',
      'sysdocs.empty': '尚未配置系统文档',
      'toast.saved': '已保存',
      'toast.status_updated': '状态已更新',
      'toast.progress_updated': '进度已更新 · {n}%',
      'toast.progress_set': '进度已设为 {n}%',
      'status.not-started': '未启动',
      'status.planned': '已排期',
      'status.in-progress': '进行中',
      'status.blocked': '阻塞',
      'status.done': '已完成',
      'status.deferred': '已推迟',
    }
  };

  let LANG = (() => {
    try { return localStorage.getItem(STORAGE_KEY + '::lang') || 'en'; }
    catch (e) { return 'en'; }
  })();

  function t(key, vars) {
    let s = (I18N[LANG] && I18N[LANG][key]) || I18N.en[key] || key;
    if (vars) for (const k in vars) s = s.split('{' + k + '}').join(vars[k]);
    return s;
  }

  // Lang-aware status label · still usable as STATUS_LABEL[key] for legacy call-sites
  const STATUS_LABEL = new Proxy({}, {
    get(_, s) { return t('status.' + s) || s; }
  });
  // English-locked label for places that want the EN form regardless
  const STATUS_LABEL_EN = new Proxy({}, {
    get(_, s) { return I18N.en['status.' + s] || s; }
  });

  function applyI18nStatic() {
    document.documentElement.lang = (LANG === 'zh' ? 'zh-CN' : 'en');
    document.querySelectorAll('[data-i18n]').forEach(el => {
      el.innerHTML = t(el.dataset.i18n);
    });
    document.querySelectorAll('[data-i18n-title]').forEach(el => {
      el.title = t(el.dataset.i18nTitle);
    });
    document.querySelectorAll('[data-i18n-aria]').forEach(el => {
      el.setAttribute('aria-label', t(el.dataset.i18nAria));
    });
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === LANG);
    });
  }

  // ── 文件类型推断(用于文档行的标签) ────────────────
  function fileExt(path) {
    const m = /\.([a-zA-Z0-9]+)$/.exec(path || '');
    return m ? m[1].toUpperCase() : (path && path.endsWith('/') ? 'DIR' : 'LINK');
  }

  // ── 项目基础信息 ─────────────────────────────────────
  function renderProjectMeta() {
    const p = RAW.project || {};
    const fallback = t('topbar.crumb');
    document.getElementById('brand-name').textContent = p.name || fallback;
    document.getElementById('brand-mark').textContent = (p.mark || (p.name || 'P').slice(0, 1)).toUpperCase();
    document.getElementById('hero-title').textContent = p.name || t('hero.title');
    if (p.tagline) document.getElementById('hero-tagline').textContent = p.tagline;
    if (p.eyebrow) document.getElementById('hero-eyebrow').textContent = p.eyebrow;
    document.getElementById('build-time').textContent = p.lastBuild || '—';
    document.title = (p.name || fallback) + ' · ' + t('topbar.crumb');
  }

  // ── KPI + 总进度 ─────────────────────────────────────
  function renderKpi() {
    const mods = allModules();
    const total = mods.length;
    const byStatus = {};
    STATUS_ORDER.forEach(s => byStatus[s] = 0);
    mods.forEach(m => byStatus[m.status] = (byStatus[m.status] || 0) + 1);

    document.getElementById('kpi-total').textContent = total;
    document.getElementById('kpi-done').textContent = byStatus['done'] || 0;
    document.getElementById('kpi-progress').textContent = (byStatus['in-progress'] || 0) + (byStatus['planned'] || 0);
    document.getElementById('kpi-progress-active').textContent = byStatus['in-progress'] || 0;
    document.getElementById('kpi-progress-planned').textContent = byStatus['planned'] || 0;
    document.getElementById('kpi-todo').textContent = (byStatus['not-started'] || 0) + (byStatus['blocked'] || 0);
    document.getElementById('kpi-blocked').textContent = byStatus['blocked'] || 0;
    const cn = (RAW.concepts || []).length;
    document.getElementById('kpi-concept-count').textContent = cn;
    document.getElementById('concept-meta').textContent = t('concept.meta_count', { n: cn });
    document.getElementById('kpi-meta').textContent = t('kpi.meta_sum', { m: total, c: cn });

    const overall = total ? Math.round(mods.reduce((a, m) => a + (m.progress || 0), 0) / total) : 0;
    document.getElementById('overall-pct').textContent = overall;
    document.getElementById('overall-fill').style.width = overall + '%';
  }

  // ── Kanban ───────────────────────────────────────────
  function renderKanban() {
    const root = document.getElementById('kanban');
    root.innerHTML = '';
    const grouped = {};
    STATUS_ORDER.forEach(s => grouped[s] = []);
    allModules().forEach(m => {
      if (!grouped[m.status]) grouped[m.status] = [];
      grouped[m.status].push(m);
    });

    STATUS_ORDER.forEach(s => {
      const col = document.createElement('div');
      col.className = 'k-col s-' + s;
      const items = grouped[s] || [];
      let inner = '<div class="k-col-head">' +
        '<span class="name"><span class="glyph"></span>' + STATUS_LABEL[s] + '</span>' +
        '<span class="count">' + items.length + '</span>' +
      '</div>';
      if (items.length === 0) {
        inner += '<div class="k-col-empty">—</div>';
      } else {
        inner += items.map(m => {
          const hasDocs = (m.docs && m.docs.length) ? m.docs.length : 0;
          const docPill = hasDocs
            ? '<span class="doc-pill" title="' + escapeHtml(t('kanban.doc_count_title', { n: hasDocs })) + '"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/></svg>' + hasDocs + '</span>'
            : '';
          return '<div class="m-card" data-id="' + escapeHtml(m.id) + '" tabindex="0" role="button" aria-label="' + escapeHtml(m.id + ' ' + m.title) + '">' +
            '<div class="m-id"><span>' + escapeHtml(m.id) + '</span>' + docPill + '</div>' +
            '<div class="m-title">' + escapeHtml(m.title) + '</div>' +
            '<div class="m-meta">' +
              '<span class="m-sprint">' + escapeHtml(m.sprint || '—') + '</span>' +
              '<span class="m-pct">' + (m.progress || 0) + '%</span>' +
            '</div>' +
            '<div class="bar"><div class="bar-fill" style="width:' + (m.progress || 0) + '%"></div></div>' +
          '</div>';
        }).join('');
      }
      col.innerHTML = inner;
      root.appendChild(col);
    });

    // 绑事件
    root.querySelectorAll('.m-card').forEach(el => {
      el.addEventListener('click', () => openModuleDrawer(el.dataset.id));
      el.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModuleDrawer(el.dataset.id);
        }
      });
    });
  }

  // ── Sprints ──────────────────────────────────────────
  function renderSprints() {
    const root = document.getElementById('sprints');
    if (!root) return;
    const mods = allModules();
    const bySprint = {};
    mods.forEach(m => {
      const sp = m.sprint || '—';
      if (!bySprint[sp]) bySprint[sp] = [];
      bySprint[sp].push(m);
    });
    const names = Object.keys(bySprint).sort((a, b) => a.localeCompare(b, 'zh-Hans-CN-u-kn-true'));
    if (!names.length) { root.innerHTML = '<div class="k-col-empty">' + escapeHtml(t('sprint.empty')) + '</div>'; return; }
    root.innerHTML = names.map(sp => {
      const items = bySprint[sp];
      const avg = Math.round(items.reduce((a, m) => a + (m.progress || 0), 0) / items.length);
      const cls = avg === 100 ? 's-done' : (avg > 0 ? 's-active' : '');
      return '<div class="sprint-row ' + cls + '">' +
        '<div class="s-name"><span class="s-dot"></span>' + escapeHtml(sp) + '</div>' +
        '<div class="s-bar"><div class="s-bar-fill" style="width:' + avg + '%"></div></div>' +
        '<div class="s-pct">' + avg + '%</div>' +
        '<div class="s-count">' + items.length + ' ' + escapeHtml(t('sprint.modules_suffix')) + '</div>' +
      '</div>';
    }).join('');
  }

  // ── Concepts ─────────────────────────────────────────
  function renderConcepts() {
    const root = document.getElementById('concepts');
    if (!root) return;
    const list = RAW.concepts || [];
    if (!list.length) { document.getElementById('concepts-section').style.display = 'none'; return; }
    root.innerHTML = list.map(c => (
      '<div class="c-chip">' +
        '<div class="c-id"><span>' + escapeHtml(c.id) + '</span><span class="c-sprint">' + escapeHtml(c.sprint || '—') + '</span></div>' +
        '<div class="c-title"><span class="c-status-dot s-' + c.status + '"></span>' + escapeHtml(c.title) + '</div>' +
        '<div class="bar"><div class="bar-fill" style="width:' + (c.progress || 0) + '%; background:' + statusColor(c.status) + '"></div></div>' +
        '<div class="c-pct">' + (c.progress || 0) + '%</div>' +
      '</div>'
    )).join('');
  }

  function statusColor(s) {
    return {
      'done': 'var(--s-done)',
      'in-progress': 'var(--s-progress)',
      'planned': 'var(--s-planned)',
      'blocked': 'var(--s-blocked)',
      'not-started': 'var(--s-todo)',
      'deferred': 'var(--s-deferred)'
    }[s] || 'var(--c-ink)';
  }

  // ── Module Drawer ────────────────────────────────────
  let _activeModuleId = null;
  function openModuleDrawer(id) {
    const m = getModule(id);
    if (!m) return;
    _activeModuleId = id;
    // 0.7.2:从 doc 预览返回模块视图时 · 收回 drawer 宽度
    const _drawer = document.getElementById('module-drawer');
    if (_drawer) _drawer.classList.remove('wide');

    document.getElementById('md-meta').innerHTML =
      '<span class="dot s-' + m.status + '"></span>' +
      '<span style="font-family: var(--f-mono);">' + escapeHtml(m.id) + '</span>' +
      '<span>·</span>' +
      '<span>' + STATUS_LABEL[m.status] + '</span>' +
      '<span>·</span>' +
      '<span>' + escapeHtml(m.sprint || '—') + '</span>';
    document.getElementById('md-title').textContent = m.title;

    const body = document.getElementById('md-body');

    // description
    const descHtml = m.desc
      ? '<div class="desc">' + escapeHtml(m.desc) + '</div>'
      : '<div class="desc empty">' + escapeHtml(t('drawer.desc_empty')) + '</div>';

    // docs · 0.7.1:button + 内联预览(有 content 时 marked 渲染 · 否则 file:// 打开)
    let docsHtml;
    if (m.docs && m.docs.length) {
      docsHtml = '<div class="doc-list">' + m.docs.map((d, i) => {
        // 兼容老 payload:exists 未定义视为存在 · content 未定义视为不可内联
        const exists = (d.exists !== false);
        const hasContent = !!(d.content && d.content.length);
        const rowClasses = ['doc-row'];
        if (!exists) rowClasses.push('missing');
        if (hasContent) rowClasses.push('has-content');
        const action = !exists
          ? ''
          : (hasContent
              ? t('drawer.docs_preview')
              : t('drawer.docs_open'));
        const actionSpan = action
          ? '<span class="doc-action">' + escapeHtml(action) + '</span>'
          : '';
        // 展示用 path:优先用解析后的绝对路径(用户能看到 docs/docs/ 这种 bug 的真实位置)
        const showPath = d.resolved || d.path || '';
        const titleAttr = !exists
          ? t('drawer.docs_missing_tooltip', { path: d.path || '' })
          : (d.mtime || '');
        return (
          '<button type="button" class="' + rowClasses.join(' ') + '"' +
            ' data-doc-i="' + i + '"' +
            ' title="' + escapeHtml(titleAttr) + '">' +
            '<svg class="doc-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/><line x1="5.5" y1="8" x2="10.5" y2="8"/><line x1="5.5" y1="10.5" x2="9" y2="10.5"/></svg>' +
            '<div class="doc-info"><div class="doc-title">' + escapeHtml(d.title) + '</div><div class="doc-path">' + escapeHtml(showPath) + '</div></div>' +
            actionSpan +
            '<span class="doc-ext">' + escapeHtml(fileExt(showPath)) + '</span>' +
          '</button>'
        );
      }).join('') + '</div>';
    } else {
      docsHtml = '<div class="doc-list-empty">' + escapeHtml(t('drawer.docs_empty')) + '</div>';
    }

    // status select
    const statusHtml = '<div class="status-select">' + STATUS_ORDER.map(s => (
      '<button data-status="' + s + '"' + (s === m.status ? ' class="active"' : '') + '>' +
        '<span class="ss-dot s-' + s + '"></span>' +
        '<span>' + escapeHtml(STATUS_LABEL[s]) + '</span>' +
      '</button>'
    )).join('') + '</div>';

    // subtasks
    let subtasksHtml = '';
    if (m.subtasks && m.subtasks.length) {
      subtasksHtml = '<div class="subtasks">' + m.subtasks.map((st, i) => (
        '<div class="st' + (st.done ? ' done' : '') + '" data-i="' + i + '" tabindex="0" role="checkbox" aria-checked="' + st.done + '">' +
          '<span class="check"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 6.5l2.5 2.5 4.5-5"/></svg></span>' +
          '<span class="st-text">' + escapeHtml(st.title) + '</span>' +
        '</div>'
      )).join('') + '</div>';
    } else {
      subtasksHtml = '<div class="doc-list-empty">' + escapeHtml(t('drawer.subtasks_empty')) + '</div>';
    }
    const doneCount = (m.subtasks || []).filter(s => s.done).length;
    const subtaskMeta = (m.subtasks && m.subtasks.length)
      ? t('drawer.subtasks_meta', { done: doneCount, total: m.subtasks.length })
      : t('drawer.subtasks_empty_dash');

    // progress control
    const hasSubtasks = m.subtasks && m.subtasks.length > 0;
    const isManual = m.manualProgress || !hasSubtasks;
    const progressHtml =
      '<div class="progress-control">' +
        '<div class="pc-head">' +
          '<span class="pc-num">' + (m.progress || 0) + '%</span>' +
          '<label class="toggle-row" title="' + escapeHtml(t('drawer.manual_tip')) + '">' +
            '<input type="checkbox" id="manual-toggle"' + (isManual ? ' checked' : '') + (hasSubtasks ? '' : ' disabled') + '>' +
            '<span class="toggle"></span>' +
            '<span>' + escapeHtml(t('drawer.manual_toggle')) + '</span>' +
          '</label>' +
        '</div>' +
        '<input type="range" min="0" max="100" step="1" value="' + (m.progress || 0) + '" id="pc-slider"' + (!isManual ? ' disabled' : '') + '>' +
        '<div class="pc-ticks"><span>0</span><span>25</span><span>50</span><span>75</span><span>100</span></div>' +
        '<div class="pc-steps">' +
          '<button data-step="0">0%</button>' +
          '<button data-step="25">25%</button>' +
          '<button data-step="50">50%</button>' +
          '<button data-step="75">75%</button>' +
          '<button data-step="100">100%</button>' +
        '</div>' +
      '</div>';

    body.innerHTML =
      '<div class="d-section">' +
        '<div class="d-label">' + escapeHtml(t('drawer.desc_label')) + '</div>' +
        descHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.status_label')) + '</span><span class="right">' + escapeHtml(STATUS_LABEL_EN[m.status]) + '</span></div>' +
        statusHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.progress_label')) + '</span><span class="right">' + escapeHtml(isManual ? t('drawer.progress_manual') : t('drawer.progress_auto')) + '</span></div>' +
        progressHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.subtasks_label')) + '</span><span class="right">' + escapeHtml(subtaskMeta) + '</span></div>' +
        subtasksHtml +
      '</div>' +

      '<div class="d-section">' +
        '<div class="d-label"><span>' + escapeHtml(t('drawer.docs_label')) + '</span><span class="right">' + escapeHtml(t('drawer.docs_meta_items', { n: ((m.docs && m.docs.length) || 0) })) + '</span></div>' +
        docsHtml +
      '</div>';

    // 绑事件:status
    body.querySelectorAll('.status-select button').forEach(btn => {
      btn.addEventListener('click', () => {
        const newStatus = btn.dataset.status;
        const ov = overrides[id] || {};
        ov.status = newStatus;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
        toast(t('toast.status_updated'));
      });
    });

    // 绑事件:slider
    const slider = body.querySelector('#pc-slider');
    if (slider) {
      slider.addEventListener('input', e => {
        const v = parseInt(e.target.value, 10);
        body.querySelector('.pc-num').textContent = v + '%';
      });
      slider.addEventListener('change', e => {
        const v = parseInt(e.target.value, 10);
        const ov = overrides[id] || {};
        ov.progress = v;
        ov.manualProgress = true;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        toast(t('toast.progress_updated', { n: v }));
      });
    }
    // 绑:快捷 25/50/75/100
    body.querySelectorAll('.pc-steps button').forEach(b => {
      b.addEventListener('click', () => {
        const v = parseInt(b.dataset.step, 10);
        if (slider) {
          slider.disabled = false;
          slider.value = v;
        }
        const ov = overrides[id] || {};
        ov.progress = v;
        ov.manualProgress = true;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
        toast(t('toast.progress_set', { n: v }));
      });
    });
    // 绑:手动切换
    const manualToggle = body.querySelector('#manual-toggle');
    if (manualToggle) {
      manualToggle.addEventListener('change', e => {
        const isManual = e.target.checked;
        const ov = overrides[id] || {};
        ov.manualProgress = isManual;
        if (!isManual) delete ov.progress;
        overrides[id] = ov;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
      });
    }
    // 绑:子任务
    body.querySelectorAll('.st').forEach(stEl => {
      const toggleSt = () => {
        const i = stEl.dataset.i;
        const k = id + '__st' + i;
        const cur = stEl.classList.contains('done');
        overrides[k] = !cur;
        saveOverrides(overrides);
        renderAll();
        openModuleDrawer(id);
      };
      stEl.addEventListener('click', toggleSt);
      stEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleSt(); }
      });
    });

    // 0.7.1:绑 docs 按钮 · 有 content 走内联预览 · 否则尝试 file:// 打开 · 缺失则弹错
    body.querySelectorAll('.doc-list button.doc-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.docI, 10);
        const d = (m.docs || [])[i];
        if (!d) return;
        showDocPreview(id, i);
      });
    });

    openDrawer('module-drawer');
  }

  // ── 0.7.1 · drawer 内联 MD 预览 ──────────────────────────
  // 不重开 drawer · 只换 #md-body 内容(drawer-head 保持模块上下文 · 标识"还在这个模块")
  // back 按钮 → 调 openModuleDrawer(_activeModuleId) 恢复模块视图
  function showDocPreview(moduleId, docIndex) {
    const m = getModule(moduleId);
    if (!m) return;
    const d = (m.docs || [])[docIndex];
    if (!d) return;
    const body = document.getElementById('md-body');
    if (!body) return;

    const backBtnHtml =
      '<button type="button" class="pv-back" id="pv-back">' +
        '<svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2.5L4 6l4 3.5"/></svg>' +
        '<span>' + escapeHtml(t('drawer.docs_back')) + '</span>' +
      '</button>';

    const exists = (d.exists !== false);
    const showPath = d.resolved || d.path || '';
    const headHtml =
      '<div class="doc-preview-head">' +
        backBtnHtml +
        '<div class="pv-meta">' +
          '<div class="pv-title">' + escapeHtml(d.title || '') + '</div>' +
          '<div class="pv-path">' + escapeHtml(showPath) + '</div>' +
          (d.mtime ? '<div class="pv-mtime">' + escapeHtml(d.mtime) + '</div>' : '') +
        '</div>' +
      '</div>';

    let contentHtml;
    if (!exists) {
      // 文件不存在 · drawer 内提示 · 不跳出浏览器
      contentHtml =
        '<div class="doc-preview-missing">' +
          '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_missing_title')) + '</div>' +
          '<div>' + escapeHtml(t('drawer.docs_missing_hint')) + '</div>' +
          '<div class="pv-missing-path">' + escapeHtml(d.path || '') + '</div>' +
        '</div>';
    } else if (d.content) {
      // 有 content → marked 渲染(CDN 失败时 fallback 到 <pre> · 见底部 CDN guard)
      let rendered;
      try {
        rendered = (typeof marked !== 'undefined' && marked.parse)
          ? marked.parse(d.content)
          : '<pre>' + escapeHtml(d.content) + '</pre>';
      } catch (e) {
        rendered = '<pre>' + escapeHtml(d.content) + '</pre>';
      }
      contentHtml = '<div class="doc-preview-body">' + rendered + '</div>';
    } else {
      // 非 .md / .markdown 或文件过大 → 尝试浏览器原生打开(图片 / PDF 等)
      // 用 file:// URL(resolved 是绝对路径)
      const url = d.resolved
        ? 'file:///' + d.resolved.replace(/\\/g, '/').replace(/^\/+/, '')
        : d.path;
      try { window.open(url, '_blank'); } catch (e) {}
      contentHtml =
        '<div class="doc-list-empty">' +
          escapeHtml(t('drawer.docs_open_external')) +
        '</div>';
    }

    body.innerHTML = headHtml + contentHtml;

    // 0.7.2:预览模式加宽 drawer · 让 MD 表格 / 代码块 / 长行有空间
    const drawer = document.getElementById('module-drawer');
    if (drawer) drawer.classList.add('wide');

    // 语法高亮
    if (d.content && typeof hljs !== 'undefined' && hljs.highlightElement) {
      body.querySelectorAll('.doc-preview-body pre code').forEach(b => {
        try { hljs.highlightElement(b); } catch (e) {}
      });
    }

    // 绑 back
    const backBtn = body.querySelector('#pv-back');
    if (backBtn) {
      backBtn.addEventListener('click', () => openModuleDrawer(moduleId));
    }

    // 滚到顶
    body.scrollTop = 0;
  }

  // ── System Docs Drawer ───────────────────────────────
  function renderSystemDocs() {
    const list = RAW.systemDocs || [];
    document.getElementById('docs-count').textContent = list.length;
    document.getElementById('dd-count').textContent = t('sysdocs.count_items', { n: list.length });
    const el = document.getElementById('sysdoc-list');
    if (!list.length) { el.innerHTML = '<div class="doc-list-empty">' + escapeHtml(t('sysdocs.empty')) + '</div>'; return; }
    el.innerHTML = list.map(d => {
      const iconSvg = iconForDoc(d.icon || 'doc');
      return '<a class="sysdoc-row" href="' + escapeHtml(d.path || '#') + '" target="_blank" rel="noopener">' +
        '<span class="sd-icon">' + iconSvg + '</span>' +
        '<div class="sd-info">' +
          '<div class="sd-title">' + escapeHtml(d.title) + '</div>' +
          '<div class="sd-desc">' + escapeHtml(d.desc || '') + '</div>' +
          '<div class="sd-path">' + escapeHtml(d.path || '') + '</div>' +
        '</div>' +
        '<svg class="sd-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3l5 5-5 5"/></svg>' +
      '</a>';
    }).join('');
  }
  function iconForDoc(kind) {
    if (kind === 'memory') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="5.5"/><path d="M8 5v3l2 1.5"/></svg>';
    }
    if (kind === 'design') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="2.5" width="11" height="11" rx="2"/><path d="M2.5 6.5h11M6.5 2.5v11"/></svg>';
    }
    if (kind === 'plan') {
      return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h10v10H3z"/><path d="M3 6.5h10M6.5 3v10"/></svg>';
    }
    return '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/><path d="M10 2.5V5.5h3"/><line x1="5.5" y1="8" x2="10.5" y2="8"/><line x1="5.5" y1="10.5" x2="9" y2="10.5"/></svg>';
  }

  // ── Drawer 通用 ─────────────────────────────────────
  function openDrawer(id) {
    document.querySelectorAll('.drawer').forEach(d => d.classList.toggle('open', d.id === id));
    document.getElementById('scrim').classList.add('open');
  }
  function closeDrawer() {
    document.querySelectorAll('.drawer').forEach(d => {
      d.classList.remove('open');
      d.classList.remove('wide');  // 0.7.2:关 drawer 时一并收回 doc-preview 加宽
    });
    document.getElementById('scrim').classList.remove('open');
    _activeModuleId = null;
  }

  // ── Toast ─────────────────────────────────────────
  let _toastTimer = null;
  function toast(msg) {
    const el = document.getElementById('toast');
    document.getElementById('toast-msg').textContent = msg;
    el.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => el.classList.remove('show'), 1600);
  }

  // ── 全量重绘 ────────────────────────────────────────
  function renderAll() {
    renderKpi();
    renderKanban();
    renderSprints();
    renderConcepts();
  }

  // ── 初始化 ────────────────────────────────────────
  function init() {
    applyI18nStatic();
    renderProjectMeta();
    renderSystemDocs();
    renderAll();

    // Lang toggle handler
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => {
        LANG = btn.dataset.lang;
        try { localStorage.setItem(STORAGE_KEY + '::lang', LANG); } catch (e) {}
        applyI18nStatic();
        renderProjectMeta();
        renderSystemDocs();
        renderAll();
        // If module drawer is open · re-render it too
        if (_activeModuleId) openModuleDrawer(_activeModuleId);
      });
    });

    document.getElementById('open-docs').addEventListener('click', () => openDrawer('docs-drawer'));
    document.getElementById('md-close').addEventListener('click', closeDrawer);
    document.getElementById('dd-close').addEventListener('click', closeDrawer);
    document.getElementById('scrim').addEventListener('click', closeDrawer);

    document.addEventListener('keydown', e => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (document.activeElement && document.activeElement.tagName) || '';
      const inField = tag === 'INPUT' || tag === 'TEXTAREA';
      if (e.key === 'Escape') { closeDrawer(); return; }
      if (inField) return;
      if (e.key === 'd' || e.key === 'D') {
        const docsOpen = document.getElementById('docs-drawer').classList.contains('open');
        if (docsOpen) closeDrawer(); else openDrawer('docs-drawer');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
