  // ── 0.11.0-alpha.6 §4.b · hash router ─────────────────────
  // URL hash 模型(plan §6.6):
  //   ''                     · dashboard 首页
  //   '#/module/<id>'        · module 二级页面(split-view · §4.c/d 填内容)
  //   '#/sysdoc/<id>'        · system doc 二级页面
  //   '#/concept/<id>'       · concept 二级页面
  // Query 参数:
  //   '?ui=modal'            · 强制走老 modal drawer(向后兼容)
  function _hasModalQueryParam() {
    try {
      return new URLSearchParams(window.location.search).get('ui') === 'modal';
    } catch (e) { return false; }
  }
  const _UI_MODE = _hasModalQueryParam() ? 'modal' : 'split-view';

  function parseHash() {
    const raw = (window.location.hash || '').replace(/^#\/?/, '').trim();
    if (!raw) return { kind: 'dashboard', id: null };
    // 0.14 M15 · 支持 query string · #/backlog?sprint=0.14&status=not-started
    const qIdx = raw.indexOf('?');
    const pathPart = qIdx >= 0 ? raw.slice(0, qIdx) : raw;
    const queryPart = qIdx >= 0 ? raw.slice(qIdx + 1) : '';
    const parts = pathPart.split('/');
    const kind = parts[0];
    const id = parts[1] ? decodeURIComponent(parts[1]) : null;
    const query = {};
    if (queryPart) {
      for (const seg of queryPart.split('&')) {
        const [k, v] = seg.split('=');
        if (k) query[decodeURIComponent(k)] = decodeURIComponent(v || '');
      }
    }
    if (['module', 'sysdoc', 'concept', 'backlog'].indexOf(kind) >= 0) {
      return { kind, id, query };
    }
    return { kind: 'dashboard', id: null, query: {} };
  }

  // 当前路由状态 · 全局
  let _currentRoute = { kind: 'dashboard', id: null };

  // 0.11.0-alpha.6 §4.c · drawer DOM 在 modal / split-view 之间搬家
  // modal 默认 DOM 位置:body 直接 child(<aside id="module-drawer">)
  // split-view:JS 把 drawer.appendChild 进 #split-nav-slot · CSS 切样式
  function _moveModuleDrawerToSplitNav() {
    const drawer = document.getElementById('module-drawer');
    const slot = document.getElementById('split-nav-slot');
    if (!drawer || !slot) return;
    if (drawer.parentElement !== slot) slot.appendChild(drawer);
    // split-view 不需要 .open class(永远显)· 但 _activeModuleId 仍要追踪
    drawer.classList.add('open');
  }

  // 0.14.4 · per-module Refine 按钮已干掉 · build 自动写 docs/refine/M<id>.md 替代
  // 老 build 出的 HTML 若已有 .refine-btn DOM · 走 CSS `display:none` 兜底
  // copyModuleRefinePrompt 函数保留(下面)· 给定制脚本 / MCP / 老书签兜底

  // 0.11.3 · 「同步 source」按钮 · 主动清当前 module 的 subtask override
  // 跟 loadOverrides 的 build-time auto-invalidation 互补 · 用户不想等下次 build 时立刻同步
  function _injectResetOverridesButton(moduleId) {
    const drawer = document.getElementById('module-drawer');
    if (!drawer) return;
    const head = drawer.querySelector('.drawer-head');
    if (!head) return;
    const old = head.querySelector('.reset-overrides-btn');
    if (old) old.remove();
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'reset-overrides-btn';
    btn.title = t('reset.btn_tooltip') || 'Clear local subtask overrides for this module · reload from source MD';
    btn.innerHTML = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8a6 6 0 1 0 1.5-3.97"/><polyline points="2 1.5 2 4.5 5 4.5"/></svg>' +
      '<span>' + escapeHtml(t('reset.btn_label') || '同步 source') + '</span>';
    btn.addEventListener('click', () => {
      // 清 `<moduleId>__st__*` + `<moduleId>` 两类 key · 让 source MD 完全接管本 module
      let dirty = false;
      for (const k of Object.keys(overrides)) {
        if (k === moduleId) { delete overrides[k]; dirty = true; continue; }
        if (k.indexOf(moduleId + '__st__') === 0) { delete overrides[k]; dirty = true; }
      }
      if (dirty) saveOverrides(overrides);
      toast(t('toast.reset_done') || ('Reset overrides for ' + moduleId + ' · reloading…'));
      setTimeout(() => location.reload(), 400);
    });
    head.appendChild(btn);
  }

  // ─── 0.14 M15 · Backlog view + 4-axis filter ────────────────────────
  // backlog state · query-encoded:time / sprint / status / q(search)
  let _backlogFilters = { time: 'all', sprint: 'all', status: 'all', q: '' };
  const BUNDLE_SELECTION_KEY = 'docs-cockpit-bundle-selection-v1';
  let _bundleSelection = new Set();
  // 0.14.1 · multi-select shift-range pivot · 最后被点的 row · 给 shift-click 算范围
  let _lastClickedStKey = null;

  function _loadBundleSelection() {
    try {
      const raw = localStorage.getItem(BUNDLE_SELECTION_KEY);
      if (!raw) return new Set();
      const parsed = JSON.parse(raw);
      // 跟 0.11.3 build-time invalidation 一致 · build 切就清
      if (parsed._built_at && parsed._built_at !== BUILD_TIME) return new Set();
      return new Set(parsed.ids || []);
    } catch (e) { return new Set(); }
  }
  function _saveBundleSelection() {
    try {
      localStorage.setItem(BUNDLE_SELECTION_KEY, JSON.stringify({
        _built_at: BUILD_TIME,
        ids: Array.from(_bundleSelection),
      }));
    } catch (e) {}
  }

  function _flatSubtasks() {
    // 把 RAW.modules 摊成 [{subtask, module}] 跨 module flat list
    const out = [];
    for (const m of (RAW.modules || [])) {
      for (const s of (m.subtasks || [])) {
        if (!s.id) continue;
        out.push({ ...s, _module: m });
      }
    }
    return out;
  }

  function _passesFilter(item, filters) {
    if (filters.status !== 'all') {
      if (item.status !== filters.status) return false;
    }
    if (filters.sprint !== 'all') {
      // 0.14.2 · `__unscheduled__` 匹配空 sprint · 其它走精确字符串
      const mSprint = (item._module.sprint || '').toString().trim();
      if (filters.sprint === '__unscheduled__') {
        if (mSprint) return false;
      } else {
        if (mSprint !== filters.sprint) return false;
      }
    }
    if (filters.time !== 'all') {
      // module.mtime 是 "YYYY-MM-DD HH:MM" · 解析对比
      const mt = item._module.mtime;
      if (!mt) return false;
      const t = Date.parse(mt.replace(' ', 'T'));
      if (isNaN(t)) return false;
      const days = filters.time === '7d' ? 7 : filters.time === '30d' ? 30 : null;
      if (days != null) {
        const cutoff = Date.now() - days * 86400 * 1000;
        if (t < cutoff) return false;
      }
    }
    if (filters.q) {
      const q = filters.q.toLowerCase();
      const hay = (item.id + ' ' + (item.title || '') + ' ' + item._module.id).toLowerCase();
      if (hay.indexOf(q) < 0) return false;
    }
    return true;
  }

  function _filtersToQuery(filters) {
    const parts = [];
    if (filters.time !== 'all') parts.push('time=' + encodeURIComponent(filters.time));
    if (filters.sprint !== 'all') parts.push('sprint=' + encodeURIComponent(filters.sprint));
    if (filters.status !== 'all') parts.push('status=' + encodeURIComponent(filters.status));
    if (filters.q) parts.push('q=' + encodeURIComponent(filters.q));
    return parts.length ? '?' + parts.join('&') : '';
  }

  function _applyFiltersFromQuery(query) {
    _backlogFilters.time = query.time || 'all';
    _backlogFilters.sprint = query.sprint || 'all';
    _backlogFilters.status = query.status || 'all';
    _backlogFilters.q = query.q || '';
    // sync DOM controls(sprint 不在这里 sync · renderBacklog 里 _populateSprintFilter 之后再 sync)
    const setEl = (id, v) => { const e = document.getElementById(id); if (e) e.value = v; };
    setEl('backlog-filter-time', _backlogFilters.time);
    setEl('backlog-filter-status', _backlogFilters.status);
    setEl('backlog-filter-search', _backlogFilters.q);
  }

  // 0.14.2 · natural version sort · "0.14" > "0.13" > "0.9" 而不是字典序 "0.9" > "0.14"
  // 也支持 M1.2 / 2026-Q1 / epic 名等混合 · fallback locale compare
  function _sprintNaturalSort(a, b) {
    // 按 '/' '.' '-' 切段 · 数字段比数字 · 字符串段比字符串
    const reSeg = /(\d+|\D+)/g;
    const aSegs = (a.match(reSeg) || []);
    const bSegs = (b.match(reSeg) || []);
    for (let i = 0; i < Math.max(aSegs.length, bSegs.length); i++) {
      const ax = aSegs[i] || '';
      const bx = bSegs[i] || '';
      const an = parseInt(ax, 10);
      const bn = parseInt(bx, 10);
      if (!isNaN(an) && !isNaN(bn)) {
        if (an !== bn) return bn - an;  // desc(新版本在前)
      } else {
        const c = bx.localeCompare(ax);
        if (c !== 0) return c;
      }
    }
    return 0;
  }

  function _populateSprintFilter() {
    const sel = document.getElementById('backlog-filter-sprint');
    if (!sel) return;
    const group = sel.closest('.backlog-filter-group');
    // 收 module 里所有 unique sprint + 检测 unscheduled
    const sprints = new Set();
    let hasUnscheduled = false;
    for (const m of (RAW.modules || [])) {
      const s = (m.sprint || '').toString().trim();
      if (s) sprints.add(s);
      else hasUnscheduled = true;
    }
    // 0.14.2 · 项目没 sprint 概念 → 隐藏整个 Sprint 过滤器(plan §1 「不是每项目都有版本号」)
    if (sprints.size === 0 && !hasUnscheduled) {
      if (group) group.style.display = 'none';
      return;
    }
    if (group) group.style.display = '';
    const sorted = Array.from(sprints).sort(_sprintNaturalSort);
    // 保留第一个 "All" option · 清掉旧的 sprint options
    while (sel.options.length > 1) sel.remove(1);
    for (const s of sorted) {
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      sel.appendChild(opt);
    }
    if (hasUnscheduled) {
      const opt = document.createElement('option');
      opt.value = '__unscheduled__';
      opt.textContent = t('backlog.filter.sprint.unscheduled') || '(unscheduled)';
      sel.appendChild(opt);
    }
    // 0.14.2 fix · populate 之后立刻 sync 当前 filter 值到 DOM · 不再走 setTimeout
    // 安全 fallback · 如果存储的 sprint 在新 options 里不存在 · 退到 'all'
    const desired = _backlogFilters.sprint || 'all';
    const exists = Array.from(sel.options).some(o => o.value === desired);
    sel.value = exists ? desired : 'all';
    if (!exists) _backlogFilters.sprint = 'all';
  }

  function _renderBundleVerdict() {
    // 走 window.__BUNDLE_META__ 算 selected 的 cohesion / conflict 总分
    const ids = Array.from(_bundleSelection);
    const verdictEl = document.getElementById('bb-verdict');
    if (!verdictEl) return;
    if (ids.length < 2) {
      verdictEl.textContent = '';
      verdictEl.title = '';
      return;
    }
    const meta = window.__BUNDLE_META__;
    if (!meta || !meta.pairs) {
      verdictEl.textContent = '(bundle-meta.js not loaded · run build)';
      verdictEl.title = '';
      return;
    }
    let cohSum = 0, cohN = 0, maxConf = 0;
    for (let i = 0; i < ids.length; i++) {
      for (let j = i + 1; j < ids.length; j++) {
        const a = ids[i], b = ids[j];
        const k = a < b ? a + '__' + b : b + '__' + a;
        const p = meta.pairs[k];
        if (p) {
          cohSum += p.cohesion;
          if (p.conflict > maxConf) maxConf = p.conflict;
        }
        cohN++;
      }
    }
    const avg = cohN ? (cohSum / cohN) : 0;
    const score = avg - maxConf;
    let verdict;
    if (maxConf >= 5) verdict = '⚠ conflict';
    else if (avg >= 4) verdict = '✅ highly cohesive';
    else if (avg >= 2) verdict = 'ok';
    else verdict = 'weak';
    verdictEl.textContent = verdict + ' · avg ' + avg.toFixed(1);
    verdictEl.title = 'avg cohesion ' + avg.toFixed(2) + ' · max conflict ' + maxConf + ' · score ' + score.toFixed(2);
  }

  function _renderBundleBar() {
    const bar = document.getElementById('bundle-bar');
    const countEl = document.getElementById('bb-count');
    if (!bar) return;
    if (_bundleSelection.size === 0) {
      bar.setAttribute('hidden', '');
      return;
    }
    bar.removeAttribute('hidden');
    if (countEl) countEl.textContent = _bundleSelection.size + ' selected';
    _renderBundleVerdict();
  }

  function _toggleBundleSelection(stKey, checked) {
    if (checked) _bundleSelection.add(stKey);
    else _bundleSelection.delete(stKey);
    _saveBundleSelection();
    _renderBundleBar();
    // 同步行的 selected 样式
    const row = document.querySelector('.backlog-row[data-st-key="' + stKey + '"]');
    if (row) row.classList.toggle('selected', checked);
    // 同步 summary 的 select-all 状态(part of selection 变化)
    _refreshSelectAllState();
  }

  function _refreshSelectAllState() {
    const sa = document.getElementById('backlog-select-all');
    if (!sa) return;
    const visible = _backlogVisibleIds;
    if (visible.length === 0) {
      sa.checked = false;
      sa.indeterminate = false;
      return;
    }
    const selectedCount = visible.filter(id => _bundleSelection.has(id)).length;
    sa.checked = (selectedCount === visible.length);
    sa.indeterminate = (selectedCount > 0 && selectedCount < visible.length);
    // 也同步 count 数字
    const summary = document.getElementById('backlog-summary');
    const countEl = summary && summary.querySelector('.bs-count');
    if (countEl) {
      const all = _flatSubtasks();
      countEl.textContent = visible.length + ' / ' + all.length + ' subtasks shown · ' + _bundleSelection.size + ' selected';
    }
  }

  // 0.14.1 · shift-click range select · 从 pivot 到 current 之间全 toggle
  function _toggleBundleRange(fromKey, toKey, targetState) {
    if (!fromKey || !toKey) return;
    const visible = _backlogVisibleIds;
    const i = visible.indexOf(fromKey);
    const j = visible.indexOf(toKey);
    if (i < 0 || j < 0) return;
    const [lo, hi] = i < j ? [i, j] : [j, i];
    for (let k = lo; k <= hi; k++) {
      const sid = visible[k];
      if (targetState) _bundleSelection.add(sid);
      else _bundleSelection.delete(sid);
      const row = document.querySelector('.backlog-row[data-st-key="' + sid + '"]');
      if (row) {
        row.classList.toggle('selected', targetState);
        const cb = row.querySelector('input[type="checkbox"]');
        if (cb) cb.checked = targetState;
      }
    }
    _saveBundleSelection();
    _renderBundleBar();
    _refreshSelectAllState();
  }

  function _bindBacklogSummaryActions(filtered) {
    // Select all visible · master checkbox
    const sa = document.getElementById('backlog-select-all');
    if (sa) {
      sa.addEventListener('change', () => {
        const targetState = sa.checked;
        for (const item of filtered) {
          if (targetState) _bundleSelection.add(item.id);
          else _bundleSelection.delete(item.id);
        }
        _saveBundleSelection();
        // re-render 同步所有 checkbox + selected class
        renderBacklog();
      });
    }
    // 快捷按钮:+ not-started · + in-progress · × clear visible
    const summary = document.getElementById('backlog-summary');
    if (!summary) return;
    summary.querySelectorAll('.bs-quick').forEach(btn => {
      btn.addEventListener('click', () => {
        const action = btn.dataset.bsQuick;
        if (action === 'clear-visible') {
          for (const item of filtered) _bundleSelection.delete(item.id);
        } else {
          // 把 filtered 内 status == action 的全部加进 selection
          for (const item of filtered) {
            if (item.status === action) _bundleSelection.add(item.id);
          }
        }
        _saveBundleSelection();
        renderBacklog();
      });
    });
  }

  // 0.14.1 · 渲染时记下当前 filtered 顺序 · shift-click range 算法用
  let _backlogVisibleIds = [];

  function renderBacklog() {
    const list = document.getElementById('backlog-list');
    const summary = document.getElementById('backlog-summary');
    if (!list) return;
    _populateSprintFilter();
    const all = _flatSubtasks();
    const filtered = all.filter(x => _passesFilter(x, _backlogFilters));
    // sort · sprint desc · module id · subtask order(stable)
    filtered.sort((a, b) => {
      const sa = (a._module.sprint || ''), sb = (b._module.sprint || '');
      if (sa !== sb) return sb.localeCompare(sa);
      return (a._module.id || '').localeCompare(b._module.id || '');
    });
    _backlogVisibleIds = filtered.map(s => s.id);
    if (summary) {
      // 0.14.1 · summary 改成 select-all + 快捷按钮 + count
      const allSelected = filtered.length > 0 && filtered.every(s => _bundleSelection.has(s.id));
      const someSelected = filtered.some(s => _bundleSelection.has(s.id));
      summary.innerHTML =
        '<span class="bs-count">' +
          escapeHtml(filtered.length + ' / ' + all.length + ' subtasks shown · ' + _bundleSelection.size + ' selected') +
        '</span>' +
        '<span class="bs-actions">' +
          '<label title="' + escapeHtml(t('backlog.selectall_title') || 'Select all visible (or Shift-click to range-select rows)') + '">' +
            '<input type="checkbox" id="backlog-select-all"' + (allSelected ? ' checked' : '') + '>' +
            '<span>' + escapeHtml(t('backlog.selectall') || 'Select all visible') + '</span>' +
          '</label>' +
          '<button class="bs-quick" data-bs-quick="not-started" type="button" title="' + escapeHtml(t('backlog.quick.notstarted_title') || 'Select all not-started in current filter') + '">' +
            escapeHtml(t('backlog.quick.notstarted') || '+ not-started') +
          '</button>' +
          '<button class="bs-quick" data-bs-quick="in-progress" type="button">' +
            escapeHtml(t('backlog.quick.inprogress') || '+ in-progress') +
          '</button>' +
          '<button class="bs-quick" data-bs-quick="clear-visible" type="button">' +
            escapeHtml(t('backlog.quick.clearvisible') || '× clear visible') +
          '</button>' +
        '</span>';
      // 半选状态 indeterminate
      const sa = document.getElementById('backlog-select-all');
      if (sa) sa.indeterminate = someSelected && !allSelected;
      _bindBacklogSummaryActions(filtered);
    }
    list.innerHTML = filtered.map(s => {
      const stKey = s.id;
      const sel = _bundleSelection.has(stKey);
      const doneClass = s.done ? ' done' : '';
      const statusBadgeClass = s.done ? 's-done' : (s.status === 'blocked' ? 's-blocked' : (s.status === 'in-progress' ? 's-in-progress' : ''));
      const sprintLabel = (s._module.sprint || '').toString().trim() || (t('backlog.filter.sprint.unscheduled') || '—');
      return '<div class="backlog-row' + doneClass + (sel ? ' selected' : '') + '" data-st-key="' + escapeHtml(stKey) + '">' +
        '<input type="checkbox"' + (sel ? ' checked' : '') + ' aria-label="Select subtask for bundle">' +
        '<span class="br-id">' + escapeHtml(stKey) + '</span>' +
        '<span class="br-title">' + escapeHtml(s.title || '') + '</span>' +
        '<span class="br-meta">' +
          '<span class="br-badge">' + escapeHtml(s._module.id) + '</span>' +
          '<span class="br-badge">' + escapeHtml(sprintLabel) + '</span>' +
          '<span class="br-badge ' + statusBadgeClass + '">' + escapeHtml(s.status || '') + '</span>' +
        '</span>' +
        '<button class="br-prompt-btn" type="button" data-action="copy-prompt" title="Copy single subtask prompt">' +
          '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="3" width="9" height="11" rx="1.5"/><path d="M3 5v8.5A1.5 1.5 0 0 0 4.5 15h7"/></svg>' +
        '</button>' +
      '</div>';
    }).join('');
    // 行 click → 切 #/module/<id> · checkbox click stop propagation
    list.querySelectorAll('.backlog-row').forEach(row => {
      const stKey = row.dataset.stKey;
      const cb = row.querySelector('input[type="checkbox"]');
      if (cb) {
        cb.addEventListener('click', (e) => {
          e.stopPropagation();
          // 0.14.1 · shift-click range · 从上次点的 row 到当前
          if (e.shiftKey && _lastClickedStKey && _lastClickedStKey !== stKey) {
            // checkbox click 先 toggle 自己 · 用 cb.checked 当 target state
            _toggleBundleRange(_lastClickedStKey, stKey, cb.checked);
          } else {
            _toggleBundleSelection(stKey, cb.checked);
          }
          _lastClickedStKey = stKey;
        });
      }
      const promptBtn = row.querySelector('[data-action="copy-prompt"]');
      if (promptBtn) {
        promptBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          copySubtaskPrompt(stKey);
        });
      }
      row.addEventListener('click', (e) => {
        // 点空白 / id / title → navigate
        if (e.target.tagName === 'INPUT' || e.target.closest('button')) return;
        // 找 module id
        const item = all.find(x => x.id === stKey);
        if (item) {
          window.location.hash = '#/module/' + item._module.id;
        }
      });
    });
    _renderBundleBar();
  }

  // filter control bindings · 一次绑定 · setState + re-render + URL sync
  function _bindBacklogFilters() {
    const ids = ['backlog-filter-time', 'backlog-filter-sprint', 'backlog-filter-status'];
    ids.forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener('change', () => {
        const key = id.replace('backlog-filter-', '');
        _backlogFilters[key] = el.value;
        _syncBacklogUrl();
        renderBacklog();
      });
    });
    const search = document.getElementById('backlog-filter-search');
    if (search) {
      let debounce;
      search.addEventListener('input', () => {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
          _backlogFilters.q = search.value || '';
          _syncBacklogUrl();
          renderBacklog();
        }, 150);
      });
    }
    const clearBtn = document.getElementById('backlog-filter-clear');
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        _backlogFilters = { time: 'all', sprint: 'all', status: 'all', q: '' };
        _applyFiltersFromQuery({});
        _syncBacklogUrl();
        renderBacklog();
      });
    }
  }

  function _syncBacklogUrl() {
    const q = _filtersToQuery(_backlogFilters);
    const newHash = '#/backlog' + q;
    if (window.location.hash !== newHash) {
      // replaceState 避免 history pollution
      history.replaceState(null, '', newHash);
    }
  }

  function copyBundlePrompt() {
    const ids = Array.from(_bundleSelection);
    if (ids.length === 0) {
      toast('No subtasks selected');
      return;
    }
    // 走 CLI command copy(MVP · 无 server fetch)
    const cmd = 'docs-cockpit prompt --bundle ' + ids.join(',') + ' --copy';
    (async () => {
      try {
        await navigator.clipboard.writeText(cmd);
        toast(t('toast.bundle_cli_copied') || 'CLI command copied · paste in terminal · prompt → clipboard');
        return;
      } catch (e) {}
      try {
        const ta = document.createElement('textarea');
        ta.value = cmd;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        toast(ok ? (t('toast.bundle_cli_copied') || 'CLI copied') : 'Copy failed');
      } catch (e) {
        toast('Copy failed · ' + e.message);
      }
    })();
  }

  function _bindBundleBar() {
    const copyBtn = document.getElementById('bb-copy');
    const clearBtn = document.getElementById('bb-clear');
    if (copyBtn) copyBtn.addEventListener('click', copyBundlePrompt);
    if (clearBtn) clearBtn.addEventListener('click', () => {
      _bundleSelection.clear();
      _saveBundleSelection();
      _renderBundleBar();
      // re-render to clear checked state
      renderBacklog();
    });
  }

  function copyModuleRefinePrompt(moduleId) {
    const prompt = (window.__REFINE_PROMPTS__ || {})[moduleId];
    if (!prompt) {
      toast(t('toast.refine_missing') || 'Refine prompt not in cache · run docs-cockpit build to refresh prompts-refine.js');
      return;
    }
    (async () => {
      try {
        await navigator.clipboard.writeText(prompt);
        toast(t('toast.refine_copied') || 'Refine prompt copied · paste to Claude / Codex · expect a YAML patch back');
        return;
      } catch (e) {}
      try {
        const ta = document.createElement('textarea');
        ta.value = prompt;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        toast(ok ? (t('toast.refine_copied') || 'Refine prompt copied') : 'Copy failed · prompt size: ' + prompt.length + ' chars');
      } catch (e) {
        toast('Copy failed · ' + e.message);
      }
    })();
  }
  function _moveModuleDrawerBackToBody() {
    const drawer = document.getElementById('module-drawer');
    if (!drawer) return;
    if (drawer.parentElement !== document.body) {
      document.body.appendChild(drawer);
    }
    drawer.classList.remove('open');
  }

  function applyRoute() {
    _currentRoute = parseHash();
    const body = document.body;
    const splitPage = document.getElementById('split-page');
    const backlogPage = document.getElementById('backlog-page');
    const backBtn = document.getElementById('back-btn');
    const crumb = document.getElementById('topbar-crumb');

    if (_currentRoute.kind === 'dashboard') {
      body.classList.remove('split-mode');
      body.classList.remove('backlog-mode');
      splitPage.setAttribute('hidden', '');
      if (backlogPage) backlogPage.setAttribute('hidden', '');
      if (backBtn) backBtn.setAttribute('hidden', '');
      if (crumb) crumb.textContent = t('topbar.crumb');
      _moveModuleDrawerBackToBody();
      const scrim = document.getElementById('scrim');
      if (scrim) scrim.classList.remove('open');
    } else if (_currentRoute.kind === 'backlog') {
      // 0.14 M15 · backlog view · 跨 module 扁平 subtask 列表 + 4-axis filter
      body.classList.remove('split-mode');
      body.classList.add('backlog-mode');
      splitPage.setAttribute('hidden', '');
      if (backlogPage) backlogPage.removeAttribute('hidden');
      if (backBtn) backBtn.removeAttribute('hidden');
      if (crumb) crumb.textContent = t('topbar.backlog_crumb') || 'Backlog';
      _moveModuleDrawerBackToBody();
      // 从 URL query 加载 filters · 应用 + 渲染
      try { _applyFiltersFromQuery(_currentRoute.query || {}); } catch (e) { console.error(e); }
      try { renderBacklog(); } catch (e) { console.error(e); }
    } else {
      body.classList.remove('backlog-mode');
      body.classList.add('split-mode');
      splitPage.removeAttribute('hidden');
      if (backlogPage) backlogPage.setAttribute('hidden', '');
      if (backBtn) backBtn.removeAttribute('hidden');
      if (crumb) {
        const kindLabel = _currentRoute.kind === 'module' ? 'Module'
                        : _currentRoute.kind === 'sysdoc' ? 'System Doc'
                        : 'Concept';
        crumb.textContent = kindLabel + ' · ' + (_currentRoute.id || '?');
      }
      // 按 kind 渲染左 navigator
      if (_currentRoute.kind === 'module' && _currentRoute.id) {
        _moveModuleDrawerToSplitNav();
        // 复用 openModuleDrawer 的渲染 + 事件绑定(CSS 在 split-mode override modal 样式)
        try { openModuleDrawer(_currentRoute.id); } catch (e) { console.error(e); }
        // 0.14.4 · Refine 按钮已干掉 · build 自动写 docs/refine/<module>.md · 见 CHANGELOG
        // 0.11.3 · 加「同步 source」按钮 · 主动清 module subtask override
        try { _injectResetOverridesButton(_currentRoute.id); } catch (e) {}
      } else if (_currentRoute.kind === 'sysdoc' && _currentRoute.id) {
        // sysdoc / concept · §4.d 接 · 暂时显占位
        _moveModuleDrawerBackToBody();
        renderSplitNavPlaceholder(_currentRoute);
      } else if (_currentRoute.kind === 'concept' && _currentRoute.id) {
        _moveModuleDrawerBackToBody();
        renderSplitNavPlaceholder(_currentRoute);
      }
    }
  }

  function renderSplitNavPlaceholder(route) {
    // sysdoc · §4.d 接 sysdoc split-view 渲染
    if (route.kind === 'sysdoc' && route.id) {
      _renderSysdocSplitNav(route.id);
      return;
    }
    // concept / 兜底
    const slot = document.getElementById('split-nav-slot');
    if (!slot) return;
    slot.innerHTML =
      '<div style="padding:24px;">' +
      '<div style="font-family:var(--f-display); font-size:18px; color:var(--c-ink); margin-bottom:8px;">' +
      escapeHtml(route.kind + ' · ' + (route.id || '?')) +
      '</div>' +
      '<div style="font-family:var(--f-mono); font-size:11px; color:var(--c-graphite);">' +
      'Concept split-view · alpha.7 follow-up' +
      '</div>' +
      '</div>';
  }

  // 0.11.0-alpha.6 §4.d · 右 preview 渲染 + linked docs 切换
  function _markdownToHtml(content) {
    if (!content) return '';
    try {
      return (typeof marked !== 'undefined' && marked.parse)
        ? marked.parse(content)
        : '<pre>' + escapeHtml(content) + '</pre>';
    } catch (e) {
      return '<pre>' + escapeHtml(content) + '</pre>';
    }
  }

  function renderSplitPreviewDoc(d, sourceBtn) {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    const exists = (d.exists !== false);
    const hasContent = !!(d.content && d.content.length);
    let bodyHtml;
    if (!exists) {
      bodyHtml = '<div class="doc-preview-missing">' +
        '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_missing_title')) + '</div>' +
        '<div>' + escapeHtml(t('drawer.docs_missing_hint')) + '</div>' +
        '<div class="pv-missing-path">' + escapeHtml(d.path || '') + '</div>' +
      '</div>';
    } else if (hasContent) {
      bodyHtml = '<div class="doc-preview-body">' + _markdownToHtml(d.content) + '</div>';
    } else {
      // 非 .md / 文件过大 · 提示外部打开
      const url = d.resolved
        ? 'file:///' + d.resolved.replace(/\\/g, '/').replace(/^\/+/, '')
        : (d.path || '');
      bodyHtml =
        '<div class="doc-preview-missing">' +
          '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_open_external')) + '</div>' +
          '<div class="pv-missing-path">' + escapeHtml(url) + '</div>' +
        '</div>';
    }
    slot.innerHTML =
      '<div class="split-preview-head">' +
        '<div class="pv-title">' + escapeHtml(d.title || d.path || '') + '</div>' +
        (d.path ? '<div class="pv-path">' + escapeHtml(d.path) + '</div>' : '') +
        (d.mtime ? '<div class="pv-mtime">' + escapeHtml(d.mtime) + '</div>' : '') +
      '</div>' +
      bodyHtml;
    // 高亮当前 active doc-row(左 navigator)
    const allRows = document.querySelectorAll('#split-nav-slot .doc-list .doc-row');
    allRows.forEach(r => r.classList.remove('active'));
    if (sourceBtn && sourceBtn.classList) sourceBtn.classList.add('active');
    // 滚到顶
    slot.scrollTop = 0;
  }

  function renderSplitPreviewEmpty() {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    slot.innerHTML =
      '<div class="split-preview-placeholder">' +
        'No linked docs for this module · add `docs:` in frontmatter or `## Related` section in body.' +
      '</div>';
  }

  // 0.11.0-alpha.8 · 右栏渲染 code preview · 支持 focusIdx 单条聚焦(没传就渲染全部)
  function renderSplitPreviewCode(subtask, focusIdx, sourceBtn) {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    const all = subtask.code_anchors || [];
    if (!all.length) return;
    const anchors = (typeof focusIdx === 'number' && all[focusIdx]) ? [all[focusIdx]] : all;
    let bodyHtml = '';
    for (const ca of anchors) {
      const hasPreview = !!(ca.preview && ca.preview.length);
      const vscodeBtn = ca.vscode_url
        ? '<a class="code-anchor-vscode" href="' + escapeHtml(ca.vscode_url) + '" title="Open in VS Code">↗ VS Code</a>'
        : '';
      bodyHtml += '<div class="code-anchor-block">' +
        '<div class="code-anchor-head">' +
          '<span class="ca-path">' + escapeHtml(ca.path || '') + (ca.lines ? ':' + escapeHtml(ca.lines) : '') + '</span>' +
          vscodeBtn +
        '</div>' +
        (ca.warning ? '<div class="code-anchor-warn">⚠ ' + escapeHtml(ca.warning) + '</div>' : '') +
        (hasPreview ? '<pre class="code-anchor-preview"><code>' + escapeHtml(ca.preview) + '</code></pre>' : '') +
      '</div>';
    }
    const focusLabel = (anchors.length === 1 && all.length > 1)
      ? ' · anchor ' + (focusIdx + 1) + '/' + all.length
      : '';
    slot.innerHTML =
      '<div class="split-preview-head">' +
        '<div class="pv-title">Code anchor · ' + escapeHtml(subtask.title || '') + escapeHtml(focusLabel) + '</div>' +
        '<div class="pv-path">' + escapeHtml(subtask.id || '') + '</div>' +
      '</div>' +
      bodyHtml;
    slot.scrollTop = 0;
    // 高亮 active code-btn(只这一颗)· 清掉其它 code-btn / doc-btn 的 active
    document.querySelectorAll('#split-nav-slot .st-code-btn, #split-nav-slot .st-doc-btn').forEach(b => b.classList.remove('active'));
    if (sourceBtn && sourceBtn.classList) sourceBtn.classList.add('active');
  }

  // 0.11.0-alpha.8 · 右栏渲染 subtask 级 doc anchor · backend 已切好片 · 直接 marked
  function renderSplitPreviewSubtaskDoc(da, subtask, sourceBtn) {
    const slot = document.getElementById('split-preview-slot');
    if (!slot) return;
    const anchorLabel = da.path + (da.lines ? ':' + da.lines : (da.heading ? '#' + da.heading : ''));
    const hasContent = !!(da.content && da.content.length);
    const vscodeUrl = (da.resolved
      ? 'vscode://file/' + da.resolved.replace(/\\/g, '/') + (da.lines ? ':' + (parseInt(da.lines.split('-')[0], 10) || 1) : '')
      : '');
    const vscodeBtn = vscodeUrl
      ? '<a class="code-anchor-vscode" href="' + escapeHtml(vscodeUrl) + '" title="Open in VS Code">↗ VS Code</a>'
      : '';
    // 0.14.3 M14-f53acd · slice info badge · 让用户清楚知道这是 N 行 / 章节切片 · 不是全文
    let sliceInfo = '';
    if (hasContent && da.exists) {
      const lineCount = (da.content.match(/\n/g) || []).length + 1;
      if (da.lines) {
        sliceInfo = '<span class="pv-slice-badge">📍 ' + escapeHtml('Showing lines ' + da.lines + ' of ' + (da.path || 'file') + ' · ' + lineCount + ' lines') + '</span>';
      } else if (da.heading) {
        sliceInfo = '<span class="pv-slice-badge">📍 ' + escapeHtml('Section ' + da.heading + ' of ' + (da.path || 'file') + ' · ' + lineCount + ' lines') + '</span>';
      } else {
        sliceInfo = '<span class="pv-slice-badge">📄 ' + escapeHtml('Full document · ' + lineCount + ' lines') + '</span>';
      }
    }
    let bodyHtml;
    if (!da.exists) {
      bodyHtml = '<div class="doc-preview-missing">' +
        '<div class="pv-missing-title">Doc anchor not found</div>' +
        '<div class="pv-missing-path">' + escapeHtml(anchorLabel) + '</div>' +
        (da.warning ? '<div class="pv-missing-path" style="margin-top:6px">⚠ ' + escapeHtml(da.warning) + '</div>' : '') +
      '</div>';
    } else if (hasContent) {
      const warnBlock = da.warning ? '<div class="code-anchor-warn">⚠ ' + escapeHtml(da.warning) + '</div>' : '';
      bodyHtml = warnBlock + '<div class="doc-preview-body">' + _markdownToHtml(da.content) + '</div>';
    } else {
      const url = da.resolved ? 'file:///' + da.resolved.replace(/\\/g, '/').replace(/^\/+/, '') : (da.path || '');
      bodyHtml = '<div class="doc-preview-missing">' +
        '<div class="pv-missing-title">' + escapeHtml(t('drawer.docs_open_external') || 'Open externally') + '</div>' +
        '<div class="pv-missing-path">' + escapeHtml(url) + '</div>' +
      '</div>';
    }
    const titleStr = (da.title && da.heading) ? da.title : (subtask && subtask.title) || '';
    slot.innerHTML =
      '<div class="split-preview-head">' +
        '<div class="pv-title">Doc anchor · ' + escapeHtml(titleStr) + '</div>' +
        '<div class="pv-path">' + escapeHtml(anchorLabel) + (vscodeBtn ? ' ' : '') + vscodeBtn + '</div>' +
        sliceInfo +
        (da.mtime ? '<div class="pv-mtime">' + escapeHtml(da.mtime) + '</div>' : '') +
      '</div>' +
      bodyHtml;
    slot.scrollTop = 0;
    document.querySelectorAll('#split-nav-slot .st-code-btn, #split-nav-slot .st-doc-btn').forEach(b => b.classList.remove('active'));
    if (sourceBtn && sourceBtn.classList) sourceBtn.classList.add('active');
  }

  // 0.11.0-alpha.6 §4.e · Copy prompt for subtask · alpha.3 prompts.js sidecar 接入
  function copySubtaskPrompt(subtaskId) {
    const prompt = (window.__PROMPTS__ || {})[subtaskId];
    if (!prompt) {
      toast(t('toast.prompt_missing') || 'Prompt not available · run docs-cockpit build to refresh');
      return;
    }
    // 0.10.1 clipboard fallback(file:// 兼容)
    (async () => {
      try {
        await navigator.clipboard.writeText(prompt);
        toast(t('toast.prompt_copied') || 'Prompt copied · paste to Claude / Codex');
        return;
      } catch (e) {}
      // execCommand fallback
      try {
        const ta = document.createElement('textarea');
        ta.value = prompt;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        toast(ok ? (t('toast.prompt_copied') || 'Prompt copied') : 'Copy failed · prompt preview: ' + prompt.slice(0, 200) + '…');
      } catch (e) {
        toast('Copy failed · ' + e.message);
      }
    })();
  }

  // 0.11.0-alpha.6 §4.d · sysdoc split-view · 左 navigator 是 systemDocs list ·
  // 右 preview 渲染 active 那条 doc body
  function _renderSysdocSplitNav(activeId) {
    const slot = document.getElementById('split-nav-slot');
    if (!slot) return;
    const list = RAW.systemDocs || [];
    const rowsHtml = list.map(d => {
      const isActive = (d.id === activeId);
      const iconSvg = iconForDoc(d.icon || 'doc');
      return '<button type="button" class="sysdoc-row sysdoc-nav-row' + (isActive ? ' active' : '') + '" data-sysdoc-id="' + escapeHtml(d.id) + '">' +
        '<span class="sd-icon">' + iconSvg + '</span>' +
        '<div class="sd-info">' +
          '<div class="sd-title">' + escapeHtml(d.title) + '</div>' +
          '<div class="sd-desc">' + escapeHtml(d.desc || '') + '</div>' +
        '</div>' +
      '</button>';
    }).join('');
    slot.innerHTML =
      '<div class="drawer-head" style="position:sticky;top:0;background:var(--c-bg);z-index:2;border-bottom:1px solid var(--c-hairline);padding:14px 20px;">' +
        '<div>' +
          '<div class="h-meta" style="font-family:var(--f-mono);font-size:11px;color:var(--c-graphite);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px;">' + escapeHtml(t('sysdocs.eyebrow')) + '</div>' +
          '<h2 style="margin:0;font-size:18px;font-weight:600;color:var(--c-ink);">' + escapeHtml(t('sysdocs.title')) + '</h2>' +
        '</div>' +
      '</div>' +
      '<div class="drawer-body" style="padding:16px;">' +
        '<div class="sysdoc-list">' + rowsHtml + '</div>' +
      '</div>';
    // 绑 click · 切 sysdoc(同 split-view 内导航)
    slot.querySelectorAll('.sysdoc-row').forEach(btn => {
      btn.addEventListener('click', () => {
        const newId = btn.dataset.sysdocId;
        if (newId === activeId) return;
        window.location.hash = '#/sysdoc/' + encodeURIComponent(newId);
      });
    });
    // 渲染右 preview · 当前 active sysdoc 的 content
    const active = list.find(d => d.id === activeId);
    if (active) {
      renderSplitPreviewDoc(active, null);
    } else {
      renderSplitPreviewEmpty();
    }
  }

  function navigateTo(kind, id) {
    // _UI_MODE === 'modal' 时退回老 modal flow(向后兼容)
    if (_UI_MODE === 'modal') {
      if (kind === 'module') openModuleDrawer(id);
      else if (kind === 'sysdoc') {
        // sysdoc 老 modal 行为:新窗口打开 · 不变
        const doc = (RAW.systemDocs || []).find(d => d.id === id);
        if (doc && doc.path) window.open(doc.path, '_blank');
      }
      return;
    }
    const newHash = '#/' + kind + '/' + encodeURIComponent(id);
    if (window.location.hash !== newHash) {
      window.location.hash = newHash;
    } else {
      // 同 hash · 强制 re-render
      applyRoute();
    }
  }

  function backToDashboard() {
    if (window.location.hash) {
      // 走 history · 浏览器 back 键 work
      window.location.hash = '';
    } else {
      applyRoute();
    }
  }

  // ── 初始化 ────────────────────────────────────────
  function init() {
    applyI18nStatic();
    renderProjectMeta();
    renderSystemDocs();
    renderAll();

    // Lang toggle handler
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => {
        LANG = btn.dataset.lang;
        try { localStorage.setItem(STORAGE_KEY + '::lang', LANG); } catch (e) {}
        applyI18nStatic();
        renderProjectMeta();
        renderSystemDocs();
        renderAll();
        // If module drawer is open · re-render it too
        if (_activeModuleId) openModuleDrawer(_activeModuleId);
      });
    });

    document.getElementById('open-docs').addEventListener('click', () => openDrawer('docs-drawer'));

    // 0.14 M15 · Backlog 入口 · 跳 #/backlog hash route
    const _backlogBtn = document.getElementById('open-backlog');
    if (_backlogBtn) {
      _backlogBtn.addEventListener('click', () => {
        window.location.hash = '#/backlog';
      });
    }
    // 0.14 M15 + M16 · bind backlog filter controls + bundle bar buttons + load selection state
    try { _bundleSelection = _loadBundleSelection(); } catch (e) {}
    try { _bindBacklogFilters(); } catch (e) { console.error(e); }
    try { _bindBundleBar(); } catch (e) { console.error(e); }

    // 0.12 M09 · Export overrides button · download localStorage JSON · 给 docs-cockpit sync-status --import 用
    const _exportBtn = document.getElementById('export-overrides');
    if (_exportBtn) {
      _exportBtn.addEventListener('click', () => {
        const stored = (() => {
          try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
          catch (e) { return {}; }
        })();
        // 加 _exported_at 元数据 · 让 sync-status 知道 export 时间
        stored._exported_at = new Date().toISOString();
        const blob = new Blob([JSON.stringify(stored, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const projectName = (RAW.project && RAW.project.name) || 'docs-cockpit';
        const stamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
        a.href = url;
        a.download = `${projectName}-overrides-${stamp}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        toast(t('toast.export_done') || 'Overrides exported · run: docs-cockpit sync-status --import <file>');
      });
    }
    document.getElementById('md-close').addEventListener('click', closeDrawer);
    document.getElementById('dd-close').addEventListener('click', closeDrawer);
    document.getElementById('scrim').addEventListener('click', closeDrawer);

    // 0.11.0-alpha.6 §4.b · Back 按钮 + hashchange + Esc 处理 split-view
    const backBtn = document.getElementById('back-btn');
    if (backBtn) backBtn.addEventListener('click', backToDashboard);
    window.addEventListener('hashchange', applyRoute);
    // initial apply · 处理打开页面时 URL 已带 hash 的场景
    applyRoute();

    document.addEventListener('keydown', e => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (document.activeElement && document.activeElement.tagName) || '';
      const inField = tag === 'INPUT' || tag === 'TEXTAREA';
      if (e.key === 'Escape') {
        // 0.11.0-alpha.6 §4.b · Esc 优先关 modal(若开)· 否则返回 dashboard
        const anyDrawerOpen = document.querySelector('.drawer.open');
        if (anyDrawerOpen) { closeDrawer(); return; }
        if (_currentRoute.kind !== 'dashboard') { backToDashboard(); return; }
        return;
      }
      if (inField) return;
      if (e.key === 'd' || e.key === 'D') {
        const docsOpen = document.getElementById('docs-drawer').classList.contains('open');
        if (docsOpen) closeDrawer(); else openDrawer('docs-drawer');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
