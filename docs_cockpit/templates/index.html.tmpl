<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>项目看板 · 模板</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github.min.css" />
<style>
/* ───── design tokens ───────────────────────────── */
:root {
  --c-primary:        #024ad8;
  --c-primary-bright: #296ef9;
  --c-primary-deep:   #0e3191;
  --c-primary-soft:   #eaf1fe;

  --c-canvas:    #ffffff;
  --c-paper:     #ffffff;
  --c-tint:      #fafafa;
  --c-cloud:     #f4f4f5;
  --c-fog:       #ebebec;
  --c-hairline:  #e6e6e8;
  --c-steel:     #c5c5c8;
  --c-graphite:  #6b6b71;
  --c-charcoal:  #2f2f33;
  --c-ink:       #18181b;
  --c-ink-deep:  #0a0a0d;
  --c-on-ink:    #ffffff;

  --s-done:      #059669;
  --s-progress:  #024ad8;
  --s-planned:   #6366f1;
  --s-blocked:   #dc2626;
  --s-todo:      #a1a1a8;
  --s-deferred:  #d97706;

  --r-xs: 2px; --r-sm: 4px; --r-md: 6px; --r-lg: 10px; --r-xl: 16px; --r-pill: 9999px;

  --shadow-sm: 0 1px 2px rgba(15, 17, 23, 0.04), 0 1px 1px rgba(15, 17, 23, 0.06);
  --shadow-md: 0 2px 4px rgba(15, 17, 23, 0.04), 0 8px 16px rgba(15, 17, 23, 0.06);
  --shadow-lg: 0 12px 32px rgba(15, 17, 23, 0.14), 0 4px 8px rgba(15, 17, 23, 0.06);

  --f-display: 'Inter', ui-sans-serif, system-ui, sans-serif;
  --f-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: var(--f-display);
  color: var(--c-ink);
  background: var(--c-canvas);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
button { font: inherit; color: inherit; }
a { color: var(--c-primary); text-decoration: none; }
a:hover { text-decoration: underline; }
:focus-visible {
  outline: 2px solid var(--c-primary);
  outline-offset: 2px;
  border-radius: 3px;
}

/* ───── top bar ──────────────────────────────────── */
.topbar {
  position: sticky; top: 0; z-index: 30;
  background: rgba(255,255,255,0.92);
  backdrop-filter: saturate(140%) blur(8px);
  border-bottom: 1px solid var(--c-hairline);
  padding: 0 28px;
  height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 24px;
}
.brand {
  display: flex; align-items: center; gap: 11px;
  font-weight: 600; font-size: 14px;
  letter-spacing: -0.005em;
  color: var(--c-ink);
}
.brand .mark {
  width: 26px; height: 26px;
  background: var(--c-ink);
  border-radius: 6px;
  display: grid; place-items: center;
  color: var(--c-on-ink);
  font-family: var(--f-mono); font-weight: 600;
  font-size: 13px;
}
.brand .crumb {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding-left: 12px;
  margin-left: 2px;
  border-left: 1px solid var(--c-hairline);
  white-space: nowrap;
}
@media (max-width: 720px) {
  .brand .crumb { display: none; }
  .docs-btn span:not(.docs-count):not(.docs-icon) { display: none; }
  .build-stamp span:not(.dot) { display: none; }
}
.topbar-right { display: flex; align-items: center; gap: 12px; }

/* ─ Language toggle ─ */
.lang-toggle {
  display: inline-flex;
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
  font-family: var(--f-mono);
  font-size: 11px;
  flex-shrink: 0;
}
.lang-toggle button {
  padding: 4px 9px;
  color: var(--c-graphite);
  border: 0;
  background: none;
  cursor: pointer;
  font: inherit;
}
.lang-toggle button.active {
  background: var(--c-ink);
  color: var(--c-on-ink);
}
.lang-toggle button:hover:not(.active) {
  background: var(--c-fog);
  color: var(--c-ink);
}
.build-stamp {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  letter-spacing: 0.02em;
  display: flex; align-items: center; gap: 8px;
  white-space: nowrap;
  flex-shrink: 0;
}
.build-stamp .dot {
  width: 6px; height: 6px;
  background: var(--s-done);
  border-radius: 50%;
  box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.12);
}
.docs-btn {
  display: inline-flex; align-items: center; gap: 8px;
  height: 32px;
  padding: 0 12px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  cursor: pointer;
  font-size: 12.5px; font-weight: 500;
  color: var(--c-charcoal);
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.docs-btn:hover {
  background: var(--c-tint);
  border-color: var(--c-steel);
  color: var(--c-ink);
}
.docs-btn .docs-icon {
  width: 14px; height: 14px;
  color: var(--c-graphite);
}
.docs-btn .docs-count {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  background: var(--c-cloud);
  color: var(--c-graphite);
  padding: 1px 6px;
  border-radius: var(--r-pill);
  letter-spacing: 0.02em;
}

/* ───── main shell ──────────────────────────────── */
.shell {
  max-width: 1440px;
  margin: 0 auto;
  padding: 36px 28px 96px;
}

/* ───── hero ────────────────────────────────────── */
.hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 48px;
  align-items: end;
  padding: 8px 0 36px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--c-hairline);
}
.hero .eyebrow {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 14px;
}
.hero h1 {
  margin: 0 0 8px;
  font-size: 40px; font-weight: 500;
  line-height: 1.05;
  letter-spacing: -0.022em;
  color: var(--c-ink);
}
.hero p.tagline {
  margin: 0;
  max-width: 560px;
  font-size: 15px;
  color: var(--c-graphite);
  line-height: 1.55;
}
.hero .gauge {
  text-align: right;
  padding-right: 4px;
}
.hero .gauge .num {
  font-family: var(--f-display);
  font-size: 64px; font-weight: 500;
  line-height: 0.95;
  color: var(--c-primary);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.035em;
}
.hero .gauge .label {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-top: 10px;
}
.hero .gauge .track {
  margin-top: 12px;
  width: 200px;
  height: 3px;
  background: var(--c-fog);
  border-radius: 0;
  margin-left: auto;
}
.hero .gauge .fill {
  height: 100%;
  background: var(--c-primary);
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ───── section heading ─────────────────────────── */
.section { margin-bottom: 44px; }
.section-head {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--c-hairline);
}
.section-head .title {
  font-family: var(--f-display);
  font-size: 11px; font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--c-ink);
}
.section-head .meta {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
}

/* ───── kpi strip ───────────────────────────────── */
.kpi-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--c-paper);
}
.kpi-cell {
  padding: 22px 24px 20px;
  border-left: 1px solid var(--c-hairline);
  position: relative;
}
.kpi-cell:first-child { border-left: none; }
.kpi-cell::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c-ink);
}
.kpi-cell.t-done::before     { background: var(--s-done); }
.kpi-cell.t-progress::before { background: var(--s-progress); }
.kpi-cell.t-todo::before     { background: var(--s-todo); }
.kpi-cell .k-label {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12px;
}
.kpi-cell .k-num {
  font-size: 36px;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.022em;
  line-height: 1;
  color: var(--c-ink);
}
.kpi-cell.t-done .k-num     { color: var(--s-done); }
.kpi-cell.t-progress .k-num { color: var(--s-progress); }
.kpi-cell .k-sub {
  margin-top: 10px;
  font-size: 11.5px;
  color: var(--c-graphite);
}
@media (max-width: 900px) {
  .kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .kpi-cell { border-left: none; border-top: 1px solid var(--c-hairline); }
  .kpi-cell:nth-child(2) { border-left: 1px solid var(--c-hairline); }
  .kpi-cell:nth-child(-n+2) { border-top: none; }
}

/* ───── kanban ──────────────────────────────────── */
.kanban {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14px;
  align-items: start;
}
@media (max-width: 1240px) { .kanban { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 760px)  { .kanban { grid-template-columns: 1fr; } }
.k-col {
  min-height: 80px;
}
.k-col-head {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 8px;
  margin-bottom: 10px;
  border-bottom: 1px solid;
  font-family: var(--f-mono);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.k-col-head .name {
  display: inline-flex; align-items: center; gap: 7px;
  font-weight: 600;
  color: var(--c-ink);
}
.k-col-head .count {
  font-weight: 500;
  color: var(--c-graphite);
  font-size: 10.5px;
}
.k-col-head .glyph {
  width: 8px; height: 8px;
  border-radius: 50%;
  display: inline-block;
}
.k-col.s-not-started .k-col-head { border-color: var(--s-todo); }
.k-col.s-not-started .k-col-head .glyph { background: transparent; border: 1.5px solid var(--s-todo); }
.k-col.s-planned     .k-col-head { border-color: var(--s-planned); }
.k-col.s-planned     .k-col-head .glyph { background: var(--s-planned); opacity: 0.55; }
.k-col.s-in-progress .k-col-head { border-color: var(--s-progress); }
.k-col.s-in-progress .k-col-head .glyph { background: var(--s-progress); }
.k-col.s-blocked     .k-col-head { border-color: var(--s-blocked); }
.k-col.s-blocked     .k-col-head .glyph { background: var(--s-blocked); }
.k-col.s-done        .k-col-head { border-color: var(--s-done); }
.k-col.s-done        .k-col-head .glyph { background: var(--s-done); }

/* card */
.m-card {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-left: 3px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 12px 14px 13px;
  margin-bottom: 8px;
  cursor: pointer;
  transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  position: relative;
}
.m-card:hover {
  transform: translateY(-1px);
  border-color: var(--c-steel);
  box-shadow: var(--shadow-md);
}
.k-col.s-not-started .m-card { border-left-color: #d1d1d4; }
.k-col.s-planned     .m-card { border-left-color: #a5b4fc; }
.k-col.s-in-progress .m-card { border-left-color: var(--s-progress); }
.k-col.s-blocked     .m-card { border-left-color: #fca5a5; }
.k-col.s-done        .m-card { border-left-color: #6ee7b7; }

.m-card .m-id {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--c-graphite);
  display: flex; justify-content: space-between; align-items: center;
}
.m-card .m-id .doc-pill {
  font-size: 9.5px;
  font-weight: 500;
  color: var(--c-graphite);
  display: inline-flex; align-items: center; gap: 3px;
  letter-spacing: 0;
}
.m-card .m-id .doc-pill svg { width: 10px; height: 10px; }
.m-card .m-title {
  font-size: 13px; font-weight: 500;
  margin-top: 5px; margin-bottom: 11px;
  color: var(--c-ink);
  line-height: 1.36;
}
.m-card .m-meta {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 7px;
}
.m-card .m-sprint {
  font-family: var(--f-mono);
  font-size: 9.5px; font-weight: 500;
  letter-spacing: 0.02em;
  background: var(--c-cloud);
  color: var(--c-charcoal);
  padding: 2px 7px;
  border-radius: var(--r-xs);
}
.m-card .m-pct {
  font-family: var(--f-mono);
  font-size: 11px; font-weight: 600;
  color: var(--c-ink);
  font-variant-numeric: tabular-nums;
}
.k-col.s-done .m-card .m-pct { color: var(--s-done); }
.k-col.s-in-progress .m-card .m-pct { color: var(--s-progress); }
.bar {
  height: 3px;
  background: var(--c-fog);
  overflow: hidden;
}
.bar > .bar-fill {
  height: 100%;
  background: var(--c-ink);
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.k-col.s-done .bar-fill        { background: var(--s-done); }
.k-col.s-in-progress .bar-fill { background: var(--s-progress); }
.k-col.s-blocked .bar-fill     { background: var(--s-blocked); }
.k-col.s-planned .bar-fill     { background: var(--s-planned); }
.k-col-empty {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-steel);
  padding: 16px 4px;
  text-align: center;
  letter-spacing: 0.04em;
}

/* ───── sprint rows ────────────────────────────── */
.sprint-row {
  display: grid;
  grid-template-columns: 140px 1fr 72px 80px;
  gap: 20px;
  padding: 13px 0;
  border-bottom: 1px solid var(--c-hairline);
  align-items: center;
}
.sprint-row:last-child { border-bottom: none; }
.sprint-row .s-name {
  font-family: var(--f-mono);
  font-size: 12px; font-weight: 600;
  color: var(--c-ink);
  display: flex; align-items: center; gap: 9px;
}
.sprint-row .s-dot {
  width: 8px; height: 8px;
  background: var(--c-steel);
  transform: rotate(45deg);
}
.sprint-row.s-done .s-dot   { background: var(--s-done); }
.sprint-row.s-active .s-dot { background: var(--s-progress); }
.sprint-row .s-bar { height: 4px; background: var(--c-fog); }
.sprint-row .s-bar > .s-bar-fill {
  height: 100%;
  background: var(--c-primary);
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}
.sprint-row.s-done .s-bar-fill { background: var(--s-done); }
.sprint-row .s-pct {
  font-family: var(--f-mono);
  font-size: 12px; font-weight: 600;
  color: var(--c-ink);
  text-align: right;
  font-variant-numeric: tabular-nums;
}
.sprint-row.s-done   .s-pct { color: var(--s-done); }
.sprint-row.s-active .s-pct { color: var(--s-progress); }
.sprint-row .s-count {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  text-align: right;
}

/* ───── concept grid ───────────────────────────── */
.concept-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
}
.c-chip {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
}
.c-chip:hover {
  transform: translateY(-1px);
  border-color: var(--c-steel);
  box-shadow: var(--shadow-md);
}
.c-chip .c-id {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--c-graphite);
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 6px;
}
.c-chip .c-sprint {
  font-family: var(--f-mono);
  font-size: 9.5px;
  background: var(--c-cloud);
  color: var(--c-charcoal);
  padding: 1px 6px; border-radius: var(--r-xs);
  letter-spacing: 0.02em;
}
.c-chip .c-title {
  font-size: 13px; font-weight: 500;
  margin-bottom: 10px;
  color: var(--c-ink);
  line-height: 1.36;
}
.c-chip .c-title .c-status-dot {
  display: inline-block;
  width: 7px; height: 7px;
  border-radius: 50%;
  margin-right: 7px;
  vertical-align: middle;
}
.c-status-dot.s-done       { background: var(--s-done); }
.c-status-dot.s-in-progress { background: var(--s-progress); }
.c-status-dot.s-planned    { background: var(--s-planned); }
.c-status-dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.c-status-dot.s-blocked    { background: var(--s-blocked); }
.c-status-dot.s-deferred   { background: var(--s-deferred); }
.c-chip .c-pct {
  font-family: var(--f-mono);
  font-size: 10.5px; font-weight: 600;
  color: var(--c-graphite);
  text-align: right;
  margin-top: 5px;
  font-variant-numeric: tabular-nums;
}

/* ───── drawer + scrim ──────────────────────────── */
.scrim {
  position: fixed; inset: 0;
  background: rgba(20, 22, 30, 0.4);
  opacity: 0;
  pointer-events: none;
  z-index: 80;
  transition: opacity 0.22s;
}
.scrim.open { opacity: 1; pointer-events: auto; }
.drawer {
  position: fixed; top: 0; right: 0; bottom: 0;
  width: min(540px, 100vw);
  background: var(--c-paper);
  z-index: 90;
  transform: translateX(100%);
  /* 0.7.2:width 也进 transition · 预览模式下平滑加宽 */
  transition: transform 0.28s cubic-bezier(0.32, 0.72, 0.24, 1),
              width 0.22s cubic-bezier(0.32, 0.72, 0.24, 1);
  display: flex; flex-direction: column;
  box-shadow: -16px 0 48px rgba(15, 17, 23, 0.16);
}
.drawer.open { transform: translateX(0); }
/* 0.7.2:doc 预览模式加宽 · 容下 markdown 表格 / 代码块 / 长行 */
.drawer.wide { width: min(960px, 96vw); }

.drawer-head {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 16px;
  padding: 20px 24px 16px;
  border-bottom: 1px solid var(--c-hairline);
}
.drawer-head .h-meta {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 6px;
  display: flex; align-items: center; gap: 10px;
}
.drawer-head .h-meta .dot {
  width: 7px; height: 7px; border-radius: 50%;
}
.drawer-head .h-meta .dot.s-done       { background: var(--s-done); }
.drawer-head .h-meta .dot.s-in-progress { background: var(--s-progress); }
.drawer-head .h-meta .dot.s-planned    { background: var(--s-planned); }
.drawer-head .h-meta .dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.drawer-head .h-meta .dot.s-blocked    { background: var(--s-blocked); }
.drawer-head .h-meta .dot.s-deferred   { background: var(--s-deferred); }
.drawer-head h2 {
  font-size: 20px; font-weight: 500;
  line-height: 1.25;
  letter-spacing: -0.015em;
  margin: 0;
  color: var(--c-ink);
}
.drawer-head .h-close {
  width: 32px; height: 32px;
  border-radius: var(--r-md);
  background: transparent;
  border: 1px solid transparent;
  cursor: pointer;
  display: grid; place-items: center;
  color: var(--c-graphite);
}
.drawer-head .h-close:hover {
  background: var(--c-cloud);
  color: var(--c-ink);
}
.drawer-head .h-close svg { width: 14px; height: 14px; }
.drawer-body {
  flex: 1; overflow-y: auto;
  padding: 24px;
}
.drawer-body .d-section {
  margin-bottom: 28px;
}
.drawer-body .d-section:last-child { margin-bottom: 0; }
.drawer-body .d-label {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 600;
  color: var(--c-graphite);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 10px;
  display: flex; justify-content: space-between; align-items: baseline;
}
.drawer-body .d-label .right { color: var(--c-charcoal); font-weight: 500; letter-spacing: 0.04em; }
.drawer-body .desc {
  font-size: 13.5px;
  color: var(--c-charcoal);
  line-height: 1.6;
  padding: 12px 14px;
  background: var(--c-tint);
  border-radius: var(--r-md);
  border: 1px solid var(--c-hairline);
}
.drawer-body .desc.empty {
  font-style: italic;
  color: var(--c-graphite);
}

/* docs list */
.doc-list {
  display: flex; flex-direction: column;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
}
.doc-list .doc-row {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px;
  border-bottom: 1px solid var(--c-hairline);
  text-decoration: none;
  color: var(--c-ink);
  transition: background 0.15s;
  font-size: 13px;
}
.doc-list .doc-row:last-child { border-bottom: none; }
.doc-list .doc-row:hover {
  background: var(--c-tint);
  text-decoration: none;
}
.doc-list .doc-row .doc-icon {
  width: 16px; height: 16px;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.doc-list .doc-row .doc-info { flex: 1; min-width: 0; }
.doc-list .doc-row .doc-title {
  font-weight: 500;
  color: var(--c-ink);
}
.doc-list .doc-row .doc-path {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  margin-top: 1px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-list .doc-row .doc-ext {
  font-family: var(--f-mono);
  font-size: 10px; font-weight: 500;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.doc-list-empty {
  padding: 18px 14px;
  border: 1px dashed var(--c-hairline);
  border-radius: var(--r-md);
  text-align: center;
  font-size: 12px;
  color: var(--c-graphite);
}
/* 0.7.1:doc-row 状态指示 */
.doc-list .doc-row.missing {
  background: repeating-linear-gradient(45deg, transparent 0 6px, rgba(220,38,38,0.04) 6px 8px);
}
.doc-list .doc-row.missing .doc-title::after {
  content: "404";
  font-family: var(--f-mono);
  font-size: 9.5px;
  background: rgba(220,38,38,0.12);
  color: #b91c1c;
  margin-left: 8px;
  padding: 1px 5px;
  border-radius: 3px;
  letter-spacing: 0.04em;
}
.doc-list .doc-row.has-content:hover {
  background: var(--c-primary-soft);
}
.doc-list .doc-row .doc-action {
  font-family: var(--f-mono);
  font-size: 9.5px;
  font-weight: 600;
  color: var(--c-primary);
  background: var(--c-primary-soft);
  padding: 2px 6px;
  border-radius: 3px;
  flex-shrink: 0;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.doc-list .doc-row.missing .doc-action {
  display: none;
}

/* 0.7.1:drawer 内联 MD 预览 ───────────────────────── */
.doc-preview-head {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 14px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--c-hairline);
}
.doc-preview-head .pv-back {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 6px 12px;
  cursor: pointer;
  font: 500 12px/1 var(--f-sans);
  color: var(--c-charcoal);
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}
.doc-preview-head .pv-back:hover {
  background: var(--c-tint);
  border-color: var(--c-steel);
  color: var(--c-ink);
}
.doc-preview-head .pv-back svg { width: 12px; height: 12px; }
.doc-preview-head .pv-meta {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 2px;
  text-align: right;
}
.doc-preview-head .pv-title {
  font-size: 13px; font-weight: 600;
  color: var(--c-ink);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-preview-head .pv-path {
  font-family: var(--f-mono);
  font-size: 10.5px;
  color: var(--c-graphite);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.doc-preview-head .pv-mtime {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
}
.doc-preview-body {
  font-size: 14px; line-height: 1.65;
  color: var(--c-ink);
}
.doc-preview-body h1, .doc-preview-body h2, .doc-preview-body h3,
.doc-preview-body h4, .doc-preview-body h5, .doc-preview-body h6 {
  font-weight: 600;
  margin: 1.4em 0 0.5em;
  line-height: 1.3;
}
.doc-preview-body h1 { font-size: 22px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 0.3em; }
.doc-preview-body h2 { font-size: 18px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 0.25em; }
.doc-preview-body h3 { font-size: 16px; }
.doc-preview-body h4 { font-size: 14.5px; }
.doc-preview-body h5, .doc-preview-body h6 { font-size: 13.5px; color: var(--c-charcoal); }
.doc-preview-body p { margin: 0.75em 0; }
.doc-preview-body ul, .doc-preview-body ol { margin: 0.6em 0; padding-left: 1.6em; }
.doc-preview-body li { margin: 0.25em 0; }
.doc-preview-body li > ul, .doc-preview-body li > ol { margin: 0.25em 0; }
.doc-preview-body code {
  font-family: var(--f-mono);
  font-size: 0.88em;
  background: var(--c-cloud);
  padding: 1px 5px;
  border-radius: 3px;
}
.doc-preview-body pre {
  background: var(--c-tint);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 12px 14px;
  overflow-x: auto;
  margin: 0.8em 0;
  font-size: 12.5px;
  line-height: 1.55;
}
.doc-preview-body pre code {
  background: transparent;
  padding: 0;
  border-radius: 0;
  font-size: 1em;
}
.doc-preview-body blockquote {
  margin: 0.8em 0;
  padding: 4px 14px;
  border-left: 3px solid var(--c-primary);
  background: var(--c-primary-soft);
  color: var(--c-charcoal);
  border-radius: 0 var(--r-md) var(--r-md) 0;
}
.doc-preview-body blockquote p:first-child { margin-top: 0; }
.doc-preview-body blockquote p:last-child { margin-bottom: 0; }
.doc-preview-body table {
  border-collapse: collapse;
  margin: 0.9em 0;
  font-size: 12.5px;
  width: 100%;
}
.doc-preview-body th, .doc-preview-body td {
  border: 1px solid var(--c-hairline);
  padding: 7px 10px;
  text-align: left;
}
.doc-preview-body th {
  background: var(--c-tint);
  font-weight: 600;
}
.doc-preview-body a {
  color: var(--c-primary);
  text-decoration: none;
}
.doc-preview-body a:hover { text-decoration: underline; }
.doc-preview-body hr {
  border: none;
  border-top: 1px solid var(--c-hairline);
  margin: 1.6em 0;
}
.doc-preview-body img {
  max-width: 100%;
  border-radius: var(--r-md);
}
.doc-preview-body input[type="checkbox"] {
  margin-right: 6px;
  vertical-align: middle;
}
.doc-preview-missing {
  padding: 28px 18px;
  border: 1px dashed #fecaca;
  background: rgba(220,38,38,0.04);
  border-radius: var(--r-md);
  text-align: center;
  color: #b91c1c;
  font-size: 13px;
}
.doc-preview-missing .pv-missing-title {
  font-weight: 600;
  margin-bottom: 8px;
}
.doc-preview-missing .pv-missing-path {
  font-family: var(--f-mono);
  font-size: 11px;
  color: var(--c-graphite);
  word-break: break-all;
}

/* status select */
.status-select {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
}
.status-select button {
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 9px 4px 8px;
  cursor: pointer;
  text-align: center;
  font-size: 11px; font-weight: 500;
  color: var(--c-charcoal);
  transition: background 0.15s, border-color 0.15s, color 0.15s;
  display: flex; flex-direction: column; align-items: center; gap: 5px;
}
.status-select button:hover {
  border-color: var(--c-steel);
  background: var(--c-tint);
}
.status-select button .ss-dot {
  width: 9px; height: 9px;
  border-radius: 50%;
}
.status-select button.active {
  border-color: var(--c-ink);
  color: var(--c-ink);
  background: var(--c-paper);
  box-shadow: 0 0 0 2px var(--c-ink) inset;
  border-color: transparent;
}
.status-select .ss-dot.s-not-started { background: transparent; border: 1.5px solid var(--s-todo); }
.status-select .ss-dot.s-planned     { background: var(--s-planned); opacity: 0.7; }
.status-select .ss-dot.s-in-progress { background: var(--s-progress); }
.status-select .ss-dot.s-blocked     { background: var(--s-blocked); }
.status-select .ss-dot.s-done        { background: var(--s-done); }

/* progress control */
.progress-control {
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  padding: 16px;
  background: var(--c-tint);
}
.progress-control .pc-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 12px;
}
.progress-control .pc-num {
  font-family: var(--f-display);
  font-size: 28px; font-weight: 500;
  font-variant-numeric: tabular-nums;
  color: var(--c-ink);
  line-height: 1;
  letter-spacing: -0.02em;
}
.progress-control .pc-mode {
  display: flex; align-items: center; gap: 8px;
  font-size: 11.5px;
  color: var(--c-graphite);
}
.progress-control input[type="range"] {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  height: 6px;
  background: var(--c-fog);
  border-radius: 99px;
  outline: none;
  cursor: pointer;
}
.progress-control input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--c-primary);
  border: 3px solid var(--c-paper);
  box-shadow: 0 0 0 1px var(--c-primary);
  cursor: pointer;
  transition: transform 0.1s;
}
.progress-control input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.1); }
.progress-control input[type="range"]::-moz-range-thumb {
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--c-primary);
  border: 3px solid var(--c-paper);
  box-shadow: 0 0 0 1px var(--c-primary);
  cursor: pointer;
}
.progress-control input[type="range"]:disabled { opacity: 0.5; cursor: not-allowed; }
.progress-control .pc-ticks {
  display: flex; justify-content: space-between;
  margin-top: 8px;
  font-family: var(--f-mono);
  font-size: 9.5px;
  color: var(--c-graphite);
}
.progress-control .pc-steps {
  display: flex; gap: 4px;
  margin-top: 10px;
}
.progress-control .pc-steps button {
  flex: 1;
  height: 26px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-sm);
  font-family: var(--f-mono);
  font-size: 11px; font-weight: 500;
  color: var(--c-charcoal);
  cursor: pointer;
  transition: background 0.12s, border-color 0.12s;
}
.progress-control .pc-steps button:hover {
  border-color: var(--c-steel);
  background: var(--c-tint);
}

/* toggle (sync mode) */
.toggle-row {
  display: flex; align-items: center; gap: 10px;
  font-size: 12px;
  color: var(--c-charcoal);
  cursor: pointer;
  user-select: none;
}
.toggle-row .toggle {
  width: 30px; height: 18px;
  background: var(--c-fog);
  border-radius: 9999px;
  position: relative;
  transition: background 0.18s;
  flex-shrink: 0;
}
.toggle-row .toggle::after {
  content: "";
  position: absolute;
  top: 2px; left: 2px;
  width: 14px; height: 14px;
  background: var(--c-paper);
  border-radius: 50%;
  box-shadow: 0 1px 2px rgba(0,0,0,0.2);
  transition: transform 0.18s;
}
.toggle-row input { display: none; }
.toggle-row input:checked + .toggle { background: var(--c-primary); }
.toggle-row input:checked + .toggle::after { transform: translateX(12px); }

/* subtask checklist */
.subtasks {
  display: flex; flex-direction: column;
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  overflow: hidden;
}
.subtasks .st {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px;
  border-bottom: 1px solid var(--c-hairline);
  cursor: pointer;
  transition: background 0.12s;
  font-size: 13px;
}
.subtasks .st:last-child { border-bottom: none; }
.subtasks .st:hover { background: var(--c-tint); }
.subtasks .st .check {
  width: 16px; height: 16px;
  border: 1.5px solid var(--c-steel);
  border-radius: 4px;
  flex-shrink: 0;
  display: grid; place-items: center;
  transition: background 0.12s, border-color 0.12s;
}
.subtasks .st.done .check {
  background: var(--s-done);
  border-color: var(--s-done);
}
.subtasks .st .check svg {
  width: 10px; height: 10px;
  color: white;
  opacity: 0;
  transition: opacity 0.12s;
}
.subtasks .st.done .check svg { opacity: 1; }
.subtasks .st .st-text {
  flex: 1;
  color: var(--c-ink);
}
.subtasks .st.done .st-text {
  text-decoration: line-through;
  color: var(--c-graphite);
}

/* system-docs drawer specific */
.sysdoc-list {
  display: flex; flex-direction: column;
  gap: 8px;
}
.sysdoc-row {
  display: flex; align-items: flex-start; gap: 12px;
  padding: 14px 16px;
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: var(--r-md);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, transform 0.18s, box-shadow 0.18s;
  text-decoration: none;
  color: inherit;
}
.sysdoc-row:hover {
  border-color: var(--c-steel);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
}
.sysdoc-row .sd-icon {
  width: 34px; height: 34px;
  background: var(--c-cloud);
  border-radius: var(--r-md);
  display: grid; place-items: center;
  color: var(--c-graphite);
  flex-shrink: 0;
}
.sysdoc-row .sd-icon svg { width: 16px; height: 16px; }
.sysdoc-row .sd-info { flex: 1; min-width: 0; }
.sysdoc-row .sd-title {
  font-family: var(--f-mono);
  font-size: 13px; font-weight: 600;
  color: var(--c-ink);
  margin-bottom: 3px;
}
.sysdoc-row .sd-desc {
  font-size: 12px;
  color: var(--c-graphite);
  line-height: 1.45;
}
.sysdoc-row .sd-path {
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
  margin-top: 6px;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.sysdoc-row .sd-arrow {
  align-self: center;
  color: var(--c-steel);
  flex-shrink: 0;
}
.sysdoc-row:hover .sd-arrow { color: var(--c-ink); }

/* toast */
.toast {
  position: fixed; bottom: 22px; left: 50%;
  transform: translateX(-50%) translateY(20px);
  z-index: 200;
  background: var(--c-ink);
  color: var(--c-on-ink);
  padding: 9px 16px;
  border-radius: 9999px;
  font-size: 12.5px; font-weight: 500;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s, transform 0.18s;
  display: inline-flex; align-items: center; gap: 8px;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.toast .ck {
  width: 14px; height: 14px;
  background: #6ee7b7;
  border-radius: 50%;
  display: grid; place-items: center;
  color: var(--c-ink);
  font-size: 10px; font-weight: 700;
}

/* utilities */
.spacer-sm { height: 8px; }
.spacer-md { height: 16px; }
.kbd-hint {
  font-family: var(--f-mono);
  font-size: 10px;
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  border-bottom-width: 2px;
  color: var(--c-charcoal);
  padding: 1px 6px;
  border-radius: 3px;
}
</style>
</head>
<body>

<header class="topbar">
  <div class="brand">
    <span class="mark" id="brand-mark">·</span>
    <span id="brand-name">Project Dashboard</span>
    <span class="crumb" data-i18n="topbar.crumb">Project Dashboard</span>
  </div>
  <div class="topbar-right">
    <span class="build-stamp"><span class="dot"></span><span><span data-i18n="topbar.last_build">Last build</span> · <span id="build-time">—</span></span></span>
    <button class="docs-btn" id="open-docs" type="button" data-i18n-title="topbar.sysdocs_title" title="System Docs (D)">
      <svg class="docs-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9A.5.5 0 0 1 3 13V2.5Z"/>
        <path d="M10 2.5V5.5h3"/>
        <line x1="5.5" y1="8" x2="10.5" y2="8"/>
        <line x1="5.5" y1="10.5" x2="9" y2="10.5"/>
      </svg>
      <span data-i18n="topbar.sysdocs_btn">System Docs</span>
      <span class="docs-count" id="docs-count">0</span>
    </button>
    <div class="lang-toggle" role="group" aria-label="Language">
      <button data-lang="en" class="active">EN</button>
      <button data-lang="zh">中</button>
    </div>
  </div>
</header>

<main class="shell">
  <section class="hero">
    <div>
      <div class="eyebrow" id="hero-eyebrow" data-i18n="hero.eyebrow">PROJECT DASHBOARD · MODULE PROGRESS</div>
      <h1 id="hero-title" data-i18n="hero.title">Project progress overview</h1>
      <p class="tagline" id="hero-tagline" data-i18n="hero.tagline">Module status · sprint progress · core concepts · one-stop visualization with fine-grained progress control.</p>
    </div>
    <div class="gauge">
      <div class="num"><span id="overall-pct">0</span>%</div>
      <div class="label" data-i18n="hero.gauge_label">Overall · module-weighted</div>
      <div class="track"><div class="fill" id="overall-fill"></div></div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="title" data-i18n="kpi.title">Overview</div>
      <div class="meta" id="kpi-meta">—</div>
    </div>
    <div class="kpi-strip">
      <div class="kpi-cell">
        <div class="k-label" data-i18n="kpi.total">Total modules</div>
        <div class="k-num" id="kpi-total">0</div>
        <div class="k-sub"><span data-i18n="kpi.total_sub_prefix">configured ·</span> <span id="kpi-concept-count">0</span> <span data-i18n="kpi.concepts_suffix">concepts</span></div>
      </div>
      <div class="kpi-cell t-done">
        <div class="k-label" data-i18n="kpi.done">Done</div>
        <div class="k-num" id="kpi-done">0</div>
        <div class="k-sub">status = done</div>
      </div>
      <div class="kpi-cell t-progress">
        <div class="k-label" data-i18n="kpi.progress">In progress · Planned</div>
        <div class="k-num" id="kpi-progress">0</div>
        <div class="k-sub"><span id="kpi-progress-active">0</span> active · <span id="kpi-progress-planned">0</span> planned</div>
      </div>
      <div class="kpi-cell t-todo">
        <div class="k-label" data-i18n="kpi.todo">Not started · Blocked</div>
        <div class="k-num" id="kpi-todo">0</div>
        <div class="k-sub"><span id="kpi-blocked">0</span> blocked</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div class="title" data-i18n="kanban.title">Module Kanban</div>
