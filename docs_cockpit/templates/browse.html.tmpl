<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Browse · docs-cockpit</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github.min.css" />
<style>
:root {
  --c-primary:        #024ad8;
  --c-primary-soft:   #eaf1fe;
  --c-canvas:         #ffffff;
  --c-paper:          #ffffff;
  --c-cloud:          #f7f7f8;
  --c-fog:            #ebebec;
  --c-hairline:       #e6e6e8;
  --c-steel:          #c5c5c8;
  --c-graphite:       #6b6b71;
  --c-charcoal:       #2f2f33;
  --c-ink:            #18181b;
  --c-on-ink:         #ffffff;
  --c-active:         #024ad8;
  --c-active-soft:    #eaf1fe;

  --f-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
  --f-mono: 'JetBrains Mono', ui-monospace, Menlo, monospace;

  --sidebar-w: 320px;
  --topbar-h: 48px;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; height: 100%; }
body {
  font-family: var(--f-sans);
  color: var(--c-ink);
  background: var(--c-canvas);
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
a { color: var(--c-primary); text-decoration: none; }
a:hover { text-decoration: underline; }
button { font: inherit; color: inherit; cursor: pointer; background: none; border: 0; }

.app {
  display: grid;
  grid-template-columns: var(--sidebar-w) 1fr;
  grid-template-rows: var(--topbar-h) 1fr;
  height: 100vh;
}

/* ── Topbar ──────────────────────────────────────── */
.topbar {
  grid-column: 1 / -1;
  display: flex;
  align-items: center;
  padding: 0 16px;
  background: var(--c-paper);
  border-bottom: 1px solid var(--c-hairline);
  gap: 16px;
}
.topbar .brand {
  display: flex; align-items: center; gap: 10px;
  font-weight: 600;
}
.topbar .brand .mark {
  width: 26px; height: 26px;
  display: grid; place-items: center;
  background: var(--c-ink); color: var(--c-on-ink);
  font-family: var(--f-mono); font-size: 13px;
  border-radius: 5px;
}
.topbar .crumb {
  font-size: 12px; color: var(--c-graphite);
  text-transform: uppercase; letter-spacing: 0.08em;
}
.topbar .stats {
  font-size: 12px;
  color: var(--c-graphite);
  font-family: var(--f-mono);
}
.topbar .spacer { flex: 1; }
.lang-toggle {
  display: inline-flex;
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  border-radius: 6px;
  overflow: hidden;
  font-family: var(--f-mono);
  font-size: 11px;
}
.lang-toggle button {
  padding: 4px 10px;
  color: var(--c-graphite);
  border: 0;
  background: none;
  cursor: pointer;
}
.lang-toggle button.active {
  background: var(--c-ink);
  color: var(--c-on-ink);
}
.lang-toggle button:hover:not(.active) {
  background: var(--c-fog);
  color: var(--c-ink);
}

/* ── Sidebar ─────────────────────────────────────── */
.sidebar {
  background: var(--c-cloud);
  border-right: 1px solid var(--c-hairline);
  overflow-y: auto;
  padding: 12px 0 24px;
}
.sidebar .search {
  padding: 0 12px 12px;
  position: sticky;
  top: 0;
  background: var(--c-cloud);
  z-index: 1;
}
.sidebar .search input {
  width: 100%;
  padding: 6px 10px;
  font-size: 13px;
  font-family: var(--f-sans);
  background: var(--c-paper);
  border: 1px solid var(--c-hairline);
  border-radius: 6px;
  color: var(--c-ink);
}
.sidebar .search input:focus {
  outline: none;
  border-color: var(--c-primary);
  box-shadow: 0 0 0 3px var(--c-primary-soft);
}

.root-section {
  margin-bottom: 8px;
}
.root-section .root-label {
  padding: 8px 12px 4px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--c-graphite);
  font-family: var(--f-mono);
}
.root-section .root-base {
  padding: 0 12px 6px;
  font-size: 11px;
  color: var(--c-steel);
  font-family: var(--f-mono);
  word-break: break-all;
}

.tree { font-size: 13px; }
.node { user-select: none; }
.node .row {
  display: flex; align-items: center;
  padding: 3px 12px 3px 0;
  cursor: pointer;
  gap: 4px;
  border-left: 2px solid transparent;
}
.node .row:hover { background: var(--c-fog); }
.node.dir > .row .twist {
  display: inline-block; width: 14px;
  font-family: var(--f-mono);
  font-size: 10px;
  color: var(--c-graphite);
  transition: transform 0.1s;
}
.node.dir.open > .row .twist { transform: rotate(0deg); }
.node.dir.closed > .row .twist { transform: rotate(-90deg); }
.node.file > .row .twist { width: 14px; }
.node .name {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.node.dir > .row .name { font-weight: 500; color: var(--c-charcoal); }
.node.file > .row .name { color: var(--c-ink); }
.node .count {
  font-size: 10px;
  color: var(--c-steel);
  font-family: var(--f-mono);
  padding-left: 4px;
}

.node.file > .row.active {
  background: var(--c-active-soft);
  border-left-color: var(--c-active);
}
.node.file > .row.active .name {
  color: var(--c-active);
  font-weight: 500;
}

.node.dir.closed > .children { display: none; }
.node .children { padding-left: 14px; }

/* Hide on search-mismatch */
.node.hidden { display: none; }

/* ── Main ────────────────────────────────────────── */
.main {
  overflow-y: auto;
  background: var(--c-canvas);
}
.main .crumbs {
  padding: 12px 24px 0;
  font-size: 12px;
  color: var(--c-graphite);
  font-family: var(--f-mono);
  word-break: break-all;
}
.main article {
  max-width: 820px;
  margin: 0 auto;
  padding: 16px 24px 80px;
}

/* Markdown styling */
.main article h1, .main article h2, .main article h3,
.main article h4, .main article h5, .main article h6 {
  margin: 1.4em 0 0.6em;
  line-height: 1.3;
  font-weight: 600;
  color: var(--c-ink);
}
.main article h1 { font-size: 28px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 8px; }
.main article h2 { font-size: 22px; border-bottom: 1px solid var(--c-hairline); padding-bottom: 6px; }
.main article h3 { font-size: 18px; }
.main article h4 { font-size: 16px; }
.main article p { margin: 0.6em 0; }
.main article ul, .main article ol { padding-left: 26px; margin: 0.5em 0; }
.main article li { margin: 0.2em 0; }
.main article li > p { margin: 0.2em 0; }
.main article blockquote {
  border-left: 3px solid var(--c-primary);
  background: var(--c-cloud);
  margin: 0.8em 0;
  padding: 0.4em 12px;
  color: var(--c-charcoal);
}
.main article code {
  background: var(--c-cloud);
  border-radius: 3px;
  padding: 1px 5px;
  font-family: var(--f-mono);
  font-size: 12.5px;
}
.main article pre {
  background: var(--c-cloud);
  border: 1px solid var(--c-hairline);
  padding: 12px 16px;
  border-radius: 6px;
  overflow-x: auto;
  font-size: 12.5px;
}
.main article pre code {
  background: none;
  padding: 0;
  border-radius: 0;
}
.main article hr {
  border: 0;
  border-top: 1px solid var(--c-hairline);
  margin: 1.5em 0;
}
.main article table {
  border-collapse: collapse;
  margin: 0.8em 0;
}
.main article th, .main article td {
  border: 1px solid var(--c-hairline);
  padding: 6px 12px;
  text-align: left;
}
.main article th { background: var(--c-cloud); font-weight: 600; }

.empty {
  display: grid;
  place-items: center;
  height: 100%;
  color: var(--c-graphite);
  font-size: 14px;
}

.cdn-banner {
  position: fixed; top: 8px; right: 8px;
  padding: 6px 12px;
  background: #dc2626; color: white;
  border-radius: 6px;
  font-size: 12px;
  display: none;
}
.cdn-banner.show { display: block; }
</style>
</head>

<body>

<script id="browse-data" type="application/json">__DOCS_JSON__</script>

<div class="app">
  <header class="topbar">
    <div class="brand">
      <span class="mark" id="brand-mark">·</span>
      <span id="brand-name">Browse</span>
    </div>
    <span class="crumb" id="brand-crumb" data-i18n="browse.crumb">MARKDOWN BROWSER</span>
    <div class="stats" id="stats">— files</div>
    <div class="spacer"></div>
    <div class="lang-toggle" role="group" aria-label="Language">
      <button data-lang="en" class="active">EN</button>
      <button data-lang="zh">中</button>
    </div>
  </header>

  <aside class="sidebar">
    <div class="search">
      <input id="search" type="text" data-i18n-placeholder="browse.search_placeholder" placeholder="Search file path..." />
    </div>
    <div id="tree-root"></div>
  </aside>

  <main class="main">
    <div class="crumbs" id="crumbs"></div>
    <article id="content">
      <div class="empty" data-i18n="browse.empty_state">Click a file in the sidebar to read</div>
    </article>
  </main>
</div>

<div class="cdn-banner" id="cdn-banner" data-i18n="browse.cdn_banner">⚠️ marked.js / highlight.js failed to load · MD shown as plain text</div>

<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/core.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/python.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/javascript.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/typescript.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/bash.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/yaml.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/json.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/markdown.min.js"></script>

<script>
(function() {
  'use strict';

  const DATA = JSON.parse(document.getElementById('browse-data').textContent);
  const STORAGE_KEY = 'docs-cockpit-browse-v1::' + (DATA.project || 'default');

  // ── i18n ───────────────────────────────────────────
  const I18N = {
    en: {
      'browse.crumb': 'MARKDOWN BROWSER',
      'browse.search_placeholder': 'Search file path...',
      'browse.empty_state': 'Click a file in the sidebar to read',
      'browse.cdn_banner': '⚠️ marked.js / highlight.js failed to load · MD shown as plain text',
      'stats.files': '{n} files · build {time}',
      'browse.empty_root': 'No files in this section',
    },
    zh: {
      'browse.crumb': '文档浏览器',
      'browse.search_placeholder': '搜索文件名 / 路径...',
      'browse.empty_state': '点击左侧文件开始阅读',
      'browse.cdn_banner': '⚠️ marked.js / highlight.js 加载失败 · MD 显示为原文',
      'stats.files': '{n} 份 · 构建于 {time}',
      'browse.empty_root': '此分类下无文件',
    }
  };
  let LANG = (localStorage.getItem(STORAGE_KEY + '::lang') || 'en');
  function t(key, vars) {
    let s = (I18N[LANG] && I18N[LANG][key]) || I18N.en[key] || key;
    if (vars) for (const k in vars) s = s.split('{' + k + '}').join(vars[k]);
    return s;
  }
  function applyI18nStatic() {
    document.documentElement.lang = (LANG === 'zh' ? 'zh-CN' : 'en');
    document.querySelectorAll('[data-i18n]').forEach(el => {
      el.textContent = t(el.dataset.i18n);
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      el.placeholder = t(el.dataset.i18nPlaceholder);
    });
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === LANG);
    });
  }

  // ── CDN guard ──────────────────────────────────────
  if (typeof marked === 'undefined') {
    document.getElementById('cdn-banner').classList.add('show');
    window.marked = { parse: (s) => '<pre>' + escapeHtml(s) + '</pre>' };
  }
  if (typeof hljs !== 'undefined' && hljs.registerLanguage) {
    ['python', 'javascript', 'typescript', 'bash', 'yaml', 'json', 'markdown']
      .forEach(lang => {
        if (hljs.getLanguage && !hljs.getLanguage(lang)) { /* already auto-loaded */ }
      });
  }

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // ── Project meta ───────────────────────────────────
  function renderMeta() {
    const p = DATA.project || 'Browse';
    document.getElementById('brand-name').textContent = p;
    document.getElementById('brand-mark').textContent =
      (DATA.mark || (p[0] || 'B')).toUpperCase();
    document.title = p + ' · Browse';
    const total = (DATA.roots || []).reduce((a, r) => a + (r.files || []).length, 0);
    document.getElementById('stats').textContent =
      t('stats.files', { n: total, time: DATA.build_time || '—' });
  }

  // ── Build hierarchical tree from flat file paths ──
  function buildTree(files) {
    // root = { _children: {}, _files: [] }
    const root = { _children: {}, _files: [] };
    for (const f of files) {
      const parts = f.path.split('/').filter(Boolean);
      let cursor = root;
      for (let i = 0; i < parts.length - 1; i++) {
        const dirName = parts[i];
        if (!cursor._children[dirName]) {
          cursor._children[dirName] = { _children: {}, _files: [] };
        }
        cursor = cursor._children[dirName];
      }
      cursor._files.push({ ...f, _name: parts[parts.length - 1] });
    }
    return root;
  }

  // ── Render tree recursively ─────────────────────
  function renderNode(node, container, depth, expandState) {
    // Dirs first (sorted), then files (sorted)
    const dirNames = Object.keys(node._children).sort((a, b) =>
      a.localeCompare(b, 'zh-Hans-CN-u-kn-true')
    );
    for (const name of dirNames) {
      const child = node._children[name];
      const totalFiles = countFiles(child);
      const key = container.dataset.path
        ? container.dataset.path + '/' + name
        : name;
      const isOpen = expandState[key] !== false; // default expanded
      const el = document.createElement('div');
      el.className = 'node dir ' + (isOpen ? 'open' : 'closed');
      el.dataset.path = key;
      el.innerHTML =
        '<div class="row">' +
          '<span class="twist">▼</span>' +
          '<span class="name">' + escapeHtml(name) + '/</span>' +
          '<span class="count">' + totalFiles + '</span>' +
        '</div>' +
        '<div class="children"></div>';
      const row = el.querySelector('.row');
      row.addEventListener('click', () => {
        el.classList.toggle('open');
        el.classList.toggle('closed');
        expandState[key] = el.classList.contains('open');
        saveExpandState(expandState);
      });
      container.appendChild(el);
      renderNode(child, el.querySelector('.children'), depth + 1, expandState);
    }
    const files = node._files.slice().sort((a, b) =>
      a._name.localeCompare(b._name, 'zh-Hans-CN-u-kn-true')
    );
    for (const f of files) {
      const el = document.createElement('div');
      el.className = 'node file';
      el.dataset.filePath = f.path;
      el.innerHTML =
        '<div class="row">' +
          '<span class="twist">·</span>' +
          '<span class="name">' + escapeHtml(f._name.replace(/\.md$/i, '')) + '</span>' +
        '</div>';
      el.querySelector('.row').addEventListener('click', () => showFile(f));
      container.appendChild(el);
    }
  }

  function countFiles(node) {
    let n = node._files.length;
    for (const c of Object.values(node._children)) n += countFiles(c);
    return n;
  }

  function saveExpandState(state) {
    try { localStorage.setItem(STORAGE_KEY + '::expand', JSON.stringify(state)); } catch (e) {}
  }
  function loadExpandState() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY + '::expand') || '{}'); }
    catch (e) { return {}; }
  }

  // ── Show file content ──────────────────────────────
  let _currentPath = null;
  function showFile(f) {
    _currentPath = f.path;
    // Update active highlight
    document.querySelectorAll('.node.file .row.active').forEach(el =>
      el.classList.remove('active')
    );
    const target = document.querySelector(
      `.node.file[data-file-path="${CSS.escape(f.path)}"] .row`
    );
    if (target) target.classList.add('active');
    // Crumbs
    document.getElementById('crumbs').textContent = f.path;
    // Render content
    const content = document.getElementById('content');
    try {
      content.innerHTML = marked.parse(f.content || '');
    } catch (e) {
      content.innerHTML = '<pre>' + escapeHtml(f.content || '') + '</pre>';
    }
    // Syntax highlight
    if (typeof hljs !== 'undefined' && hljs.highlightElement) {
      content.querySelectorAll('pre code').forEach(b => {
        try { hljs.highlightElement(b); } catch (e) {}
      });
    }
    // Scroll to top
    document.querySelector('.main').scrollTop = 0;
    // Save last viewed
    try { localStorage.setItem(STORAGE_KEY + '::last', f.path); } catch (e) {}
  }

  // ── Search filter ──────────────────────────────────
  function applySearch(q) {
    q = q.trim().toLowerCase();
    if (!q) {
      document.querySelectorAll('.node').forEach(el => el.classList.remove('hidden'));
      return;
    }
    // Mark files: show only matching · then show parent dirs of any visible file
    document.querySelectorAll('.node.file').forEach(el => {
      const path = (el.dataset.filePath || '').toLowerCase();
      const match = path.includes(q);
      el.classList.toggle('hidden', !match);
    });
    document.querySelectorAll('.node.dir').forEach(el => {
      const visibleFiles = el.querySelectorAll('.node.file:not(.hidden)').length;
      el.classList.toggle('hidden', visibleFiles === 0);
      if (visibleFiles > 0) {
        el.classList.add('open');
        el.classList.remove('closed');
      }
    });
  }

  // ── Init ───────────────────────────────────────────
  function init() {
    applyI18nStatic();
    renderMeta();

    // Lang toggle handler
    document.querySelectorAll('.lang-toggle button').forEach(btn => {
      btn.addEventListener('click', () => {
        LANG = btn.dataset.lang;
        try { localStorage.setItem(STORAGE_KEY + '::lang', LANG); } catch (e) {}
        applyI18nStatic();
        renderMeta();
      });
    });

    const expandState = loadExpandState();
    const treeRoot = document.getElementById('tree-root');

    // Render each root section
    for (const root of (DATA.roots || [])) {
      const sec = document.createElement('div');
      sec.className = 'root-section';
      sec.innerHTML =
        '<div class="root-label">' + escapeHtml(root.label || root.id) + '</div>' +
        (root.base ? '<div class="root-base">' + escapeHtml(root.base) + '</div>' : '') +
        '<div class="tree" data-path="' + escapeHtml(root.id) + '"></div>';
      treeRoot.appendChild(sec);
      const tree = buildTree(root.files || []);
      const treeEl = sec.querySelector('.tree');
      treeEl.dataset.path = root.id;
      renderNode(tree, treeEl, 0, expandState);
    }

    // Search
    document.getElementById('search').addEventListener('input', e => {
      applySearch(e.target.value);
    });

    // Restore last viewed
    let lastPath = null;
    try { lastPath = localStorage.getItem(STORAGE_KEY + '::last'); } catch (e) {}
    if (lastPath) {
      // Find file across roots
      for (const root of (DATA.roots || [])) {
        const f = (root.files || []).find(x => x.path === lastPath);
        if (f) { showFile(f); break; }
      }
    }

    // Keyboard nav
    document.addEventListener('keydown', e => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (document.activeElement && document.activeElement.tagName) || '';
      if (tag === 'INPUT' || tag === 'TEXTAREA') {
        if (e.key === 'Escape') document.activeElement.blur();
        return;
      }
      if (e.key === '/' || (e.key === 'k' && !e.ctrlKey)) {
        e.preventDefault();
        document.getElementById('search').focus();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
